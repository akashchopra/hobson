{
  "id": "a5e1fd60-8c4c-4cee-a0e0-f060aa75f739",
  "name": "field-editor-checkbox",
  "type": "66666666-0000-0000-0000-000000000000",
  "created": 1768550742282,
  "modified": 1775756666118,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Field editor for boolean values, rendered as a checkbox with optional label. Used by "
        },
        [
          ":item-ref",
          {
            "s": "ffd688d1-93a8-4c4b-b09a-127b249294f5"
          },
          {
            "s": "generic-editor"
          }
        ],
        {
          "s": " for fields with "
        },
        [
          ":code",
          {
            "s": "editor: 'checkbox'"
          }
        ],
        {
          "s": "."
        }
      ],
      [
        ":h2",
        {
          "s": "Options"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "label"
              }
            ],
            {
              "s": ": Text displayed next to checkbox"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "readonly"
              }
            ],
            {
              "s": ": Disables the checkbox"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Example ui_hints"
        }
      ],
      [
        ":code-block",
        {
          "s": "ui_hints: {\n  \"content.enabled\": { editor: \"checkbox\", label: \"Enable feature\" }\n}"
        }
      ]
    ],
    "code": "\nexport function render(value, onChange, api, options = {}) {\n  const wrapper = api.createElement('label', {\n    style: 'display: flex; align-items: center; gap: 8px; cursor: pointer;'\n  });\n\n  const checkbox = api.createElement('input', {\n    type: 'checkbox',\n    checked: !!value,\n    style: 'width: 18px; height: 18px; cursor: pointer;',\n    onchange: (e) => onChange(e.target.checked)\n  });\n\n  if (options.readonly) {\n    checkbox.disabled = true;\n  }\n\n  wrapper.appendChild(checkbox);\n\n  if (options.label) {\n    const labelText = api.createElement('span', {}, [options.label]);\n    wrapper.appendChild(labelText);\n  }\n\n  return wrapper;\n}\n",
