{
  "id": "c0c0c0c0-0036-0000-0000-000000000000",
  "name": "Testing",
  "type": "871ae771-b9b1-4f40-8c7f-d9038bfb69c3",
  "created": 1770508800000,
  "modified": 1773243817563,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Testing in Hobson follows the same principles as everything else in the system: tests are items, they run inside Hobson, and they use existing infrastructure rather than introducing special-cased machinery."
        }
      ],
      [
        ":p",
        {
          "s": "The key insight is that "
        },
        [
          ":strong",
          {
            "s": "nested instances provide everything a test environment needs"
          }
        ],
        {
          "s": ": isolated storage (via ID prefixing), isolated DOM (via the iframe), and free cleanup (via cascade delete on instance deletion). Tests run inside a forked copy of the system, exercising real views, real rendering, and real storage — just in a disposable context."
        }
      ],
      [
        ":h2",
        {
          "s": "Design Principles"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Tests are items"
              }
            ],
            {
              "s": " — No external test harness. Test definitions, the assertion library, and the test runner are all regular items."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Use existing infrastructure"
              }
            ],
            {
              "s": " — Nested instances for isolation, the rendering system for UI testing, the module system for loading test code."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Test the real system"
              }
            ],
            {
              "s": " — Tests exercise live code inside a real Hobson environment, not mocks or simulations."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Inspectable results"
              }
            ],
            {
              "s": " — Test outcomes are visible as rendered items, not hidden in a console log."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "No kernel changes"
              }
            ],
            {
              "s": " — Everything is implemented as user-space items."
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Items"
        }
      ],
      [
        ":h3",
        {
          "s": "test tag"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "ID:"
          }
        ],
        {
          "s": " "
        },
        [
          ":code",
          {
            "s": "c0c0c0c0-0070-0000-0000-000000000000"
          }
        ],
        {
          "s": " — "
        },
        [
          ":strong",
          {
            "s": "Type:"
          }
        ],
        {
          "s": " NOTE (used as tag)"
        }
      ],
      [
        ":p",
        {
          "s": "A tag item for test discovery. The test runner queries for all items with this tag. Same pattern as "
        },
        [
          ":code",
          {
            "s": "concept"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "idea"
          }
        ],
        {
          "s": ", and "
        },
        [
          ":code",
          {
            "s": "starred"
          }
        ],
        {
          "s": " tags. Has a green color ("
        },
        [
          ":code",
          {
            "s": "#22c55e"
          }
        ],
        {
          "s": ")."
        }
      ],
      [
        ":h3",
        {
          "s": "test-lib"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "ID:"
          }
        ],
        {
          "s": " "
        },
        [
          ":code",
          {
            "s": "7e570001-0000-4000-8000-000000000000"
          }
        ],
        {
          "s": " — "
        },
        [
          ":strong",
          {
            "s": "Type:"
          }
        ],
        {
          "s": " LIBRARY"
        }
      ],
      [
        ":p",
        {
          "s": "Minimal assertion, test-grouping, and DOM-waiting API. Each test file calls "
        },
        [
          ":code",
          {
            "s": "createSuite(name)"
          }
        ],
        {
          "s": " to get its own isolated result collector — no shared module-level state."
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Exports:"
          }
        ]
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "createSuite(name)"
              }
            ],
            {
              "s": " — Returns "
            },
            [
              ":code",
              {
                "s": "{ test, testAsync, getResults }"
              }
            ],
            {
              "s": ". Each result tracks "
            },
            [
              ":code",
              {
                "s": "name"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "passed"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "error"
              }
            ],
            {
              "s": ", and "
            },
            [
              ":code",
              {
                "s": "symbol"
              }
            ],
            {
              "s": " (the test function's "
            },
            [
              ":code",
              {
                "s": ".name"
              }
            ],
            {
              "s": ", used for source navigation in the runner UI)."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "assert(condition, message)"
              }
            ],
            {
              "s": " — Throws if falsy."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "assertEquals(actual, expected, message)"
              }
            ],
            {
              "s": " — Strict equality with JSON diff in error message."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "assertDeepEquals(actual, expected, message)"
              }
            ],
            {
              "s": " — Recursive structural equality."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "waitFor(fn, { timeout, interval })"
              }
            ],
            {
              "s": " — Polls "
            },
            [
              ":code",
              {
                "s": "fn()"
              }
            ],
            {
              "s": " until truthy. Defaults: 2s timeout, 50ms interval. Useful for waiting on rendering."
            }
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "test-suite"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "ID:"
          }
        ],
        {
          "s": " "
        },
        [
          ":code",
          {
            "s": "7e570002-0000-4000-8000-000000000000"
          }
        ],
        {
          "s": " — "
        },
        [
          ":strong",
          {
            "s": "Type:"
          }
        ],
        {
          "s": " TYPE_DEFINITION (extends ATOM)"
        }
      ],
      [
        ":p",
        {
          "s": "A container type for running tests. Navigate to a "
        },
        [
          ":code",
          {
            "s": "test-suite"
          }
        ],
        {
          "s": " item to see the test runner UI. Its "
        },
        [
          ":code",
          {
            "s": "preferredView"
          }
        ],
        {
          "s": " points to "
        },
        [
          ":code",
          {
            "s": "test-runner-view"
          }
        ],
        {
          "s": ". The item's "
        },
        [
          ":code",
          {
            "s": "content.lastRun"
          }
        ],
        {
          "s": " stores the most recent test results for display on reload."
        }
      ],
      [
        ":h3",
        {
          "s": "test-runner-view"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "ID:"
          }
        ],
        {
          "s": " "
        },
        [
          ":code",
          {
            "s": "7e570003-0000-4000-8000-000000000000"
          }
        ],
        {
          "s": " — "
        },
        [
          ":strong",
          {
            "s": "Type:"
          }
        ],
        {
          "s": " VIEW — "
        },
        [
          ":strong",
          {
            "s": "For type:"
          }
        ],
        {
          "s": " "
        },
        [
          ":code",
          {
            "s": "test-suite"
          }
        ]
      ],
      [
        ":p",
        {
          "s": "The parent-side UI. Discovers test items and orchestrates test runs via nested instances. On \"Run All\":"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Copies all items"
              }
            ],
            {
              "s": " into a new nested instance namespace via direct IndexedDB writes (bypasses kernel to avoid side effects)."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Creates a `hobson-instance` item"
              }
            ],
            {
              "s": " and opens it as a sibling viewport."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Waits for a `test-instance-ready` postMessage"
              }
            ],
            {
              "s": " from the child (sent by "
            },
            [
              ":code",
              {
                "s": "test-runner-service"
              }
            ],
            {
              "s": " on boot)."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Receives `test-progress` messages"
              }
            ],
            {
              "s": " as each suite completes, updating the UI incrementally."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Receives a `test-complete` message"
              }
            ],
            {
              "s": " with the full "
            },
            [
              ":code",
              {
                "s": "lastRun"
              }
            ],
            {
              "s": " payload, which it persists to the test-suite item."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Shows a \"Clean Up Instance\" button"
              }
            ],
            {
              "s": " — the nested instance stays alive for inspection until explicitly deleted."
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "The view also restores and displays the last run's results on load, so results survive page refreshes."
        }
      ],
      [
        ":p",
        {
          "s": "Each test item row shows a pass/fail indicator, count, and expandable details. Individual test names are clickable links that navigate to the test item's code (opening at the relevant symbol if available via "
        },
        [
          ":code",
          {
            "s": "api.siblingContainer.addSibling"
          }
        ],
        {
          "s": ")."
        }
      ],
      [
        ":h3",
        {
          "s": "test-runner-service"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "ID:"
          }
        ],
        {
          "s": " "
        },
        [
          ":code",
          {
            "s": "7e570009-0000-4000-8000-000000000000"
          }
        ],
        {
          "s": " — "
        },
        [
          ":strong",
          {
            "s": "Type:"
          }
        ],
        {
          "s": " CODE"
        }
      ],
      [
        ":p",
        {
          "s": "The child-side counterpart. Watches for "
        },
        [
          ":code",
          {
            "s": "kernel:boot-complete"
          }
        ],
        {
          "s": " and, if running inside a nested instance ("
        },
        [
          ":code",
          {
            "s": "api.getInstanceId()"
          }
        ],
        {
          "s": " is truthy), immediately auto-runs all tests:"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            {
              "s": "Discovers test items (tagged with "
            },
            [
              ":code",
              {
                "s": "test"
              }
            ],
            {
              "s": ", having "
            },
            [
              ":code",
              {
                "s": "name"
              }
            ],
            {
              "s": " and "
            },
            [
              ":code",
              {
                "s": "content.code"
              }
            ],
            {
              "s": ")."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Creates a hidden off-screen test area for rendering viewports."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "For each test item, loads it via "
            },
            [
              ":code",
              {
                "s": "api.require(name)"
              }
            ],
            {
              "s": " and calls its "
            },
            [
              ":code",
              {
                "s": "run(testApi)"
              }
            ],
            {
              "s": " function."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Reports results back to the parent via "
            },
            [
              ":code",
              {
                "s": "postMessage"
              }
            ],
            {
              "s": " ("
            },
            [
              ":code",
              {
                "s": "test-progress"
              }
            ],
            {
              "s": " per suite, "
            },
            [
              ":code",
              {
                "s": "test-complete"
              }
            ],
            {
              "s": " at the end)."
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "The "
        },
        [
          ":strong",
          {
            "s": "testApi"
          }
        ],
        {
          "s": " passed to each test's "
        },
        [
          ":code",
          {
            "s": "run()"
          }
        ],
        {
          "s": " function wraps the kernel API with testing conveniences:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "set(item)"
              }
            ],
            {
              "s": " — Creates/updates an item (uses "
            },
            [
              ":code",
              {
                "s": "{ silent: true }"
              }
            ],
            {
              "s": " to avoid re-renders)."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "get(id)"
              }
            ],
            {
              "s": " — Returns item or "
            },
            [
              ":code",
              {
                "s": "null"
              }
            ],
            {
              "s": " (swallows not-found errors)."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "delete(id)"
              }
            ],
            {
              "s": " — Deletes an item (swallows errors)."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "query(filter)"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "getAll()"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "require(name)"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "typeChainIncludes(typeId, targetId)"
              }
            ],
            {
              "s": " — Direct delegates."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "attach(parentId, itemId)"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "detach(parentId, itemId)"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "findContainerOf(itemId)"
              }
            ],
            {
              "s": " — Attachment operations."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "events"
              }
            ],
            {
              "s": " — The kernel event bus."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "openViewport(itemId, viewId?)"
              }
            ],
            {
              "s": " — Creates an 800x600 div in the hidden test area, renders the item into it via "
            },
            [
              ":code",
              {
                "s": "api.renderItem()"
              }
            ],
            {
              "s": ", returns the container element. Tests query within this scoped element."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "closeViewport(el)"
              }
            ],
            {
              "s": " — Removes the viewport element."
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "Each test item gets a 30s timeout. The entire run has a 120s timeout."
        }
      ],
      [
        ":h2",
        {
          "s": "Test Items"
        }
      ],
      [
        ":p",
        {
          "s": "Test items are CODE items tagged with "
        },
        [
          ":code",
          {
            "s": "test"
          }
        ],
        {
          "s": " that export an async "
        },
        [
          ":code",
          {
            "s": "run(testApi)"
          }
        ],
        {
          "s": " function returning an array of result objects "
        },
        [
          ":code",
          {
            "s": "{ name, passed, error?, symbol? }"
          }
        ],
        {
          "s": "."
        }
      ],
      [
        ":p",
        {
          "s": "18 test suites exist, covering storage, rendering, modules, events, and extensive Hob language coverage (reader, evaluator, stdlib, macros, destructuring, concurrency, atoms, errors, DOM, views, watches, reactivity, integration):"
        }
