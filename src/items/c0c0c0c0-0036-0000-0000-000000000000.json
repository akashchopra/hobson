        ":h2",
        {
          "s": "What This Does Not Include"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Mocking"
              }
            ],
            {
              "s": " — Tests run against real storage, real rendering, real code. No mock framework."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Coverage tracking"
              }
            ],
            {
              "s": " — No bytecode instrumentation."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "CI/CD integration"
              }
            ],
            {
              "s": " — Hobson is offline-first and browser-based. Tests are run by the user, inside the system."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Snapshot testing"
