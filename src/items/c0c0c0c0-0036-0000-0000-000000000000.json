      [
        ":p",
        {
          "s": "The test suites use named functions for each test case (e.g. "
        },
        [
          ":code",
          {
            "s": "async function createsAnItem() { ... }"
          }
        ],
        {
          "s": ") so that "
        },
        [
          ":code",
          {
            "s": "fn.name"
          }
        ],
        {
          "s": " is captured as the "
        },
        [
          ":code",
          {
            "s": "symbol"
          }
        ],
        {
          "s": " field. This lets the runner UI link directly to the test function's source."
        }
      ],
      [
        ":h2",
        {
          "s": "Test Suite Instance"
        }
      ],
      [
        ":p",
        {
          "s": "A "
        },
        [
          ":code",
          {
            "s": "Test Suite"
          }
        ],
        {
          "s": " item ("
        },
        [
          ":code",
          {
            "s": "56a2c83c-1fd4-4db7-a3e8-3aa152524721"
          }
        ],
        {
          "s": ") of type "
        },
        [
          ":code",
          {
            "s": "test-suite"
          }
        ],
        {
          "s": " exists and stores the last run results in "
        },
        [
          ":code",
          {
            "s": "content.lastRun"
          }
        ],
        {
          "s": "."
        }
      ],
      [
        ":h2",
        {
          "s": "Writing a New Test"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            {
              "s": "Create a CODE item with a kebab-case name (e.g. "
            },
            [
              ":code",
              {
                "s": "my-feature-tests"
              }
            ],
            {
              "s": ")."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Tag it with the "
            },
            [
              ":code",
              {
                "s": "test"
              }
            ],
            {
              "s": " tag ("
            },
            [
              ":code",
              {
                "s": "c0c0c0c0-0070-0000-0000-000000000000"
              }
            ],
            {
              "s": ")."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Export an async "
            },
            [
              ":code",
              {
                "s": "run(api)"
              }
            ],
            {
              "s": " function that uses "
            },
            [
              ":code",
              {
                "s": "test-lib"
              }
            ],
            {
              "s": ":"
            }
          ]
        ]
      ],
      [
        ":code-block",
        {
          "s": "export async function run(api) {\n  const { createSuite, assert, assertEquals } = await api.require('test-lib');\n  const { testAsync, getResults } = createSuite('My Feature');\n\n  async function doesSomething() {\n    // ... use api.set(), api.get(), api.openViewport(), etc.\n    assert(true, 'it works');\n  }\n\n  await testAsync('does something', doesSomething);\n  return getResults();\n}"
        }
      ],
      [
        ":p",
        {
          "s": "Use named functions for test cases so the runner can link to them by symbol. Since tests run inside a nested instance, items created via "
        },
        [
          ":code",
          {
            "s": "api.set()"
          }
        ],
        {
          "s": " are automatically prefixed and isolated — no manual cleanup needed."
        }
      ],
