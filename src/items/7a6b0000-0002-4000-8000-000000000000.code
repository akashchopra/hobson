;; tab-state-lib — Session-only active tab tracking for workspace views.
;; Module-level atom persists across require calls via Hob module cache.

(def state (atom {}))

(defn get-active-tab [workspace-id]
  (get (deref state) workspace-id))

(defn set-active-tab! [workspace-id tab-id]
  (swap! state assoc workspace-id tab-id))
