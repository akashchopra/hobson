    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "A range slider widget for use in app-pages."
        }
      ],
      [
        ":p",
        {
          "s": "The slider writes its numeric value to shared page state via "
        },
        [
          ":code",
          {
            "s": "stateKey"
          }
        ],
        {
          "s": ", enabling other widgets (like buttons) to read it."
        }
      ],
      [
        ":h3",
        {
          "s": "Content Fields"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "label"
              }
            ],
            {
              "s": " (string) - Slider label displayed to the left"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "min"
              }
            ],
            {
              "s": " (number) - Minimum value (default: 0)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "max"
              }
            ],
            {
              "s": " (number) - Maximum value (default: 100)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "step"
              }
            ],
            {
              "s": " (number) - Step increment (default: 1)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "stateKey"
              }
            ],
            {
              "s": " (string) - Key to write the value to in page state"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "defaultValue"
              }
            ],
            {
              "s": " (number) - Initial value (default: min)"
            }
          ]
        ]
      ]
    ],
