  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "A runtime debugging tool for identifying which items and views are responsible for rendered UI elements."
        }
      ],
      [
        ":p",
        {
          "s": "Instances of this type provide an interactive inspector interface with controls to enable debug mode, trigger element inspection, and view results showing the rendering chain for any clicked element."
        }
      ],
      [
        ":h2",
        {
          "s": "How It Works"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            {
              "s": "Enable debug mode (adds "
            },
            [
              ":code",
              {
                "s": "data-*"
              }
            ],
            {
              "s": " attributes to rendered elements during render)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Click \"Inspect Element\" to enter inspect mode"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Hover over any element to highlight it, click to inspect"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "View the rendering chain: which item, view, and source code produced each element"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Click links in the results to navigate directly to the responsible code"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "See Also"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "eeee0000-0000-0000-0000-000000000001"
              },
              {
                "s": "element-inspector (library)"
              }
            ],
            {
              "s": " — the underlying library with "
            },
            [
              ":code",
              {
                "s": "inspectOnce"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "collectElementInfo"
              }
            ],
            {
              "s": ", and "
            },
            [
              ":code",
