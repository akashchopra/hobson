              {
                "s": "aaaaaaaa-0000-0000-0000-000000000000"
              },
              {
                "s": "kernel:view"
              }
            ],
            {
              "s": " — Imperative view code"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "cccccccc-0000-0000-0000-000000000000"
              },
              {
                "s": "field-view"
              }
            ],
            {
              "s": " — Field-level rendering components"
            }
          ]
        ]
      ]
    ],
    "tags": [
      "c0c0c0c0-0033-0000-0000-000000000000"
