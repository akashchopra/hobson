{
  "id": "bbbbbbbb-0000-0000-0000-000000000000",
  "name": "view-spec",
  "type": "11111111-0000-0000-0000-000000000000",
  "extends": "00000000-0000-0000-0000-000000000000",
  "created": 1769279958484,
  "modified": 1774988059719,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "A declarative way to define how an item is displayed without writing JavaScript code. View-specs use "
        },
        [
          ":code",
          {
            "s": "ui_hints"
          }
        ],
        {
          "s": " to describe which fields to show and how."
        }
      ],
      [
        ":h2",
        {
          "s": "When to Use View-Spec vs View"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Use View-Spec when..."
              }
            ],
            [
              ":th",
              {
                "s": "Use "
              },
              [
                ":item-ref",
                {
                  "s": "aaaaaaaa-0000-0000-0000-000000000000"
                },
                {
                  "s": "View"
                }
              ],
              {
                "s": " when..."
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              {
                "s": "Standard form-like layout"
              }
            ],
            [
              ":td",
              {
                "s": "Custom visual design"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Displaying/editing fields"
              }
            ],
            [
              ":td",
              {
                "s": "Complex interactivity"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Rapid prototyping"
              }
            ],
            [
              ":td",
              {
                "s": "Conditional rendering"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "No custom logic needed"
              }
            ],
            [
              ":td",
              {
                "s": "Computed displays"
              }
            ]
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Structure"
        }
      ],
      [
        ":code-block",
        {
          "s": "{\n  id: crypto.randomUUID(),\n  name: \"my-type-view-spec\",\n  type: \"bbbbbbbb-0000-0000-0000-000000000000\",  // view-spec\n  content: {\n    for_type: \"my-type-uuid\",\n    displayName: \"My Type Editor\",\n    description: \"Standard editing view for my-type items\",\n    ui_hints: [\n      { field: \"title\", label: \"Title\", component: \"text\", mode: \"editable\" },\n      { field: \"description\", label: \"Content\", component: \"markdown\", mode: \"editable\" },\n      { field: \"created\", label: \"Created\", component: \"timestamp\", mode: \"readonly\" }\n    ]\n  }\n}"
        }
      ],
      [
        ":h2",
        {
          "s": "The "
        },
        [
          ":code",
          {
            "s": "ui_hints"
          }
        ],
        {
          "s": " Array"
        }
      ],
      [
        ":p",
        {
          "s": "Each hint describes one field to render:"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Property"
              }
            ],
            [
              ":th",
              {
                "s": "Description"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "field"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Path to the value in "
              },
              [
                ":code",
                {
                  "s": "item.content"
                }
              ],
              {
                "s": " (e.g., "
              },
              [
                ":code",
                {
                  "s": "\"title\""
                }
              ],
              {
                "s": ", "
              },
              [
                ":code",
                {
                  "s": "\"metadata.author\""
                }
              ],
              {
                "s": ")"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "label"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Human-readable label shown above the field"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "component"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Which "
              },
              [
                ":item-ref",
                {
                  "s": "cccccccc-0000-0000-0000-000000000000"
                },
                {
                  "s": "field-view"
                }
              ],
              {
                "s": " to use"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "mode"
                }
              ]
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "\"readonly\""
                }
              ],
              {
                "s": " or "
              },
              [
                ":code",
                {
                  "s": "\"editable\""
                }
              ]
            ]
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Available Components"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Component"
              }
            ],
            [
              ":th",
              {
                "s": "Purpose"
              }
            ],
            [
              ":th",
              {
                "s": "Modes"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "text"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Single-line text"
              }
            ],
            [
              ":td",
              {
                "s": "readonly, editable"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "textarea"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Multi-line plain text"
              }
            ],
            [
              ":td",
              {
                "s": "readonly, editable"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "markdown"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Markdown with rendering"
              }
            ],
            [
              ":td",
              {
                "s": "readonly, editable"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "code"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Syntax-highlighted code"
              }
            ],
            [
              ":td",
              {
                "s": "readonly, editable"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "checkbox"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Boolean toggle"
              }
            ],
            [
              ":td",
              {
                "s": "readonly, editable"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "number"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Numeric input"
              }
            ],
            [
              ":td",
              {
                "s": "readonly, editable"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "timestamp"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Date/time display"
              }
            ],
            [
              ":td",
              {
                "s": "readonly"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "json"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Raw JSON editing"
              }
            ],
            [
              ":td",
              {
                "s": "readonly, editable"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "heading"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Section header (display only)"
              }
            ],
            [
              ":td",
              {
                "s": "readonly"
              }
            ]
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "How It Works"
        }
      ],
      [
        ":p",
        [
          ":item-ref",
          {
            "s": "b429b19d-ef0d-4f4f-b2a2-b9e6f80451f2"
          },
          {
            "s": "generic-view"
          }
        ],
        {
          "s": " interprets view-specs:"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            {
              "s": "Loads the view-spec for the item's type"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Iterates through "
            },
            [
              ":code",
              {
                "s": "ui_hints"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "For each hint, loads the appropriate field-view component"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Renders field-views with values from "
            },
            [
              ":code",
              {
                "s": "item.content"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "In editable mode, field changes are saved back to the item"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Example: Note Type View-Spec"
        }
      ],
      [
        ":code-block",
        {
          "s": "ui_hints: [\n  { \n    field: \"title\", \n    label: \"Title\", \n    component: \"heading\",\n    mode: \"editable\" \n  },\n  { \n    field: \"description\", \n    label: \"Content\", \n    component: \"markdown\", \n    mode: \"editable\" \n  },\n  { \n    field: \"tags\", \n    label: \"Tags\", \n    component: \"tags\", \n    mode: \"editable\" \n  }\n]"
        }
      ],
      [
        ":h2",
        {
          "s": "Extending with Custom Components"
        }
      ],
      [
        ":p",
        {
          "s": "Create new "
        },
        [
          ":item-ref",
          {
            "s": "cccccccc-0000-0000-0000-000000000000"
          },
          {
            "s": "field-view"
          }
        ],
        {
          "s": " items to add custom components. Once created, reference them by name in "
        },
        [
          ":code",
          {
            "s": "ui_hints"
          }
        ],
        {
          "s": "."
        }
      ],
      [
        ":h2",
        {
          "s": "See Also"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
