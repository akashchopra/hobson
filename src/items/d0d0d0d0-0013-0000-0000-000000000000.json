    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Creates image items from various sources: data URLs, Blobs/Files, or filesystem paths (Tauri). Used by obsidian-import and the image editor. "
        }
      ]
    ],
    "code": "// image-import-lib — Creates image items from various sources\n// Used by obsidian-import, paste handlers, and the image editor\n\nconst IMAGE_TYPE = 'd0d0d0d0-0010-0000-0000-000000000000';\n\n/** Create an image item from a base64 data URL.\n * @param {Object} api - Hobson API\n * @param {string} dataUrl - Base64 data URL (data:image/png;base64,...)\n * @param {Object} [opts] - Options: name, alt\n * @returns {Promise<string>} The new image item's ID\n */\nexport async function fromDataUrl(api, dataUrl, opts = {}) {\n  const mimeMatch = dataUrl.match(/^data:([^;]+);/);\n  const mimeType = mimeMatch ? mimeMatch[1] : 'image/png';\n  const base64 = dataUrl.split(',')[1];\n  const bytes = Uint8Array.from(atob(base64), c => c.charCodeAt(0));\n  const blob = new Blob([bytes], { type: mimeType });\n  return fromBlob(api, blob, opts);\n}\n\n/** Create an image item from a Blob or File.\n * @param {Object} api - Hobson API\n * @param {Blob|File} blob - Image blob\n * @param {Object} [opts] - Options: name, alt\n * @returns {Promise<string>} The new image item's ID\n */\nexport async function fromBlob(api, blob, opts = {}) {\n  const id = crypto.randomUUID();\n  const name = opts.name || (blob.name ? blob.name.replace(/\\.[^.]+$/, '') : 'Image');\n  const item = {\n    id,\n    name,\n    type: IMAGE_TYPE,\n    created: Date.now(),\n    modified: Date.now(),\n    content: {\n      mimeType: blob.type || 'image/png',\n      alt: opts.alt || undefined\n    },\n    attachments: []\n  };\n  await api.set(item);\n  await api.setBlob(id, blob);\n  return id;\n}\n\n/** Create an image item from a file path (Tauri only).\n * @param {Object} api - Hobson API\n * @param {string} filePath - Absolute file path\n * @param {Object} [opts] - Options: name, alt\n * @returns {Promise<string>} The new image item's ID\n */\nexport async function fromFile(api, filePath, opts = {}) {\n  const tauri = window.__TAURI__;\n  if (!tauri) throw new Error('fromFile requires Tauri (filesystem access)');\n\n  const bytes = await tauri.fs.readFile(filePath);\n  const ext = filePath.split('.').pop().toLowerCase();\n  const mimeMap = {\n    png: 'image/png', jpg: 'image/jpeg', jpeg: 'image/jpeg',\n    gif: 'image/gif', webp: 'image/webp', svg: 'image/svg+xml',\n    bmp: 'image/bmp', ico: 'image/x-icon'\n  };\n  const mimeType = mimeMap[ext] || 'image/png';\n  const blob = new Blob([bytes], { type: mimeType });\n  const fileName = filePath.split('/').pop().split('\\\\').pop().replace(/\\.[^.]+$/, '');\n  const name = opts.name || fileName || 'Image';\n  return fromBlob(api, blob, { ...opts, name });\n}\n",
