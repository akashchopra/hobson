          ":strong",
          {
            "s": "Status:"
          }
        ],
        {
          "s": " Assessment (March 2026)"
        }
      ],
      [
        ":p",
        {
          "s": "An analysis of what "
        },
        [
          ":item-ref",
          {
            "s": "c0c0c0c0-0074-0000-0000-000000000000"
          },
          {
            "s": "Computed Fields"
          }
        ],
        {
          "s": " and "
        },
        [
          ":item-ref",
          {
            "s": "c0c0c0c0-0073-0000-0000-000000000000"
          },
          {
            "s": "Structured Notes"
          }
        ],
        {
          "s": " provide compared to the existing "
        },
        [
          ":item-ref",
          {
            "s": "c0c0c0c0-0035-0000-0000-000000000000"
          },
          {
            "s": "Transclusion"
          }
        ],
        {
          "s": " system, and what gaps must be closed before transclusions could be removed."
        }
      ],
      [
        ":h2",
        {
          "s": "What Transclusions Provide Today"
        }
      ],
      [
