                {
                  "s": "<details>"
                }
              ],
              {
                "s": " box with \"Transcluded from\" header and navigation link"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Editor gesture"
              }
            ],
            [
              ":td",
              {
                "s": "\"Insert Link/Transclusion\" toolbar button with item search modal"
              }
            ]
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "What Computed Fields Cover"
        }
      ],
      [
        ":p",
        {
          "s": "The computed fields system ("
        },
        [
          ":code",
          {
            "s": "content.computed"
          }
        ],
        {
          "s": " + "
        },
        [
          ":code",
          {
            "s": "{{field-name}}"
          }
        ],
        {
          "s": ") covers:"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Feature"
              }
            ],
            [
              ":th",
              {
                "s": "Equivalent"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              {
                "s": "Field transclusion"
              }
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "(get-field @other :description)"
                }
              ]
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Functional transclusion"
              }
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "(invoke (require \"module\") \"fn\" api params)"
                }
              ]
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Computed values"
              }
            ],
            [
              ":td",
              {
                "s": "Any Hob expression — arithmetic, aggregation, etc."
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Cross-item reactivity"
              }
            ],
            [
              ":td",
              {
                "s": "Automatic re-render when referenced items change"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Cycle detection"
              }
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "_computingFields"
                }
              ],
              {
                "s": " Set prevents infinite recursion"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Error sentinels"
              }
            ],
            [
              ":td",
              {
                "s": "Graceful "
              },
              [
                ":code",
                {
                  "s": "ERR"
                }
              ],
              {
                "s": " display with tooltip, error items via "
              },
              [
                ":code",
                {
                  "s": "captureError"
                }
              ]
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Provenance links"
              }
            ],
            [
              ":td",
              {
                "s": "AST walk extracts "
              },
              [
                ":code",
                {
                  "s": "@"
                }
              ],
              {
                "s": "-referenced items in field summary"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Inline rendering"
              }
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "{{field-name}}"
                }
              ],
              {
                "s": " in markdown body with dashed underline, clickable"
              }
            ]
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "Computed fields are stronger than transclusions in reactivity, error handling, and extensibility to non-transclusion use cases (spreadsheet calculations, aggregations). But they don't cover everything."
        }
      ],
      [
        ":h2",
        {
          "s": "Gaps"
        }
      ],
      [
        ":h3",
        {
          "s": "1. Full item rendering — no equivalent"
        }
      ],
      [
        ":p",
        {
          "s": "Transclusion renders an "
        },
        [
          ":em",
          {
            "s": "entire item"
          }
        ],
        {
          "s": " via "
        },
        [
          ":code",
          {
            "s": "renderItem()"
          }
        ],
        {
          "s": " inside a "
        },
        [
          ":code",
          {
            "s": "<details>"
          }
        ],
        {
          "s": " box — the full view, not just a single field. Computed fields can only return a single field value. There's no "
        },
        [
          ":code",
          {
            "s": "{{}}"
          }
        ],
        {
          "s": " equivalent for \"embed this item's complete rendered view here.\""
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Possible fix:"
          }
        ],
        {
          "s": " A Hob function like "
        },
        [
          ":code",
          {
            "s": "(render-item @other-item)"
          }
        ],
        {
          "s": " that returns a DOM element. The functional transclusion path already supports DOM returns, so this may be straightforward."
        }
      ],
      [
        ":h3",
        {
          "s": "2. Region extraction ("
        },
        [
          ":code",
          {
            "s": "?region=name"
          }
        ],
        {
          "s": ") — no equivalent"
        }
      ],
      [
        ":p",
        {
          "s": "Transclusions can pull a named "
        },
        [
          ":code",
          {
            "s": "[BEGIN:name]/[END:name]"
          }
        ],
        {
          "s": " region from a code field. "
        },
        [
          ":code",
          {
            "s": "get-field"
          }
        ],
        {
          "s": " returns the entire field value."
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Possible fix:"
          }
        ],
        {
          "s": " A stdlib function "
        },
        [
          ":code",
          {
            "s": "(extract-region (get-field @item :code) \"regionName\")"
          }
        ],
        {
          "s": "."
        }
      ],
      [
        ":h3",
        {
          "s": "3. Line range extraction ("
        },
        [
          ":code",
          {
            "s": "?lines=10-20"
          }
        ],
        {
          "s": ") — no equivalent"
        }
      ],
      [
        ":p",
        {
          "s": "Extracting a slice of a multiline string."
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Possible fix:"
          }
        ],
        {
          "s": " "
        },
        [
          ":code",
          {
            "s": "(slice-lines (get-field @item :code) 10 20)"
          }
        ],
        {
          "s": "."
        }
      ],
      [
        ":h3",
        {
          "s": "4. Symbol extraction ("
        },
        [
          ":code",
          {
            "s": "?symbol=fnName"
          }
        ],
        {
          "s": ") — no equivalent"
        }
      ],
      [
        ":p",
        {
          "s": "Transclusions resolve symbols via "
        },
        [
          ":code",
          {
            "s": "_symbols"
          }
        ],
        {
          "s": " metadata to extract function/class definitions. No Hob function exposes this."
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Possible fix:"
          }
        ],
        {
          "s": " "
        },
        [
          ":code",
          {
            "s": "(extract-symbol @item \"fnName\")"
          }
        ],
        {
          "s": " that reads "
        },
        [
          ":code",
          {
            "s": "_symbols"
          }
        ],
        {
          "s": " and applies the line range."
        }
      ],
      [
        ":h3",
        {
          "s": "5. Query blocks — no equivalent"
        }
      ],
      [
        ":p",
        [
          ":code",
          {
            "s": " "
          }
        ],
        {
          "s": "`"
        },
        [
          ":code",
          {
            "s": "query "
          }
        ],
        {
          "s": "`"
        },
        [
          ":code",
          {
            "s": " "
          }
        ],
        {
          "s": " blocks execute arbitrary JS with full "
        },
        [
          ":code",
          {
            "s": "api"
          }
        ],
        {
          "s": " access and return DOM or markdown. Computed fields use Hob and are per-field, not inline blocks. The "
        },
        [
          ":code",
          {
            "s": "transclude()"
          }
        ],
        {
          "s": " and "
        },
        [
          ":code",
          {
            "s": "transcludeEach()"
          }
        ],
        {
          "s": " helpers for attribution chrome have no Hob equivalents."
        }
      ],
      [
        ":p",
        {
          "s": "This is the biggest gap. Query blocks enable dynamic lists, filtered views, and aggregation dashboards with flexible output formatting. Computed fields can do "
        },
        [
          ":em",
          {
            "s": "some"
          }
        ],
        {
          "s": " of this via "
        },
        [
          ":code",
          {
            "s": "(reduce + 0 (map ...))"
          }
        ],
        {
          "s": ", but can't easily produce complex multi-item markdown with attribution chrome."
        }
      ],
      [
        ":p",
        {
          "s": "This may need to remain as a separate mechanism, or evolve into a Hob equivalent."
        }
      ],
      [
        ":h3",
        {
          "s": "6. Collapsible chrome with provenance — partially covered"
        }
      ],
      [
        ":p",
        {
          "s": "Transclusions render in collapsible "
        },
        [
          ":code",
          {
            "s": "<details>"
          }
        ],
        {
          "s": " boxes with \"Transcluded from: [Name] ↗\" headers. Computed field "
        },
        [
          ":code",
          {
            "s": "{{refs}}"
          }
        ],
        {
          "s": " render inline with dashed underlines and click-to-scroll — no visual boxing, no collapse, no \"from\" attribution at the reference site. Provenance is only shown in the field summary section at the bottom."
        }
      ],
      [
        ":p",
        {
          "s": "This is a deliberate design choice (inline vs. block), but for cases where the user wants to embed a paragraph from another note with visible attribution, the old chrome is more appropriate."
        }
      ],
      [
        ":h3",
        {
          "s": "7. Editor gesture for computed transclusions — not implemented"
        }
      ],
      [
        ":p",
        {
          "s": "The old editor has an \"Insert Link/Transclusion\" button that opens a search modal and inserts "
        },
        [
          ":code",
          {
            "s": "![name](item://id)"
          }
        ],
        {
          "s": " at the cursor. The "
        },
        [
          ":item-ref",
          {
            "s": "c0c0c0c0-0073-0000-0000-000000000000"
          },
          {
            "s": "Structured Notes"
          }
        ],
        {
          "s": " doc describes a gesture that creates both the "
        },
        [
          ":code",
          {
            "s": "content.computed"
          }
        ],
        {
          "s": " entry and the "
        },
        [
          ":code",
          {
            "s": "{{name}}"
          }
        ],
        {
          "s": " reference at the cursor, but this isn't built yet."
        }
      ],
      [
        ":p",
        {
          "s": "Without this, creating a computed-field transclusion requires: (1) switch to edit mode, (2) add a computed field in the computed-fields section, (3) write the formula manually, (4) go back to the body and type "
        },
        [
          ":code",
          {
            "s": "{{name}}"
          }
        ],
        {
          "s": ". Four steps vs. one click."
        }
      ],
      [
        ":h3",
        {
          "s": "8. Render mode override — no equivalent"
        }
      ],
      [
        ":p",
        [
          ":code",
          {
            "s": "?render=code"
          }
        ],
        {
          "s": " forces code-block rendering of a description field. Computed fields return raw values — the rendering is always inline text."
        }
      ],
      [
        ":h2",
        {
          "s": "Inline-Editable Field References"
        }
      ],
      [
        ":h3",
        {
          "s": "The Vision"
        }
      ],
      [
        ":p",
        {
          "s": "Today, "
        },
        [
          ":code",
          {
            "s": "{{field-name}}"
          }
        ],
        {
          "s": " references are always readonly — changing a field value requires switching to edit mode and finding the field in the static-fields or computed-fields section. If "
        },
        [
          ":code",
          {
            "s": "{{field-name}}"
          }
        ],
        {
          "s": " could render as an editable input, structured notes would feel like spreadsheets: click on a value, type a new one, and watch computed fields reactively update."
        }
      ],
      [
        ":p",
        {
          "s": "For example, a note with "
        },
        [
          ":code",
          {
            "s": "The total is **{{total}}**"
          }
        ],
        {
          "s": " where "
        },
        [
          ":code",
          {
            "s": "total"
          }
        ],
        {
          "s": " is computed from "
        },
        [
          ":code",
          {
            "s": "{{quantity!}} × {{unit-price!}}"
          }
        ],
        {
          "s": " — you'd click on \"10\", type \"12\", and see "
        },
        [
          ":code",
          {
            "s": "total"
          }
        ],
        {
          "s": " update immediately."
        }
      ],
      [
        ":p",
        {
          "s": "This also opens the door to "
        },
        [
          ":strong",
          {
            "s": "form-like notes"
          }
        ],
        {
          "s": ": "
        },
        [
          ":code",
          {
            "s": "Name: {{name!}}, Email: {{email!}}, Status: {{status!}}"
          }
        ],
        {
          "s": " where each field is directly editable inline."
        }
      ],
      [
        ":h3",
        {
          "s": "Syntax: "
        },
        [
          ":code",
          {
            "s": "{{field-name!}}"
          }
        ]
      ],
      [
        ":p",
        {
          "s": "The note author controls which references are editable via a "
        },
        [
          ":code",
          {
            "s": "!"
          }
        ],
        {
          "s": " suffix:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "{{field-name}}"
              }
            ],
            {
              "s": " — readonly (default, backwards compatible)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "{{field-name!}}"
              }
            ],
            {
              "s": " — editable inline"
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "The "
        },
        [
          ":code",
          {
            "s": "!"
          }
        ],
        {
          "s": " follows the Hob convention for mutation (like "
        },
        [
          ":code",
          {
            "s": "set!"
          }
        ],
        {
          "s": "). The author's intent is visible right where the reference appears — no need to look in a separate config map."
        }
      ],
      [
        ":p",
        {
          "s": "The parser change is minimal: "
        },
        [
          ":code",
          {
            "s": "resolveRefsMarkup"
          }
        ],
        {
          "s": " already extracts the field name from between "
        },
        [
          ":code",
          {
            "s": "{{"
          }
        ],
        {
          "s": " and "
        },
        [
          ":code",
          {
            "s": "}}"
          }
        ],
        {
          "s": "; it would trim a trailing "
        },
        [
          ":code",
          {
            "s": "!"
          }
        ],
        {
          "s": " and pass an "
        },
        [
          ":code",
          {
            "s": "editable"
          }
        ],
        {
          "s": " flag to the rendering logic."
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Future extension:"
          }
        ],
        {
          "s": " If richer per-field config is needed later (input type, placeholder, validation, choices), a "
        },
        [
          ":code",
          {
            "s": "content.fields"
          }
        ],
        {
          "s": " metadata map could provide defaults, with "
        },
        [
          ":code",
          {
            "s": "!"
          }
        ],
        {
          "s": " as sugar for "
        },
        [
          ":code",
          {
            "s": "{ \"editable\": true }"
          }
        ],
        {
          "s": ". But for the initial implementation, the syntax alone is sufficient."
        }
      ],
      [
        ":h3",
        {
          "s": "Rendering"
        }
      ],
      [
        ":p",
        [
          ":code",
          {
            "s": "resolveRefsMarkup"
          }
        ],
        {
          "s": " currently generates HTML strings injected into markdown before markdown-it processes it. For editable fields, it would use the "
        },
        [
          ":strong",
          {
            "s": "DOM mount pattern"
          }
        ],
        {
          "s": " (already used for DOM-node computed field values): insert a "
        },
        [
          ":code",
          {
            "s": "<span data-field-mount=\"...\">"
          }
        ],
        {
          "s": " placeholder in the HTML string, then mount a real interactive element after markdown rendering."
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Display mode:"
          }
        ],
        {
          "s": " The field shows as text with visual affordances distinguishing it from readonly refs — a solid underline (vs. dashed for readonly/computed), "
        },
        [
          ":code",
          {
            "s": "cursor: text"
          }
        ],
        {
          "s": ", and a subtle background tint on hover."
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Click:"
          }
        ],
        {
          "s": " Text becomes an "
        },
        [
          ":code",
          {
            "s": "<input>"
          }
        ],
        {
          "s": " (or "
        },
        [
          ":code",
          {
            "s": "<textarea>"
          }
        ],
        {
          "s": " for multiline values), focused, content selected."
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Blur or Enter:"
          }
        ],
        {
          "s": " Auto-save via "
        },
        [
          ":code",
          {
            "s": "api.set()"
          }
        ],
        {
          "s": " with the new value. Type coercion reuses the logic from "
        },
        [
          ":code",
          {
            "s": "field-view-static-fields"
          }
        ],
        {
          "s": " — detect numbers, booleans ("
        },
        [
          ":code",
          {
            "s": "true"
          }
        ],
        {
          "s": "/"
        },
        [
          ":code",
          {
            "s": "false"
          }
        ],
        {
          "s": "), null ("
        },
        [
          ":code",
          {
            "s": "null"
          }
        ],
        {
          "s": "/"
        },
        [
          ":code",
          {
            "s": "nil"
          }
        ],
        {
          "s": "), otherwise string."
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Escape:"
          }
        ],
        {
          "s": " Cancel, revert to original value."
        }
      ],
      [
        ":h3",
        {
          "s": "What Is Editable"
        }
      ],
      [
        ":p",
        {
          "s": "Even with the "
        },
        [
          ":code",
          {
            "s": "!"
          }
        ],
        {
          "s": " modifier, not every field reference can sensibly be edited inline:"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Situation"
              }
            ],
            [
              ":th",
              {
                "s": "Editable?"
              }
            ],
            [
              ":th",
              {
                "s": "Why"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              {
                "s": "Static field on same item + "
              },
              [
                ":code",
                {
                  "s": "!"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Yes"
              }
            ],
            [
              ":td",
              {
                "s": "The simple, safe case"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Computed field + "
              },
              [
                ":code",
                {
                  "s": "!"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "No — ignore the "
              },
              [
                ":code",
                {
                  "s": "!"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Derived values can't be edited directly"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Error sentinel"
              }
            ],
            [
              ":td",
              {
                "s": "No"
              }
            ],
            [
              ":td",
              {
                "s": "Nothing to edit"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "DOM node value"
              }
            ],
            [
              ":td",
              {
                "s": "No"
              }
            ],
            [
              ":td",
              {
                "s": "Not a scalar"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Static field without "
              },
              [
                ":code",
                {
                  "s": "!"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "No"
              }
            ],
            [
              ":td",
              {
                "s": "Author chose readonly"
              }
            ]
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "Cross-item editing (a computed formula that dereferences to a static field on another item) is deferred. It's conceptually interesting — editing through a transclusion — but raises questions about intent, permissions, and which item the save targets. Start with same-item static fields only."
        }
      ],
      [
        ":h3",
        {
          "s": "Difficulties"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Re-render loops."
          }
        ],
        {
          "s": " Saving via "
        },
        [
          ":code",
          {
            "s": "api.set()"
          }
        ],
        {
          "s": " emits "
        },
        [
          ":code",
          {
            "s": "item:updated"
          }
        ],
        {
          "s": ", which triggers a re-render that replaces the entire DOM — including the input the user just edited. This causes focus loss, cursor reset, and flicker. The best mitigation is to "
        },
        [
          ":strong",
          {
            "s": "suppress re-render while editing"
          }
        ],
        {
          "s": ": set a flag on the render instance that prevents "
        },
        [
          ":code",
          {
            "s": "item:updated"
          }
        ],
        {
          "s": " from scheduling a re-render while an inline input is focused. Apply the pending update after blur. The reactive system already has per-instance control via "
        },
        [
          ":code",
          {
            "s": "RenderInstanceRegistry"
          }
        ],
        {
          "s": ", so this is architecturally feasible."
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "HTML injection into markdown."
          }
        ],
        {
          "s": " Raw "
        },
        [
          ":code",
          {
            "s": "<input>"
          }
        ],
        {
          "s": " elements in the HTML string could be mangled by markdown-it (escaped, wrapped in "
        },
        [
          ":code",
          {
            "s": "<p>"
          }
        ],
        {
          "s": "). The DOM mount pattern avoids this — insert a placeholder span in the HTML, mount the real input after markdown rendering. This already works for DOM-node computed fields."
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Long values."
          }
        ],
        {
          "s": " A field containing a paragraph doesn't fit in an inline "
        },
        [
          ":code",
          {
            "s": "<input>"
          }
        ],
        {
          "s": ". Options: auto-expand to "
        },
        [
          ":code",
          {
            "s": "<textarea>"
          }
        ],
        {
          "s": " for multiline values, or limit inline editing to short/scalar values and require edit mode for long text. Detecting multiline ("
        },
        [
          ":code",
          {
            "s": "value.includes(' ')"
          }
        ],
        {
          "s": ") is simple."
        }
      ],
      [
        ":h3",
        {
          "s": "Implementation Sketch"
        }
      ],
      [
        ":p",
        {
          "s": "Changes are localized to "
        },
        [
          ":code",
          {
            "s": "field-view-markdown-readonly"
          }
        ],
        {
          "s": ":"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Parser"
              }
            ],
            {
              "s": ": In "
            },
            [
              ":code",
              {
                "s": "resolveRefsMarkup"
              }
            ],
            {
              "s": ", detect trailing "
            },
            [
              ":code",
              {
                "s": "!"
              }
            ],
            {
              "s": " in "
            },
            [
              ":code",
              {
                "s": "{{field-name!}}"
              }
            ],
            {
              "s": ". Check if the field is static (not in "
            },
            [
              ":code",
              {
                "s": "content.computed"
              }
            ],
            {
              "s": "). If both: emit a DOM mount placeholder with "
            },
            [
              ":code",
              {
                "s": "data-field-editable"
              }
            ],
            {
              "s": " attribute."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Mount"
              }
            ],
            {
              "s": ": After markdown rendering, mount interactive elements into placeholders. Each editable mount renders the value as text with solid underline styling and a click handler."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Click handler"
              }
            ],
            {
              "s": ": Swap text for an "
            },
            [
              ":code",
              {
                "s": "<input>"
              }
            ],
            {
              "s": ", focus, select all. Store original value for cancel."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Blur/Enter handler"
              }
            ],
            {
              "s": ": Type-coerce the value, update "
            },
            [
              ":code",
              {
                "s": "item.content[fieldName]"
              }
            ],
            {
              "s": ", call "
            },
            [
              ":code",
              {
                "s": "api.set(item)"
              }
            ],
            {
              "s": ". Set a suppress-re-render flag before saving, clear after the DOM update settles."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Escape handler"
              }
            ],
            {
              "s": ": Revert to original value, exit edit mode."
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "UX Observations"
        }
      ],
      [
        ":h3",
        {
          "s": "Formula authoring is too raw"
        }
      ],
      [
        ":p",
        {
          "s": "Creating a computed field requires writing Hob AST in the structural editor. For the common case of \"pull field X from item Y\", this is "
        },
        [
          ":code",
          {
            "s": "(get-field @item-id :field-name)"
          }
        ],
        {
          "s": " — reasonable for developers, but intimidating for note-taking. Consider:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "A \"quick transclusion\" builder: pick item, pick field, auto-generate the formula"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Template formulas for common patterns (transclusion, sum, count)"
            }
          ]
        ]
      ],
      [
        ":h3",
        [
          ":code",
          {
            "s": "{{field-name}}"
          }
        ],
        {
          "s": " conflates identity with display"
        }
      ],
      [
        ":p",
        {
          "s": "The field name is both the programmatic key in "
        },
        [
          ":code",
          {
            "s": "content.computed"
          }
        ],
        {
          "s": " and the human-visible reference in the body. Renaming a computed field breaks every "
        },
        [
          ":code",
          {
            "s": "{{old-name}}"
          }
        ],
        {
          "s": " in the body."
        }
      ],
      [
        ":p",
        {
          "s": "Consider auto-renaming "
        },
        [
          ":code",
          {
            "s": "{{refs}}"
          }
        ],
        {
          "s": " in the body when a computed field is renamed in the editor."
        }
      ],
      [
        ":h3",
        {
          "s": "No preview of computed values in the editor"
        }
      ],
      [
        ":p",
        {
          "s": "When editing, you see raw "
        },
        [
          ":code",
          {
            "s": "{{tokens}}"
          }
        ],
        {
          "s": ", not resolved values. A live preview pane or inline resolution would help."
        }
      ],
      [
        ":h3",
        {
          "s": "Field summary feels like a debugging tool"
        }
      ],
      [
        ":p",
        {
          "s": "The field summary at the bottom showing formulas + resolved values + provenance is powerful but feels more like a developer inspector. Consider:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Collapsed by default for notes with few fields"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "A \"compact\" mode showing only values, not formulas"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Provenance links inline near the "
            },
            [
              ":code",
              {
                "s": "{{ref}}"
              }
            ],
            {
              "s": " rather than only at the bottom"
            }
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "Error UX is minimal"
        }
      ],
      [
        ":p",
        {
          "s": "A red \"ERR\" span with a tooltip is functional but not discoverable — users won't always hover. Consider:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "An error count badge in the field summary header"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Clicking ERR navigates to the error item or opens the formula editor"
            }
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "No reverse dependency lookup"
        }
      ],
      [
        ":p",
        {
          "s": "Provenance shows \"this formula references items A, B, C\" (forward refs), but there's no reverse lookup — \"what items have formulas that reference "
        },
        [
          ":em",
          {
            "s": "this"
          }
        ],
        {
          "s": " item?\" The \"used by\" direction would be valuable for understanding impact before editing."
        }
      ],
      [
        ":h2",
        {
          "s": "Verdict: Can Transclusions Be Removed?"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Not yet."
          }
        ],
        {
          "s": " Five functional gaps (full item rendering, region/line/symbol extraction, query blocks), one critical UX gap (editor gesture), and one missing capability (inline-editable field references) remain."
        }
      ],
      [
        ":p",
        {
          "s": "Computed fields handle the common case of \"pull a field value from another item\" well, with better reactivity and error handling. But transclusions serve broader use cases — especially code documentation with region/symbol extraction and query-driven dynamic content."
        }
      ],
      [
        ":h2",
        {
          "s": "Recommended Path"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Keep both systems"
              }
            ],
            {
              "s": " — they're orthogonal and don't conflict"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Implement `{{field!}}` inline editing"
              }
            ],
            {
              "s": " — the feature that makes structured notes feel like spreadsheets"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Build the editor gesture"
              }
            ],
            {
              "s": " for creating computed transclusions (highest UX impact for authoring)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Add stdlib functions"
              }
            ],
            {
              "s": " for region/line/symbol extraction (closes the code-doc gap)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Evaluate query blocks separately"
              }
            ],
            {
              "s": " — these may evolve into a Hob equivalent or remain as JS escape hatches"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Author real notes"
              }
            ],
            {
              "s": " using computed fields to discover which gaps matter in practice"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "References"
        }
