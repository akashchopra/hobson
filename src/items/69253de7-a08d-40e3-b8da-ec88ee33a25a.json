{"id": "69253de7-a08d-40e3-b8da-ec88ee33a25a", "type": "aaaaaaaa-0000-0000-0000-000000000000", "name": "sortable-list-view", "created": 1737849600000, "modified": 1774532370047, "content": {"for_type": "00000000-0000-0000-0000-000000000000", "displayName": "Sortable List", "capabilities": ["read", "write"], "description": [":doc", [":p", {"s": "Sortable lists provide drag-to-reorder functionality for item attachments displayed in a linear list (as opposed to the spatial canvas layout)."}], [":h2", {"s": "Concept"}], [":p", {"s": "While the "}, [":item-ref", {"s": "ef793c27-2d4b-4c99-b05a-2769db5bc5a9"}, {"s": "spatial windowing system"}], {"s": " arranges children on a 2D canvas, some contexts benefit from an ordered list:"}], [":ul", [":li", [":p", {"s": "Todo lists where order represents priority"}]], [":li", [":p", {"s": "Document outlines where order represents sequence"}]], [":li", [":p", {"s": "Playlists, reading lists, step-by-step instructions"}]]], [":p", {"s": "Sortable lists render attachments in array order with drag handles for reordering."}], [":h2", {"s": "Implementation"}], [":p", {"s": "The reorder operation modifies the parent item's "}, [":code", {"s": "attachments"}], {"s": " array:"}], [":ol", [":li", [":p", {"s": "User drags an item to a new position"}]], [":li", [":p", {"s": "The attachment is removed from its current index"}]], [":li", [":p", {"s": "Inserted at the target index"}]], [":li", [":p", {"s": "Parent item saved with "}, [":code", {"s": "api.update()"}], {"s": " to reflect new order"}]]], [":p", {"s": "The "}, [":code", {"s": "attachments"}], {"s": " array is ordered — array position determines display order."}], [":h2", {"s": "Drag Interaction"}], [":ul", [":li", [":p", {"s": "Drag handle (grip icon) on each list item"}]], [":li", [":p", {"s": "Visual feedback: dragged item lifts, gap appears at drop target"}]], [":li", [":p", {"s": "Drop saves the new order immediately"}]], [":li", [":p", {"s": "Uses "}, [":item-ref", {"s": "c0c0c0c0-0010-0000-0000-000000000000"}, {"s": "silent updates"}], {"s": " during drag for smooth interaction"}]]], [":h2", {"s": "See Also"}], [":ul", [":li", [":p", [":item-ref", {"s": "ef793c27-2d4b-4c99-b05a-2769db5bc5a9"}, {"s": "Spatial Windowing"}], {"s": " — The 2D alternative to linear lists"}]], [":li", [":p", [":item-ref", {"s": "c0c0c0c0-0005-0000-0000-000000000000"}, {"s": "Attachments"}], {"s": " — Ordered attachment arrays"}]]]], "tags": ["a63eadd8-ec56-4163-acf2-207aa392069b"], "hob": [["defn", "render", {"v": ["item", "api"]}, ["def", "attachments", ["or", [":attachments", "item"], {"v": []}]], ["def", "default-view-id", {"s": "a1b2c3d4-e5f6-4a7b-8c9d-0e1f2a3b4c5d"}], {"v": [":div.sortable-list-view", {"m": [[":style", {"s": "display: flex; flex-direction: column; height: 100%; background: var(--color-bg-surface-alt);"}]]}, {"v": [":div.sortable-list-items", {"m": [[":style", {"s": "flex: 1; overflow-y: auto; padding-left: 2px; padding-top: 4px; padding-bottom: 10px; padding-right: 2px;"}], [":sortable", {"m": [[":handle", {"s": ".drag-handle"}], [":on-reorder", ["fn", {"v": ["from", "to"]}, ["reorder-attachments!", "from", "to"]]]]}]]}, ["if", ["seq", "attachments"], ["for", {"v": ["child", ["seq", "attachments"]]}, ["let", {"v": ["child-id", ["if", ["string?", "child"], "child", [":id", "child"]], "view-id", ["or", ["get-in", "child", {"v": [":view", ":type"]}], "default-view-id"]]}, {"v": [":div.sortable-list-item", {"m": [[":data-item-id", "child-id"], [":data-parent-id", [":id", "item"]], [":data-sort-key", "child-id"], [":style", {"s": "display: flex; align-items: center; margin-bottom: 4px;"}]]}, {"v": [":div.drag-handle", {"m": [[":style", {"s": "width: 24px; display: flex; align-items: center; justify-content: center; cursor: grab; user-select: none; flex-shrink: 0; color: var(--color-border-dark);"}], [":title", {"s": "Drag to reorder"}]]}, {"s": "≡"}]}, {"v": [":div", {"m": [[":style", {"s": "flex: 1; padding: 2px 4px; min-width: 0;"}]]}, {"v": [":render-child", {"m": [[":item", "child-id"], [":view", "view-id"], [":open-in", ["get-parent-id"]]]}]}]}, {"v": [":div", {"m": [[":style", {"s": "width: 24px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;"}]]}, {"v": [":button", {"m": [[":style", {"s": "background: none; border: none; color: var(--color-border-dark); cursor: pointer; font-size: 1.125rem; padding: 4px;"}], [":title", {"s": "Remove from list"}], [":on-click", ["fn", {"v": ["e"]}, ["detach!", "child-id"], ["rerender!"]]]]}, {"s": "×"}]}]}]}]], {"v": [":div", {"m": [[":style", {"s": "text-align: center; color: var(--color-border-dark); padding: 60px 20px; font-style: italic;"}]]}, {"s": "This list is empty."}]}]]}]}]], "_symbols": {"render": {"name": "render", "kind": "function", "scope": null, "signature": "(item api)"}}}, "attachments": [{"id": "ad3bddac-95ce-41ae-aa11-6f6e6f537bc6"}]}