    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Track changes to items over time with diff, revert, and history browsing."
        }
      ],
      [
        ":h2",
        {
          "s": "Concept"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Every edit creates a version snapshot"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "View history timeline for any item"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Diff changes between versions"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Revert to previous versions"
            }
          ]
        ]
      ],
