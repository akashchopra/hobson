        ":h2",
        {
          "s": "UI Considerations"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Timeline view showing version history"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Diff visualization (inline or side-by-side)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Could be implemented as a view for any item type"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Implementation Notes"
        }
      ],
      [
        ":p",
        {
          "s": "Version items could be regular items with a "
        },
        [
          ":code",
          {
            "s": "version_of"
          }
        ],
        {
          "s": " field pointing to the original, plus a timestamp. A declarative watch on "
        },
        [
          ":code",
          {
            "s": "item:updated"
          }
        ],
        {
          "s": " could automatically create version snapshots."
        }
      ],
      [
        ":h2",
        {
          "s": "Design Questions"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "What's the retention policy? Keep forever? Auto-prune old versions?"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Is this worth the complexity for personal use, or only for collaboration?"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Should code items have more granular versioning than data items?"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Priority"
        }
      ],
      [
        ":p",
        {
          "s": "Low — useful but significant complexity. Manual export provides basic backup capability today."
        }
