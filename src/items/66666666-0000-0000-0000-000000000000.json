  "extends": "22222222-0000-0000-0000-000000000000",
  "created": 1768505848878,
  "modified": 1774988048499,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "A reusable code module that exports functions, classes, or values for other code items to use."
        }
      ],
      [
        ":h2",
        {
          "s": "Purpose"
        }
      ],
      [
        ":p",
        {
          "s": "Libraries provide shared functionality:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Utility functions"
              }
            ],
            {
              "s": " (string manipulation, data transformation)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Third-party code"
              }
            ],
            {
              "s": " (markdown-it, CodeMirror)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Domain logic"
              }
            ],
            {
              "s": " (tag tree building, search indexing)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "UI components"
              }
            ],
            {
              "s": " (modal dialogs, form elements)"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Loading Libraries"
        }
      ],
      [
        ":p",
        {
          "s": "Use "
        },
        [
          ":code",
          {
            "s": "api.require()"
          }
        ],
        {
          "s": " with the library's name:"
        }
      ],
      [
        ":code-block",
        {
          "s": "// In a view or other code item\nconst modal = await api.require('modal-lib');\nawait modal.confirm('Delete this item?');\n\nconst md = await api.require('hobson-markdown');\nconst html = await md.render(markdownText, api);"
        }
      ],
      [
        ":h2",
        {
          "s": "Creating a Library"
        }
      ],
      [
        ":code-block",
        {
          "s": "{\n  id: crypto.randomUUID(),\n  name: \"my-utils\",  // Name used with api.require()\n  type: \"66666666-0000-0000-0000-000000000000\",  // kernel:library\n  content: {\n    description: \"Utility functions for string manipulation\",\n    code: `\n      export function capitalize(str) {\n        return str.charAt(0).toUpperCase() + str.slice(1);\n      }\n\n      export function slugify(str) {\n        return str.toLowerCase().replace(/\\\\s+/g, '-');\n      }\n\n      // Default export also works\n      export default { capitalize, slugify };\n    `\n  }\n}"
        }
      ],
      [
        ":h2",
        {
          "s": "Third-Party Libraries"
        }
      ],
      [
        ":p",
        {
          "s": "External JavaScript libraries can be stored as library items:"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "UMD/Global libraries"
              }
            ],
            {
              "s": ": Store the minified source, library attaches to "
            },
            [
              ":code",
              {
                "s": "window"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "ES modules"
              }
            ],
            {
              "s": ": Store the source directly, exports work naturally"
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "Example: "
        },
        [
          ":item-ref",
          {
            "s": "08d5ecd2-01a1-43f1-ad50-314027db231a"
          },
          {
            "s": "markdown-it"
          }
        ],
        {
          "s": " stores the library source, then "
        },
        [
          ":item-ref",
          {
            "s": "3a206d5a-54bb-4045-827e-20bf1a09f3de"
          },
          {
            "s": "markdown-it-wrapper"
          }
        ],
        {
          "s": " wraps it with ES module exports."
        }
      ],
