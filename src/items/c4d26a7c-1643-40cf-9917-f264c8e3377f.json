  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Boot-time scheduler for reminder items. JS shim handles the kernel:boot-complete watch; all scheduling logic is in Hob (content.hob)."
        }
      ],
      [
        ":p",
        {
          "s": "On boot: scans all reminder items, evaluates each scheduling expression, and sets timers. When a timer fires: shows a Tauri notification and re-evaluates for recurring reminders."
        }
      ]
    ],
    "code": "// reminder-scheduler — JS boot shim\n// Loads and evaluates this item's Hob scheduling logic at boot time.\n// Also watches item:updated to reactively re-schedule edited reminders.\n//\n// evalSchedule is the single source of truth for \"what time does this\n// reminder fire next?\" — used by schedule-one! (in Hob) and the reminder\n// view. It reuses the scheduler's own interpreter, so scheduling helpers\n// like (every :day 21 30) defined in our .hob are in scope.\n//\n// scheduleOneFrom(item, baseTime) is used by the \"Done\" button to schedule\n// the next occurrence after a reminder's most recently scheduled time,\n// even when that time is now in the past.\n\nconst SELF_ID = 'c4d26a7c-1643-40cf-9917-f264c8e3377f';\nconst REMINDER_TYPE = '521cb06c-2146-47f1-9375-1207bb6b5b27';\nlet _hob = null;\nlet _interp = null;\nlet _scheduleOne = null;\n\nexport async function onKernelBootComplete({ safeMode }, api) {\n  if (safeMode) return;\n  _hob = await api.require('hob-interpreter');\n  _interp = _hob.createInterpreter(api);\n  await _interp.macrosReady;\n  const self = await api.get(SELF_ID);\n  if (!self?.content?.hob) return;\n  for (const ast of self.content.hob) {\n    await _interp.evaluate(ast);\n  }\n  _scheduleOne = await _interp.eval('schedule-one!');\n  await checkExactAlarmPermission(api);\n  await _interp.eval('(boot-scan!)');\n}\n\nexport async function onItemUpdated({ item }, api) {\n  if (!_scheduleOne || !item || item.type !== REMINDER_TYPE) return;\n  await _scheduleOne(item);\n}\n\n// Evaluate a reminder's schedule expression, returning the next-fire\n// timestamp (ms since epoch) or null. If baseTime is provided, sets\n// eval-base-time before evaluation so (every ...) uses it as the\n// reference point instead of (now). Reentrant-safe: may be called\n// from within Hob code running in _interp.\nexport async function evalSchedule(item, baseTime) {\n  if (!_interp || !_hob) return null;\n  const ast = item?.content?.hob;\n  if (!ast || ast.length === 0) return null;\n  try {\n    if (baseTime != null) {\n      await _interp.eval(`(reset! eval-base-time ${baseTime})`);\n    }\n    const source = _hob.prettyPrintAll(ast);\n    const result = await _interp.eval(source);\n    return typeof result === 'number' ? result : null;\n  } catch (e) {\n    return null;\n  } finally {\n    if (baseTime != null) {\n      await _interp.eval('(reset! eval-base-time nil)');\n    }\n  }\n}\n\n// Returns the currently scheduled OS alarm timestamp for a reminder, or null.\nexport async function getScheduledAt(itemId) {\n  if (!_interp) return null;\n  try {\n    const result = await _interp.eval(`(get (deref scheduled-at-map) \"${itemId}\")`);\n    return typeof result === 'number' ? result : null;\n  } catch (e) {\n    return null;\n  }\n}\n\n// Schedules the next occurrence of a recurring reminder, using baseTime\n// as the reference for the schedule expression. If baseTime is in the\n// past, advances forward until a future slot is found — handles \"Done\"\n// tapped after the alarm already fired. Used by the \"Done\" button.\nexport async function scheduleOneFrom(item, baseTime) {\n  if (!_interp || !_scheduleOne) return;\n  let base = baseTime;\n  const now = Date.now();\n  // Advance base until evalSchedule returns a future time.\n  // Bounded to 10 iterations (enough for any weekly recurrence pattern).\n  let iter = 0;\n  while (base != null && base <= now && iter++ < 10) {\n    const next = await evalSchedule(item, base);\n    if (next == null || next > now) break;\n    base = next;\n  }\n  try {\n    if (base != null) {\n      await _interp.eval(`(reset! eval-base-time ${base})`);\n    }\n    await _scheduleOne(item);\n  } finally {\n    await _interp.eval('(reset! eval-base-time nil)');\n  }\n}\n\n// Checks whether exact alarms are available on Android 12+.\n// If not, opens the system settings screen so the user can grant\n// SCHEDULE_EXACT_ALARM — needed for reminders to fire on time.\n// Only prompts if at least one reminder with an active schedule exists.\nasync function checkExactAlarmPermission(api) {\n  try {\n    const notif = window.__TAURI__?.notification;\n    if (!notif?.canScheduleExactAlarms) return;\n    const { value } = await notif.canScheduleExactAlarms();\n    if (value) return;\n    const items = await api.getAll();\n    const hasScheduled = items.some(\n      it => it.type === REMINDER_TYPE && it.content?.hob?.length > 0\n    );\n    if (!hasScheduled) return;\n    await notif.requestScheduleExactAlarm();\n  } catch (_) {}\n}\n",
