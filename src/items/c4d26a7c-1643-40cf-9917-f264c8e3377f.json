  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Boot-time scheduler for reminder items. JS shim handles the kernel:boot-complete watch; all scheduling logic is in Hob (content.hob)."
        }
      ],
      [
        ":p",
        {
          "s": "On boot: scans all reminder items, evaluates each scheduling expression, and sets timers. When a timer fires: shows a Tauri notification and re-evaluates for recurring reminders."
        }
      ]
    ],
    "code": "// reminder-scheduler — JS boot shim\n// Loads and evaluates this item's Hob scheduling logic at boot time.\n// Also watches item:updated to reactively re-schedule edited reminders.\n\nconst SELF_ID = 'c4d26a7c-1643-40cf-9917-f264c8e3377f';\nconst REMINDER_TYPE = '521cb06c-2146-47f1-9375-1207bb6b5b27';\nlet _scheduleOne = null;\n\nexport async function onKernelBootComplete({ safeMode }, api) {\n  if (safeMode) return;\n  const hob = await api.require('hob-interpreter');\n  const interp = hob.createInterpreter(api);\n  await interp.macrosReady;\n  const self = await api.get(SELF_ID);\n  if (!self?.content?.hob) return;\n  for (const ast of self.content.hob) {\n    await interp.evaluate(ast);\n  }\n  _scheduleOne = await interp.eval('schedule-one!');\n}\n\nexport async function onItemUpdated({ item }, api) {\n  if (!_scheduleOne || !item || item.type !== REMINDER_TYPE) return;\n  await _scheduleOne(item);\n}\n",
