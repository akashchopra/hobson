  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Boot-time scheduler for reminder items. JS shim handles the kernel:boot-complete watch; all scheduling logic is in Hob (content.hob)."
        }
      ],
      [
        ":p",
        {
          "s": "On boot: scans all reminder items, evaluates each scheduling expression, and sets timers. When a timer fires: shows a Tauri notification and re-evaluates for recurring reminders."
        }
      ]
    ],
    "code": "// reminder-scheduler — JS boot shim\n// Loads and evaluates this item's Hob scheduling logic at boot time.\n// Also watches item:updated to reactively re-schedule edited reminders.\n//\n// evalSchedule is the single source of truth for \"what time does this\n// reminder fire next?\" — used by schedule-one! (in Hob) and the reminder\n// view. It reuses the scheduler's own interpreter, so scheduling helpers\n// like (every :day 21 30) defined in our .hob are in scope.\n\nconst SELF_ID = 'c4d26a7c-1643-40cf-9917-f264c8e3377f';\nconst REMINDER_TYPE = '521cb06c-2146-47f1-9375-1207bb6b5b27';\nlet _hob = null;\nlet _interp = null;\nlet _scheduleOne = null;\n\nexport async function onKernelBootComplete({ safeMode }, api) {\n  if (safeMode) return;\n  _hob = await api.require('hob-interpreter');\n  _interp = _hob.createInterpreter(api);\n  await _interp.macrosReady;\n  const self = await api.get(SELF_ID);\n  if (!self?.content?.hob) return;\n  for (const ast of self.content.hob) {\n    await _interp.evaluate(ast);\n  }\n  _scheduleOne = await _interp.eval('schedule-one!');\n  // boot-scan! was moved out of scheduler.hob top-level so the module is\n  // safe to require as a library (no side effects on cold require). Run it\n  // explicitly here, where boot timing is owned.\n  await _interp.eval('(boot-scan!)');\n}\n\nexport async function onItemUpdated({ item }, api) {\n  if (!_scheduleOne || !item || item.type !== REMINDER_TYPE) return;\n  await _scheduleOne(item);\n}\n\n// Evaluate a reminder's schedule expression, returning the next-fire\n// timestamp (ms since epoch) or null. Reentrant-safe: may be called\n// from within Hob code running in _interp.\nexport async function evalSchedule(item) {\n  if (!_interp || !_hob) return null;\n  const ast = item?.content?.hob;\n  if (!ast || ast.length === 0) return null;\n  try {\n    const source = _hob.prettyPrintAll(ast);\n    const result = await _interp.eval(source);\n    return typeof result === 'number' ? result : null;\n  } catch (e) {\n    return null;\n  }\n}\n",
