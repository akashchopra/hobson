  "id": "f761e023-da8d-492d-9933-a75adcc8d316",
  "name": "Bootloader Source",
  "type": "ca6403d2-2c51-48b7-95a5-576bd0d711fb",
  "created": 1738540800000,
  "modified": 1773243818082,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "The bootloader ("
        },
        [
          ":code",
          {
            "s": "bootloader.html"
          }
        ],
        {
          "s": ") is the entry point for Hobson. It's a single HTML file that:"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            {
              "s": "Opens IndexedDB and looks for "
            },
            [
              ":item-ref",
              {
                "s": "33333333-1111-0000-0000-000000000000"
              },
              {
                "s": "kernel:core"
              }
            ],
            {
              "s": "."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "If found, loads and executes the kernel."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "If not found, shows an import UI to load the kernel from a JSON file."
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "The source shown below is captured at boot time from "
        },
        [
          ":code",
          {
            "s": "window.BOOTLOADER_SOURCE"
          }
        ],
        {
          "s": ", so it always reflects the exact HTML that Hobson is running from."
        }
      ]
    ],
    "source": "(populated from window.BOOTLOADER_SOURCE)"
  },
  "attachments": []
}