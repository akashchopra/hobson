              }
            ],
            {
              "s": " — Existing Acorn-based code analysis"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "ac0ac0ac-0004-0000-0000-000000000000"
              },
              {
                "s": "symbol-indexer-watch"
              }
            ],
            {
              "s": " — Auto-indexing on code item changes"
            }
          ]
        ],
        [
