              "s": " — Functional transclusion for rendering diagrams"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "c0c0c0c0-0058-0000-0000-000000000000"
              },
              {
                "s": "Hob Design Direction"
              }
            ],
            {
              "s": " — Related: Hob as the language for user-facing tools"
            }
          ]
        ]
      ]
    ],
    "tags": [
      "c0c0c0c0-0040-0000-0000-000000000000",
