{
  "id": "c0c0c0c0-0052-0000-0000-000000000000",
  "name": "Symbol Browser & API Help",
  "type": "871ae771-b9b1-4f40-8c7f-d9038bfb69c3",
  "created": 1738540800000,
  "modified": 1773243817597,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Hobson's symbol introspection system — REPL functions, cross-item search, and a visual browser for discovering and navigating code symbols across the system."
        }
      ],
      [
        ":h2",
        {
          "s": "REPL Introspection Functions"
        }
      ],
      [
        ":p",
        [
          ":item-ref",
          {
            "s": "ac0ac0ac-0005-0000-0000-000000000000"
          },
          {
            "s": "introspect-lib"
          }
        ],
        {
          "s": " provides four global functions registered at boot:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "`dir(obj)`"
              }
            ],
            {
              "s": " — Enumerate an object's properties grouped by kind (functions, sub-namespaces, values). E.g. "
            },
            [
              ":code",
              {
                "s": "dir(api)"
              }
            ],
            {
              "s": " lists all methods; "
            },
            [
              ":code",
              {
                "s": "dir(api.viewport)"
              }
            ],
            {
              "s": " lists viewport methods. Pure runtime reflection."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "`await help(obj, 'methodName')`"
              }
            ],
            {
              "s": " — Show JSDoc description, signature, params, return type, and source navigation command. Resolves source items via module provenance WeakMap (for libraries) or kernel API special-casing (for "
            },
            [
              ":code",
              {
                "s": "api"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "api.events"
              }
            ],
            {
              "s": ", etc.)."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "`await symbols(nameOrId)`"
              }
            ],
            {
              "s": " — Dump the "
            },
            [
              ":code",
              {
                "s": "_symbols"
              }
            ],
            {
              "s": " map for a code item. E.g. "
            },
            [
              ":code",
              {
                "s": "await symbols('generic-view')"
              }
            ],
            {
              "s": " shows all its functions/classes with signatures."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "`await symbolSearch(pattern, options?)`"
              }
            ],
            {
              "s": " — Cross-item symbol search. Pattern can be a string (case-insensitive substring) or RegExp. Options: "
            },
            [
              ":code",
              {
                "s": "{ kind?, scope?, limit = 50 }"
              }
            ],
            {
              "s": ". Returns results grouped by item."
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Symbol Extraction & Indexing"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "ac0ac0ac-0003-0000-0000-000000000000"
              },
              {
                "s": "symbol-extractor-lib"
              }
            ],
            {
              "s": " parses code items with Acorn and extracts functions, classes, methods, variables, and object literal properties with name, kind, signature, line/column, and JSDoc (description, "
            },
            [
              ":code",
              {
                "s": "@param"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "@returns"
              }
            ],
            {
              "s": ")."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "ac0ac0ac-0004-0000-0000-000000000000"
              },
              {
                "s": "symbol-indexer-watch"
              }
            ],
            {
              "s": " auto-indexes on "
            },
            [
              ":code",
              {
                "s": "item:created"
              }
            ],
            {
              "s": " and "
            },
            [
              ":code",
              {
                "s": "item:updated"
              }
            ],
            {
              "s": ", storing results in "
            },
            [
              ":code",
              {
                "s": "item.content._symbols"
              }
            ],
            {
              "s": ". Only re-saves when symbols actually changed."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Symbol navigation via "
            },
            [
              ":code",
              {
                "s": "api.navigate(id, { symbol: 'name' })"
              }
            ],
            {
              "s": " scrolls to a symbol in code views."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Symbol transclusion via "
            },
            [
              ":code",
              {
                "s": "![](item://id?symbol=fn)"
              }
            ],
            {
              "s": " embeds specific symbols in markdown."
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Symbol Browser View"
        }
      ],
      [
        ":p",
        {
          "s": "The "
        },
        [
          ":item-ref",
          {
            "s": "ac0ac0ac-0008-0000-0000-000000000000"
          },
          {
            "s": "Symbol Browser"
          }
        ],
        {
          "s": " provides a visual UI (rendered by the "
        },
        [
          ":item-ref",
          {
            "s": "ac0ac0ac-0007-0000-0000-000000000000"
          },
          {
            "s": "symbol-browser-view"
          }
        ],
        {
          "s": "):"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Searchable text input (debounced) across all code items"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Quick filter chips by kind: All, Functions, Classes, Methods, Properties"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Results grouped by item, showing symbol name, signature, kind badge, line number, and JSDoc details"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Click a symbol to navigate to its source via "
            },
            [
              ":code",
              {
                "s": "api.navigate(itemId, { symbol })"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Persists query and filter state in the browser item"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Kernel API Documentation"
        }
      ],
      [
        ":p",
        {
          "s": "The kernel API ("
        },
        [
          ":code",
          {
            "s": "api.*"
          }
        ],
        {
          "s": ") is discoverable through the same mechanisms as userland code:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "JSDoc comments"
              }
            ],
            {
              "s": " on all "
            },
            [
              ":code",
              {
                "s": "createAPI()"
              }
            ],
            {
              "s": " methods in "
            },
            [
              ":item-ref",
              {
                "s": "33333333-1111-0000-0000-000000000000"
              },
              {
                "s": "kernel:core"
              }
            ],
            {
              "s": " provide descriptions, "
            },
            [
              ":code",
              {
                "s": "@param"
              }
            ],
            {
              "s": " types, and "
            },
            [
              ":code",
              {
                "s": "@returns"
              }
            ],
            {
              "s": " — 168 JSDoc comments across the four kernel modules."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Symbol extraction"
              }
            ],
            {
              "s": " walks object literal properties inside "
            },
            [
              ":code",
              {
                "s": "createAPI()"
              }
            ],
            {
              "s": ", so all "
            },
            [
              ":code",
              {
                "s": "api.*"
              }
            ],
            {
              "s": " methods appear in kernel:core's "
            },
            [
              ":code",
              {
                "s": "_symbols"
              }
            ],
            {
              "s": "."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Provenance"
              }
            ],
            {
              "s": " — "
            },
            [
              ":code",
              {
                "s": "help()"
              }
            ],
            {
              "s": " special-cases "
            },
            [
              ":code",
              {
                "s": "api"
              }
            ],
            {
              "s": " → kernel:core (since "
            },
            [
              ":code",
              {
                "s": "api"
              }
            ],
            {
              "s": " isn't loaded via "
            },
            [
              ":code",
              {
                "s": "require()"
              }
            ],
            {
              "s": "), and recognizes sub-namespaces ("
            },
            [
              ":code",
              {
                "s": "api.events"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "api.viewport"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "api.instances"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "api.helpers"
              }
            ],
            {
              "s": ")."
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Module Provenance"
        }
      ],
      [
        ":p",
        [
          ":item-ref",
          {
            "s": "33333333-4444-0000-0000-000000000000"
          },
          {
            "s": "ModuleSystem"
          }
        ],
        {
          "s": " tracks which item each loaded module came from via a "
        },
        [
          ":code",
          {
            "s": "WeakMap"
          }
        ],
        {
          "s": " ("
        },
        [
          ":code",
          {
            "s": "moduleMetadata"
          }
        ],
        {
          "s": "). After "
        },
        [
          ":code",
          {
            "s": "evaluateCodeItem()"
          }
        ],
        {
          "s": ", it stores "
        },
        [
          ":code",
          {
            "s": "{ itemId, itemName }"
          }
        ],
        {
          "s": " keyed by the module object. "
        },
        [
          ":code",
          {
            "s": "help()"
          }
        ],
        {
          "s": " uses this to resolve any "
        },
        [
          ":code",
          {
            "s": "require()"
          }
        ],
        {
          "s": "'d module back to its source item — no manual metadata, works for all libraries automatically."
        }
      ],
      [
        ":p",
        {
          "s": "WeakMap is necessary because ES module namespace objects are non-extensible by spec. It also provides automatic garbage collection when modules are evicted from cache."
        }
      ],
