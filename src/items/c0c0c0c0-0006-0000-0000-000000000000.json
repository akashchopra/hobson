              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "type"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Only items of exactly this type"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "typeExtends"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Items whose type chain includes this type"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "(none)"
              }
            ],
            [
              ":td",
              {
                "s": "All events of this name"
              }
            ]
          ]
        ]
      ],
      [
