      ],
      [
        ":h2",
        {
          "s": "Event Flow Example"
        }
      ],
      [
        ":p",
        {
          "s": "When a note is saved:"
        }
      ],
      [
        ":code-block",
        {
          "s": "1. api.set(noteItem) called\n2. Storage validates and writes to IndexedDB\n3. Kernel emits item:created (or item:updated)\n4. EventBus notifies all subscribers:\n   - Runtime subscriptions (api.events.on)\n   - Declarative watches matching the event\n5. Handlers execute with event data and API access"
        }
      ],
      [
        ":h2",
        {
          "s": "Built-in Event Handlers"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Handler"
              }
            ],
            [
              ":th",
              {
                "s": "Watches"
              }
            ],
            [
              ":th",
              {
                "s": "Purpose"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              [
                ":item-ref",
                {
                  "s": "e7707000-0000-0000-0000-000000000002"
                },
                {
                  "s": "default-error-handler"
                }
              ]
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "error-event"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Creates error items, shows toast"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":item-ref",
                {
                  "s": "dafc22a5-13bf-4b42-937d-52f002c4bc70"
                },
                {
                  "s": "view-update-watcher"
                }
              ]
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "item:updated"
                }
              ],
              {
                "s": " (views)"
              }
            ],
            [
              ":td",
              {
                "s": "Re-renders when view code changes"
              }
            ]
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Creating Event-Driven Extensions"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            {
              "s": "Create a library item"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Add "
            },
            [
              ":code",
              {
                "s": "content.watches"
              }
            ],
            {
              "s": " array"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Export handler functions matching the naming convention"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "The kernel auto-wires them on boot"
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "This is how the error handling system works—no kernel modification needed."
        }
      ],
      [
        ":h2",
        {
          "s": "Watch Filter Evaluation"
        }
      ],
      [
        ":p",
        {
          "s": "Filters are evaluated at "
        },
        [
          ":strong",
          {
            "s": "event-fire time"
          }
        ],
        {
          "s": ", not cached at boot:"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            {
              "s": "When an event fires, the kernel queries all code items with matching "
            },
            [
              ":code",
              {
                "s": "watches"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "For each watcher, filters are evaluated against the event's item:"
            }
          ],
          [
            ":ul",
            [
              ":li",
              [
                ":p",
                [
                  ":code",
                  {
                    "s": "type"
                  }
                ],
                {
                  "s": ": exact match "
                },
                [
                  ":code",
                  {
                    "s": "event.item.type === filter.type"
                  }
                ]
              ]
            ],
            [
              ":li",
              [
                ":p",
                [
                  ":code",
                  {
                    "s": "typeExtends"
                  }
                ],
                {
                  "s": ": walks the item's type chain, checks if "
                },
                [
                  ":code",
                  {
                    "s": "filter.typeExtends"
                  }
                ],
                {
                  "s": " is in the chain"
                }
              ]
            ],
            [
              ":li",
              [
                ":p",
                [
                  ":code",
                  {
                    "s": "id"
                  }
                ],
                {
                  "s": ": exact match "
                },
                [
                  ":code",
                  {
                    "s": "event.item.id === filter.id"
                  }
                ]
              ]
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Multiple filter fields are AND-ed together"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "No filters (only "
            },
            [
              ":code",
              {
                "s": "event"
              }
            ],
            {
              "s": ") matches all events of that type"
            }
          ]
        ]
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Why event-fire time?"
          }
        ],
        {
          "s": " Type chains can change dynamically. Caching at boot would miss new types."
        }
      ],
      [
        ":h2",
        {
          "s": "Design Rationale"
        }
      ],
      [
        ":h3",
        {
          "s": "Why Declarative Over Imperative?"
        }
      ],
      [
        ":p",
        {
          "s": "Imperative "
        },
        [
          ":code",
          {
            "s": "api.events.on()"
          }
        ],
        {
          "s": " requires code to run at boot time to register listeners. Declarative watches as data:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Enable \"what watches what\" queries without executing code"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Automatic lifecycle management (no manual subscribe/unsubscribe)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Fit the \"everything is data\" philosophy"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Are inspectable — you can query which items watch which events"
            }
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "Why Automatic Subscriptions?"
        }
      ],
      [
        ":p",
        {
          "s": "When a renderer renders an item, the kernel automatically subscribes to changes in that item's attachments. This:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Eliminates boilerplate subscription management"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Ensures consistency (can't forget to subscribe)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Limits notifications to direct parents only (prevents cascading re-renders)"
            }
          ]
        ]
      ],
