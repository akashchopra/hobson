{
  "id": "c0c0c0c0-0006-0000-0000-000000000000",
  "name": "Event System",
  "type": "871ae771-b9b1-4f40-8c7f-d9038bfb69c3",
  "created": 1738454400000,
  "modified": 1773334195806,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Hobson uses an event system for reactive programming. Code can subscribe to events and respond when things happen in the system."
        }
      ],
      [
        ":h2",
        {
          "s": "Event Types"
        }
      ],
      [
        ":p",
        {
          "s": "Events are organized into namespaces:"
        }
      ],
      [
        ":h3",
        {
          "s": "Item Events ("
        },
        [
          ":code",
          {
            "s": "item:*"
          }
        ],
        {
          "s": ")"
        }
      ],
      [
        ":table",
        [
