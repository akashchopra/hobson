      [
        ":h2",
        {
          "s": "Subscribing to Events"
        }
      ],
      [
        ":h3",
        {
          "s": "In Code (Runtime)"
        }
      ],
      [
        ":code-block",
        {
          "s": "// Subscribe using event type GUIDs\nconst unsubscribe = api.events.on(api.EVENT_IDS.ITEM_UPDATED, (event) => {\n  console.log('Item changed:', event.content.item.id);\n});\n\n// Later: unsubscribe\nunsubscribe();"
        }
      ],
      [
        ":p",
        {
          "s": "The "
        },
        [
          ":code",
          {
            "s": "api.events.on()"
          }
        ],
        {
          "s": " function takes an "
        },
        [
          ":strong",
          {
            "s": "event type GUID"
          }
        ],
        {
          "s": ", not a string name. Use "
        },
        [
          ":code",
          {
            "s": "api.EVENT_IDS"
          }
        ],
        {
          "s": " for well-known events (ITEM_CREATED, ITEM_UPDATED, ITEM_DELETED, SYSTEM_ERROR, SYSTEM_BOOT_COMPLETE)."
        }
      ],
      [
        ":h3",
        {
          "s": "Declarative Watches"
        }
      ],
      [
        ":p",
        {
          "s": "Code items can declare event subscriptions that activate automatically:"
        }
      ],
      [
        ":code-block",
        {
          "s": "{\n  type: \"library-uuid\",\n  watches: [\n    { event: \"e0e00000-0001-0001-0000-000000000000\", type: \"note-type-uuid\" },\n    { event: \"e0e00000-0001-0002-0000-000000000000\", typeExtends: \"code-type-uuid\" },\n    { event: \"e0e00000-0002-0001-0000-000000000000\" }\n  ],\n  content: {\n    code: `\n      export async function onItemCreated(event, api) {\n        // Called when a note is created\n      }\n\n      export async function onItemUpdated(event, api) {\n        // Called when any code item is updated\n      }\n\n      export async function onErrorEvent(event, api) {\n        // Called on any system error\n      }\n    `\n  }\n}"
        }
      ],
      [
        ":p",
        {
          "s": "Note: "
        },
        [
          ":code",
          {
            "s": "watches"
          }
        ],
        {
          "s": " is a "
        },
        [
          ":strong",
          {
            "s": "top-level field"
          }
        ],
        {
          "s": " on the item, not inside "
        },
        [
          ":code",
          {
            "s": "content"
          }
        ],
        {
          "s": ". The "
        },
        [
          ":code",
          {
            "s": "event"
          }
        ],
        {
          "s": " field takes an "
        },
        [
          ":strong",
          {
            "s": "event type GUID"
          }
        ],
        {
          "s": " (not the event name string). Handler names are derived from the event definition item's name (e.g., event named "
        },
        [
          ":code",
          {
            "s": "item:created"
          }
        ],
        {
          "s": " → handler "
        },
        [
          ":code",
          {
            "s": "onItemCreated"
          }
        ],
        {
          "s": ")."
        }
      ],
      [
        ":h3",
        {
          "s": "Watch Filters"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Filter"
              }
            ],
            [
              ":th",
              {
