    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Reusable window chrome for container views. Renders a titlebar (from item name) and a :render-child mount point for the item's content view. Used by spatial-canvas, modal-frame, etc. to delegate chrome rendering so the container only depends on its own item."
        }
      ]
    ],
