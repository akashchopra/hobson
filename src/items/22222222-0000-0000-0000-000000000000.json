        ":h2",
        {
          "s": "Error Handling"
        }
      ],
      [
        ":p",
        {
          "s": "If code fails to parse or throws during evaluation:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Error is caught by the module system"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Stack trace includes item name via sourceURL"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "System continues running (errors don't crash Hobson)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Error items created if "
            },
            [
