  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Base type for executable items. Any item with "
        },
        [
          ":code",
          {
            "s": "kernel:code"
          }
        ],
        {
          "s": " in its type chain is a code item—its "
        },
        [
          ":code",
          {
            "s": "content.code"
          }
        ],
        {
          "s": " field contains JavaScript that gets evaluated as an ES module."
        }
      ],
      [
        ":h2",
        {
          "s": "How Code Execution Works"
        }
      ],
      [
        ":p",
        {
          "s": "When a code item is loaded via "
        },
        [
          ":code",
          {
            "s": "api.require()"
          }
        ],
        {
          "s": ", the module system evaluates it:"
        }
      ],
      [
        ":p",
        {
          "s": "!"
        },
        [
          ":item-ref",
          {
            "s": "33333333-4444-0000-0000-000000000000?symbol=evaluateCodeItem"
          }
        ],
        {
          "s": " "
        }
      ],
      [
        ":p",
        {
          "s": "The "
        },
        [
          ":code",
          {
            "s": "//# sourceURL"
          }
        ],
        {
          "s": " comment gives meaningful names in stack traces and the debugger."
        }
      ],
      [
        ":h2",
        {
          "s": "The "
        },
        [
          ":code",
          {
            "s": "content.code"
          }
        ],
        {
          "s": " Field"
        }
      ],
      [
        ":p",
        {
          "s": "Must be valid ES module JavaScript."
        }
      ],
      [
        ":h2",
        {
          "s": "Caching"
        }
      ],
      [
        ":p",
        {
          "s": "Modules are cached by item ID with their "
        },
        [
          ":code",
          {
            "s": "modified"
          }
        ],
        {
          "s": " timestamp. When you save a code item:"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            {
              "s": "The "
            },
            [
              ":code",
              {
                "s": "modified"
              }
            ],
            {
              "s": " timestamp updates"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Next "
            },
            [
              ":code",
              {
                "s": "api.require()"
              }
            ],
            {
              "s": " detects the timestamp change"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Module is re-evaluated from fresh code"
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "This enables live editing—change code, save, and new behavior takes effect."
        }
      ],
      [
        ":h2",
        {
          "s": "Loading Code Items"
        }
      ],
      [
        ":code-block",
        {
          "s": "// By name (searches code items)\nconst lib = await api.require('my-library');\n\n// By UUID (direct lookup)\nconst lib = await api.require('66666666-1234-5678-...');"
        }
      ],
      [
