{
  "id": "c0c0c0c0-0014-0000-0000-000000000000",
  "name": "Type Chain Validation",
  "type": "871ae771-b9b1-4f40-8c7f-d9038bfb69c3",
  "created": 1738454400000,
  "modified": 1775756670819,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "The type system in Hobson forms chains: every item has a "
        },
        [
          ":code",
          {
            "s": "type"
          }
        ],
        {
          "s": " field pointing to its type item, which itself has a type, forming a chain that terminates at "
        },
        [
          ":code",
          {
            "s": "atom"
          }
        ],
        {
          "s": " (self-referential) or "
        },
        [
          ":code",
          {
            "s": "TYPE_DEFINITION"
          }
        ],
        {
          "s": ". The kernel validates these chains on every item save."
        }
      ],
      [
        ":h2",
        {
          "s": "The Type Chain"
        }
      ],
      [
        ":p",
        {
          "s": "Starting from any item, following the "
        },
        [
          ":code",
          {
            "s": "type"
          }
        ],
        {
          "s": " field produces a chain:"
        }
      ],
      [
        ":code-block",
        {
          "s": "my-note → note → TYPE_DEFINITION → atom (self-referential)\nmy-view → view → code → TYPE_DEFINITION → atom"
        }
      ],
      [
        ":p",
        {
          "s": "The kernel walks this chain during "
        },
        [
          ":code",
          {
            "s": "typeChainIncludes()"
          }
        ],
        {
          "s": " to answer questions like \"is this item a code item?\" (does its chain include "
        },
        [
          ":code",
          {
            "s": "code"
          }
        ],
        {
          "s": "?)."
        }
      ],
      [
        ":h2",
        {
          "s": "Bounded Walking"
        }
      ],
      [
        ":p",
        {
          "s": "Type chains are walked with a boundary at "
        },
        [
          ":code",
          {
            "s": "TYPE_DEFINITION"
          }
        ],
        {
          "s": ". When an item's type is "
        },
        [
          ":code",
          {
            "s": "TYPE_DEFINITION"
          }
        ],
        {
          "s": ", that item is itself a type (not an instance), so walking further crosses a meta-level boundary."
        }
      ],
      [
        ":code-block",
        {
          "s": "async typeChainIncludes(typeId, targetId) {\n  let current = typeId;\n  const visited = new Set();\n\n  while (current && !visited.has(current)) {\n    if (current === targetId) return true;\n    visited.add(current);\n\n    if (current === this.kernel.IDS.ATOM) break;\n\n    const typeItem = await this.kernel.storage.get(current);\n    if (typeItem.type === this.kernel.IDS.TYPE_DEFINITION) break;\n\n    current = typeItem.type;\n  }\n\n  return false;\n}"
        }
      ],
      [
        ":p",
        {
          "s": "This prevents meta-level confusion:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "note_view"
              }
            ],
            {
              "s": " \"is code\" → YES (code is in chain before TYPE_DEFINITION boundary)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "note_view"
              }
            ],
            {
              "s": " \"is type_definition\" → NO (TYPE_DEFINITION is past the boundary)"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Validation Rules"
        }
      ],
      [
        ":p",
        {
          "s": "On every "
        },
        [
          ":code",
          {
            "s": "storage.set()"
          }
        ],
        {
          "s": " call, the kernel validates:"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Type exists"
              }
            ],
            {
              "s": " — the referenced type item must exist in storage"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Chain terminates"
              }
            ],
            {
              "s": " — following type pointers must reach "
            },
            [
              ":code",
              {
                "s": "atom"
              }
            ],
            {
              "s": " or "
            },
            [
              ":code",
              {
                "s": "TYPE_DEFINITION"
              }
            ],
            {
              "s": " without infinite loops"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "No circular types"
              }
            ],
            {
              "s": " — visited-set prevents infinite walking"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Code item name uniqueness"
              }
            ],
            {
              "s": " — if the item is a code item (type chain includes "
            },
            [
              ":code",
              {
                "s": "code"
              }
            ],
            {
              "s": "), its "
            },
            [
              ":code",
              {
                "s": "name"
              }
            ],
            {
              "s": " must be unique among all code items"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Why Bounded Walking Matters"
        }
      ],
      [
        ":p",
        {
          "s": "The chain conflates two different relationships:"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Subtype"
              }
            ],
            {
              "s": " (same meta-level): "
            },
            [
              ":code",
              {
                "s": "view"
              }
            ],
            {
              "s": " is-a-kind-of "
            },
            [
              ":code",
              {
                "s": "code"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Meta-level"
              }
            ],
            {
              "s": " (crosses levels): "
            },
            [
              ":code",
              {
                "s": "code"
              }
            ],
            {
              "s": " is-defined-by "
            },
            [
              ":code",
              {
                "s": "TYPE_DEFINITION"
              }
            ]
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "Without the boundary, "
        },
        [
          ":code",
          {
            "s": "typeChainIncludes(noteViewType, TYPE_DEFINITION)"
          }
        ],
        {
          "s": " would return "
        },
        [
          ":code",
          {
            "s": "true"
          }
        ],
        {
          "s": ", which is meaningless — a note view is not \"a type definition.\""
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "One rule"
          }
        ],
        {
          "s": " (stop at TYPE_DEFINITION) handles all capability detection correctly, without needing per-field content inspection."
        }
      ],
      [
        ":h2",
        {
          "s": "See Also"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
