{
  "id": "c0c0c0c0-0041-0000-0000-000000000000",
  "name": "Rich Text Editing",
  "type": "871ae771-b9b1-4f40-8c7f-d9038bfb69c3",
  "created": 1738454400000,
  "modified": 1773243817569,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "WYSIWYG editing beyond markdown."
        }
      ],
      [
        ":h2",
        {
          "s": "Concept"
        }
      ],
      [
        ":p",
        {
          "s": "Markdown is good but limited. Rich text editing could enable:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "ContentEditable with formatting toolbar"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Inline images, videos, embeds"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Tables and diagrams"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Cross-device editability preservation"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Hybrid Approach"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Store as structured data (not HTML)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Render appropriately per platform"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Preserve editing capability"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Libraries to Consider"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "ProseMirror (structured editing)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "TipTap (built on ProseMirror)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Quill"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Slate"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Trade-offs"
        }
      ],
      [
        ":p",
        {
          "s": "Markdown is simple and portable. Rich text editors are complex and fragile. The current markdown-based approach ("
        },
        [
          ":code",
          {
            "s": "hobson-markdown"
          }
        ],
        {
          "s": ", CodeMirror) may be sufficient for most use cases."
        }
      ],
      [
        ":h2",
        {
          "s": "Priority"
        }
      ],
      [
        ":p",
        {
          "s": "Low — markdown covers most needs. Only pursue if specific use cases demand it."
        }
      ]
    ],
    "tags": [
      "c0c0c0c0-0040-0000-0000-000000000000"
    ]
  },
  "attachments": []
}