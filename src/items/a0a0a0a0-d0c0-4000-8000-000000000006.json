  "content": {
    "title": "Events System",
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "API reference for Hobson's event system. For conceptual overview, subscribing patterns, watch filters, handler naming, and design rationale, see "
        },
        [
          ":item-ref",
          {
            "s": "c0c0c0c0-0006-0000-0000-000000000000"
          },
          {
            "s": "Event System concept"
          }
        ],
        {
          "s": "."
        }
      ],
      [
        ":hr"
      ],
      [
        ":h2",
        {
          "s": "API Reference"
        }
      ],
      [
        ":h3",
        [
          ":code",
          {
            "s": "api.events.on(eventTypeId, handler)"
          }
        ]
      ],
      [
        ":p",
        {
          "s": "Subscribe to an event type. Returns unsubscribe function."
        }
      ],
      [
        ":code-block",
        {
          "s": "const unsubscribe = api.events.on(api.EVENT_IDS.ITEM_UPDATED, (event) => {\n  console.log('Updated:', event.content.item.name);\n});\n\n// Later:\nunsubscribe();"
        }
      ],
      [
        ":h3",
        [
          ":code",
          {
            "s": "api.events.off(eventTypeId, handler)"
          }
        ]
      ],
      [
        ":p",
        {
          "s": "Remove a specific handler."
        }
      ],
      [
        ":h3",
        [
          ":code",
          {
            "s": "api.events.emit(event)"
          }
        ]
      ],
      [
        ":p",
        {
          "s": "Emit an event. Typically only kernel code emits core events."
        }
      ],
      [
        ":code-block",
        {
          "s": "api.events.emit({\n  type: 'my-custom-event-uuid',\n  content: { message: 'Hello!' }\n});"
        }
      ],
      [
        ":h3",
        [
          ":code",
          {
            "s": "api.events.list()"
          }
        ]
      ],
      [
        ":p",
        {
          "s": "Returns array of event type IDs with active listeners."
        }
      ],
      [
        ":hr"
      ],
      [
        ":h2",
        {
          "s": "Event Type Hierarchy"
        }
      ],
      [
        ":p",
        {
          "s": "Event types form a type chain like items. Subscribing to a parent type receives all child events."
        }
      ],
      [
        ":code-block",
        {
          "s": "event-definition (base)                  e0e00000-0000-0000-0000-000000000000\n├── item-event                           e0e00000-0001-0000-0000-000000000000\n│   ├── item:created                     e0e00000-0001-0001-0000-000000000000\n│   ├── item:updated                     e0e00000-0001-0002-0000-000000000000\n│   └── item:deleted                     e0e00000-0001-0003-0000-000000000000\n└── system-event                         e0e00000-0002-0000-0000-000000000000\n    ├── error-event                     e0e00000-0002-0001-0000-000000000000\n    └── kernel:boot-complete             e0e00000-0002-0002-0000-000000000000"
        }
      ],
      [
        ":hr"
      ],
      [
