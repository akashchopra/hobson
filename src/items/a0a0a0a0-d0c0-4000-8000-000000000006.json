        ],
        {
          "s": ", etc."
        }
      ],
      [
        ":hr"
      ],
      [
        ":h2",
        {
          "s": "Declarative Watches"
        }
      ],
      [
        ":p",
        {
          "s": "See "
        },
        [
          ":item-ref",
          {
            "s": "33333333-1111-0000-0000-000000000000#code?region=declarativeWatches"
          },
          {
            "s": "`declarativeWatches`"
          }
        ],
        {
          "s": " for implementation. For watch filter syntax and handler naming conventions, see "
        },
        [
          ":item-ref",
          {
            "s": "c0c0c0c0-0006-0000-0000-000000000000"
          },
          {
            "s": "Event System concept"
          }
        ],
        {
          "s": "."
        }
      ],
      [
        ":h3",
        {
          "s": "Example"
        }
      ],
      [
        ":code-block",
        {
          "s": "{\n  type: api.IDS.LIBRARY,\n  content: {\n    watches: [\n      { event: \"e0e00000-0002-0002-0000-000000000000\" },  // kernel:boot-complete\n      { event: \"e0e00000-0001-0002-0000-000000000000\", type: \"note-uuid\" }  // item:updated for notes\n    ],\n    code: `\n      export function onKernelBootComplete(content, api) {\n        console.log('Library activated!');\n      }\n      \n      export function onItemUpdated(content, api) {\n        console.log('Note updated:', content.item.name);\n      }\n    `\n  }\n}"
        }
      ],
      [
        ":hr"
      ],
      [
        ":h2",
        {
          "s": "Custom Event Types"
        }
      ],
      [
        ":code-block",
        {
          "s": "// Create custom event type\nawait api.set({\n  id: crypto.randomUUID(),\n  name: 'my-app:data-synced',\n  type: api.EVENT_IDS.SYSTEM_EVENT,\n  content: { description: 'Emitted when sync completes' }\n});\n\n// Rebuild cache to enable hierarchy dispatch\nawait kernel.buildEventTypeCache();"
        }
