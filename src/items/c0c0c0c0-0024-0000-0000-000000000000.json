        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "camelCase"
              }
            ],
            {
              "s": ": standard for all content fields"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "No dots in field names"
              }
            ],
            {
              "s": ": use nested objects instead"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "When to Use Which"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "`description`"
              }
            ],
            {
              "s": " — primary Active Text content for any item"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "`code`"
              }
            ],
            {
              "s": " — executable JavaScript (only for code items)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "`tags`"
              }
            ],
            {
              "s": " — classification (prefer over adding custom fields)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "`parent`"
              }
            ],
            {
              "s": " — hierarchical organization (tags, categories)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "`for_type`"
              }
            ],
            {
              "s": " — always on views and view specs"
            }
          ]
