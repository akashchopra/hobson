          "s": "const lib = await api.require('related-items-lib');\nlib.getInstancesOf(api.IDS.VIEW);       // all view items\nlib.getLinksTo(someItemId);             // items linking to it\nconst rel = await lib.getRelated(id);   // all relationships"
