  "content": {
    "code": "const totalLength = 10, bowLength = 2;\nconst mainHullLength = totalLength - bowLength;\nconst hullWidth = 2.5, hullHeight = 1.0, mastHeight = 8;\nconst sternEndX = -mainHullLength / 2 + bowLength / 2 + 0.05;\nconst mastheadX = mainHullLength / 2 - 1;\n\nexport const port = { x: 5, y: 1, z: -1.25 };\nexport const starboard = { x: 5, y: 1, z: 1.25 };\nexport const stern = { x: sternEndX, y: 1, z: 0 };\nexport const mast1 = { x: mastheadX, y: hullHeight + mastHeight - 0.5, z: 0};\nexport const mast2 = { x: mastheadX, y: hullHeight + mastHeight, z: 0};\nexport const foreMast = { x: mastheadX + 3,  y: hullHeight + 2, z: 0};\nexport const aftMast = { x: mastheadX - 4, y: hullHeight + 4, z: 0};\nexport const foreMastHigh = { x: mastheadX + 3,  y: hullHeight + 3, z: 0};\nexport const aftMastLow = { x: mastheadX - 4, y: hullHeight + 2, z: 0};\nexport const cabin1 = { x: mastheadX - 2, y: hullHeight + 2.5, z: 0};\nexport const cabin2 = { x: mastheadX - 2, y: hullHeight + 3.0, z: 0};\nexport const cabin3 = { x: mastheadX - 2, y: hullHeight + 3.5, z: 0};\nexport const cabinPort = { x: mastheadX - 2, y: hullHeight + 2.5, z: -1.25};\nexport const cabinStarboard = { x: mastheadX - 2, y: hullHeight + 2.5, z: 1.25};\n\nexport const portSector = { min: -112.5, max: 1 };\nexport const starboardSector = { min: -1, max: 112.5 };\nexport const sternSector = { min: 112.5, max: -112.5 };\nexport const forwardSector = { min: -112.5, max: 112.5 };\nexport const allRound = { min: -180.0, max: 180.0 };\n\nexport const portLight =      { name: 'port',      color: 'red', position: port,        label: 'Port',      sector: portSector };\nexport const starboardLight = { name: 'starboard', color: 'green', position: starboard, label: 'Starboard', sector: starboardSector };\nexport const sternLight =     { name: 'stern',     color: 'white', position: stern,     label: 'Stern',     sector: sternSector };\n\nexport async function render(api, boat, lights) {\n  const { THREE, OrbitControls } = await api.require('three-js-lib');\n\n  boat = boat || \"sailing\";\n  lights = lights || [];\n  \n  const container = document.createElement('div');\n  container.style.cssText = 'width:100%;height:500px;position:relative;background:#1a1a1a;border-radius:var(--border-radius-lg);overflow:hidden;';\n\n  const resetBtn = document.createElement('button');\n  resetBtn.textContent = 'Reset view';\n  resetBtn.style.cssText = 'position:absolute;top:12px;right:12px;z-index:10;padding:6px 12px;background:#222;color:#fff;border:0.5px solid #555;border-radius:6px;font-size:13px;cursor:pointer;';\n  container.appendChild(resetBtn);\n\n  const threeContainer = document.createElement('div');\n  threeContainer.style.cssText = 'width:100%;height:100%;';\n  container.appendChild(threeContainer);\n\n  const scene = new THREE.Scene();\n  scene.background = new THREE.Color(0x1a1a1a);\n\n  const initW = threeContainer.clientWidth || 800;\n  const initH = threeContainer.clientHeight || 600;\n  const camera = new THREE.PerspectiveCamera(45, initW / initH, 0.1, 1000);\n  camera.position.set(40, 15, 15);\n\n  const renderer = new THREE.WebGLRenderer({ antialias: true });\n  renderer.setSize(initW, initH, false);\n  renderer.domElement.style.cssText = 'display:block;width:100%;height:100%;'; \n  renderer.shadowMap.enabled = true;\n  threeContainer.appendChild(renderer.domElement);\n\n  scene.add(new THREE.AmbientLight(0x404040, 1.5));\n  const dir = new THREE.DirectionalLight(0xffffff, 1.5);\n  dir.position.set(-5, 15, 10);\n  dir.castShadow = true;\n  scene.add(dir);\n\n  const water = new THREE.Mesh(\n    new THREE.PlaneGeometry(100, 100),\n    new THREE.MeshBasicMaterial({ color: 0x003366, transparent: true, opacity: 0.6 })\n  );\n  water.rotation.x = -Math.PI / 2;\n  scene.add(water);\n\n  const controls = new OrbitControls(camera, renderer.domElement);\n  controls.enableDamping = true;\n  controls.dampingFactor = 0.05;\n  controls.target.set(0, 0, 0);\n\n  const boatGroup = new THREE.Group();\n  scene.add(boatGroup);\n\n  const lightMap = {};\n\n  function buildHull() {\n    const hull = new THREE.Mesh(\n      new THREE.BoxGeometry(mainHullLength, hullHeight, hullWidth),\n      new THREE.MeshStandardMaterial({ color: 0xdddddd })\n    );\n    hull.position.set(bowLength / 2, hullHeight / 2, 0);\n    boatGroup.add(hull);\n\n    const bowGeometry = new THREE.BoxGeometry(bowLength, hullHeight, hullWidth);\n    bowGeometry.translate(bowLength / 2, 0, 0);\n    const pos = bowGeometry.attributes.position;\n    for (let i = 0; i < pos.count; i++) {\n      pos.setZ(i, pos.getZ(i) * (1 - pos.getX(i) / bowLength));\n    }\n    pos.needsUpdate = true;\n    bowGeometry.computeVertexNormals();\n    const bow = new THREE.Mesh(bowGeometry, new THREE.MeshStandardMaterial({ color: 0xdddddd }));\n    bow.position.set((mainHullLength + bowLength) / 2, hullHeight / 2, 0);\n    boatGroup.add(bow);\n  }\n\n  function addSector(cfg) {\n    const s = THREE.MathUtils.degToRad(cfg.sector.min);\n    const e = THREE.MathUtils.degToRad(cfg.sector.max);\n    let delta = e - s;\n    if (delta < 0) delta += Math.PI * 2;\n\n    const segments = 32;\n    const vertices = [0, 0, 0];\n    const indices = [];\n    for (let i = 0; i <= segments; i++) {\n      const angle = s + delta * (i / segments);\n      vertices.push(Math.cos(angle) * 20, 0, Math.sin(angle) * 20);\n      if (i < segments) indices.push(0, i + 1, i + 2);\n    }\n\n    const geometry = new THREE.BufferGeometry();\n    geometry.setAttribute('position', new THREE.Float32BufferAttribute(vertices, 3));\n    geometry.setIndex(indices);\n    geometry.computeVertexNormals();\n\n    const sector = new THREE.Mesh(geometry, new THREE.MeshBasicMaterial({\n      color: cfg.color, transparent: true, opacity: 0.15,\n      side: THREE.DoubleSide, depthWrite: false\n    }));\n    sector.position.set(cfg.position.x, cfg.position.y + 0.05, cfg.position.z);\n    boatGroup.add(sector);\n    return sector;\n  }\n\n  function addLight(cfg) {\n    \n    const mesh = new THREE.Mesh(\n      new THREE.SphereGeometry(0.2, 16, 16),\n      new THREE.MeshStandardMaterial({ color: cfg.color, emissive: cfg.color, emissiveIntensity: 3.0, roughness: 0.1 })\n    );\n    mesh.position.set(cfg.position.x, cfg.position.y, cfg.position.z);\n    mesh.add(new THREE.PointLight(cfg.color, 2, 15));\n    boatGroup.add(mesh);\n\n    const canvas = document.createElement('canvas');\n    \n    //Disable labels for now\n    if (false) { //(cfg.label) {\n      canvas.width = 256; canvas.height = 64;\n      const ctx = canvas.getContext('2d');\n      ctx.fillStyle = 'rgba(0,0,0,0.5)';\n      ctx.fillRect(0, 0, 256, 64);\n      ctx.font = 'bold 28px Arial';\n      ctx.fillStyle = 'white';\n      ctx.textAlign = 'center';\n      ctx.fillText(cfg.label, 128, 42);\n    }\n    const sprite = new THREE.Sprite(new THREE.SpriteMaterial({ map: new THREE.CanvasTexture(canvas) }));\n    sprite.scale.set(3, 0.75, 1);\n    sprite.position.set(cfg.position.x, cfg.position.y + 1.5, cfg.position.z);\n    //boatGroup.add(sprite);\n\n    lightMap[cfg.name] = { mesh, sprite, min: cfg.sector.min, max: cfg.sector.max, sector: addSector(cfg) };\n  }\n\n  function getBearingFromBoat() {\n    const boatPos = new THREE.Vector3();\n    boatGroup.getWorldPosition(boatPos);\n    const dir = camera.position.clone().sub(boatPos);\n    dir.y = 0;\n    dir.normalize();\n    const forward = new THREE.Vector3(1, 0, 0).applyQuaternion(boatGroup.quaternion);\n    forward.y = 0;\n    forward.normalize();\n    return Math.atan2(forward.x * dir.z - forward.z * dir.x, forward.x * dir.x + forward.z * dir.z) * (180 / Math.PI);\n  }\n\n  function updateVisibility() {\n    const b = getBearingFromBoat();\n    for (const l of Object.values(lightMap)) {\n      const vis = l.min < l.max ? (b >= l.min && b <= l.max) : (b <= l.max || b >= l.min);\n      l.mesh.visible = vis;\n      l.sprite.visible = vis;\n      l.sector.visible = vis;\n    }\n  }\n\n  buildHull();\n  if (boat === 'sailing') {\n    const mast = new THREE.Mesh(\n      new THREE.CylinderGeometry(0.1, 0.1, mastHeight, 8),\n      new THREE.MeshStandardMaterial({ color: 0x888888 })\n    );\n    mast.position.set(mastheadX, hullHeight + mastHeight / 2, 0);\n    boatGroup.add(mast);\n  } else {\n    const cabinLen = mainHullLength * 0.3;\n    const cabin = new THREE.Mesh(\n      new THREE.BoxGeometry(cabinLen, 1.5, hullWidth * 0.7),\n      new THREE.MeshStandardMaterial({ color: 0xeeeeee })\n    );\n    cabin.position.set(mainHullLength / 4 - cabinLen, hullHeight + 0.75, 0);\n    boatGroup.add(cabin);\n  }\n  lights.forEach(cfg => addLight(cfg));\n\n  const resizeObserver = new ResizeObserver(entries => {\n    for (const entry of entries) {                    \n          const { width, height } = entry.contentRect;                                                        \n          if (height === 0) return;                   \n          camera.aspect = width / height;\n          camera.updateProjectionMatrix();\n          renderer.setSize(width, height, false);\n    }\n  });\n  resizeObserver.observe(threeContainer);\n\n  let everMounted = false;\n  function animate() {\n    const inDoc = document.contains(renderer.domElement);\n    if (everMounted && !inDoc) {\n      renderer.dispose();\n      resizeObserver.disconnect();\n      return;\n    }\n    if (inDoc) everMounted = true;\n    requestAnimationFrame(animate);\n    controls.update();\n    updateVisibility();\n    renderer.render(scene, camera);\n  }\n  animate();\n\n  resetBtn.onclick = () => {\n    camera.position.set(40, 15, 15);\n    controls.target.set(0, 0, 0);\n    controls.update();\n  };\n\n  return container;\n}",
