    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Lifejackets are designed for use on boats where you wouldn’t normally expect to end up in the water, such as on a yacht, motor cruiser, open powerboat or tender. If you are unconscious, a lifejacket will help to turn you the right way up with your mouth and nose clear of the water."
        }
      ],
      [
        ":h4",
        {
          "s": "Buoyancy Level"
        }
      ],
      [
        ":p",
        {
          "s": "The two recommended levels for yachts are shown below. Lifejackets with less buoyancy are for watersports; higher buoyancy is for extreme conditions and/or heavy clothing - makes it very difficult to get into "
        },
        [
          ":item-ref",
          {
            "s": "c212885e-3e9c-4ad7-b077-87e45f7ddda9"
          },
          {
            "s": "Liferaft"
          }
        ],
        {
          "s": "."
        }
      ],
      [
        ":h5",
        {
          "s": "Level 100 – ISO 12402-4"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Minimum buoyancy:"
              }
            ],
            {
              "s": " 100 Newtons"
            }
          ]
