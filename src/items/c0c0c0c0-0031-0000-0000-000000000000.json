              },
              {
                "s": "Safe Mode"
              }
            ],
            {
              "s": " — Recovery workflows"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "eeee0000-0000-0000-0000-000000000001"
              },
              {
                "s": "Element Inspector"
              }
            ],
            {
              "s": " — Debug mode tooling"
            }
          ]
        ]
      ]
    ],
