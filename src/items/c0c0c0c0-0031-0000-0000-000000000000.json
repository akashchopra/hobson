{
  "id": "c0c0c0c0-0031-0000-0000-000000000000",
  "name": "URL Parameters",
  "type": "871ae771-b9b1-4f40-8c7f-d9038bfb69c3",
  "created": 1770400000000,
  "modified": 1773763928696,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Hobson's bootloader and kernel recognize several URL query parameters that control startup behavior and debugging."
        }
      ],
      [
        ":h2",
        {
          "s": "Parameters"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Parameter"
              }
            ],
            [
              ":th",
              {
                "s": "Values"
              }
            ],
            [
              ":th",
              {
                "s": "Purpose"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "?safe=1"
                }
              ]
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "1"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Boot in "
              },
              [
                ":item-ref",
                {
                  "s": "33333333-7777-0000-0000-000000000000"
                },
                {
                  "s": "safe mode"
                }
              ],
              {
                "s": " — kernel only, no user code items loaded. Shows import UI for recovery."
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "?debug"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "(flag)"
              }
            ],
            [
              ":td",
              {
                "s": "Enable debug mode. Activates DOM attribution ("
              },
              [
                ":code",
                {
                  "s": "data-view-id"
                }
              ],
              {
                "s": ", "
              },
              [
                ":code",
                {
                  "s": "data-for-item"
                }
              ],
              {
                "s": ", "
              },
              [
                ":code",
                {
                  "s": "data-source"
                }
              ],
              {
                "s": ", "
              },
              [
                ":code",
                {
                  "s": "data-source-line"
                }
              ],
              {
                "s": ") and auto-loads the "
              },
              [
                ":item-ref",
                {
                  "s": "eeee0000-0000-0000-0000-000000000001"
                },
                {
                  "s": "element-inspector"
                }
              ],
              {
                "s": " on boot."
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "?instance=<id>"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "UUID"
              }
            ],
            [
              ":td",
              {
                "s": "Boot a "
              },
              [
                ":item-ref",
                {
                  "s": "c0c0c0c0-0002-0000-0000-000000000000"
                },
                {
                  "s": "nested instance"
                }
              ],
              {
                "s": ". All storage keys are prefixed with "
              },
              [
                ":code",
                {
                  "s": "<id>:"
                }
              ],
              {
                "s": " for isolation. Multiple instances share one IndexedDB but are namespaced."
              }
            ]
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Usage Examples"
        }
      ],
      [
        ":code-block",
        {
          "s": "hobson.html?safe=1              Safe mode recovery\nhobson.html?debug               Debug with inspector\nhobson.html?instance=abc123     Nested instance\nhobson.html?safe=1&debug        Combined: safe mode + debug"
        }
      ],
      [
        ":h2",
        {
          "s": "Notes"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "?safe=1"
              }
            ],
            {
              "s": " can also be triggered at runtime via "
            },
            [
              ":strong",
              {
                "s": "Ctrl+Shift+S"
              }
            ],
            {
              "s": " keyboard shortcut"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "?debug"
              }
            ],
            {
              "s": " mode adds "
            },
            [
              ":code",
              {
                "s": "data-*"
              }
            ],
            {
              "s": " attributes to all rendered DOM elements for tracing which view and item produced each element"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "?instance"
              }
            ],
            {
              "s": " enables running multiple isolated Hobson environments in different browser tabs or nested iframes"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "See Also"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "c0c0c0c0-0002-0000-0000-000000000000"
              },
              {
                "s": "Bootstrap"
              }
            ],
            {
              "s": " — Boot process that reads these parameters"
            }
          ]
        ],
        [
          ":li",
          [
