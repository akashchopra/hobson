  "content": {
    "title": "Roadmap — March 2026",
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Prioritized next steps based on a review of all notes, current capabilities, and recent git history."
        }
      ],
      [
        ":p",
        {
          "s": "Cross-reference: "
        },
        [
          ":item-ref",
          "c0c0c0c0-0042-0000-0000-000000000000"
        ],
        {
          "s": " catalogs the full possibility space. This item narrows to what's most impactful "
        },
        [
          ":em",
          {
            "s": "now"
          }
        ],
        {
          "s": " given system state as of March 2026."
        }
      ],
      [
        ":h2",
        {
          "s": "Where We Are"
        }
      ],
      [
        ":p",
        {
          "s": "Recent work has been a concentrated push on the "
        },
        [
          ":strong",
          {
            "s": "Active Text editor"
          }
        ],
        {
          "s": " — a structured document editing system replacing string-based descriptions with the Active Text format. This is a major architectural shift that unifies prose, code, and data under one representation."
        }
      ],
      [
        ":p",
        {
          "s": "Key accomplishments:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Active Text editor"
              }
            ],
            {
              "s": " — contenteditable prose editor with per-block editing, DOM↔AST synchronization, and inline formatting (bold, italic, code, strikethrough, highlight via keyboard shortcuts)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Table support"
              }
            ],
            {
              "s": " — full table parsing to "
            },
            [
              ":code",
              {
                "s": ":table"
              }
            ],
            {
              "s": " AST, readonly rendering with alignment, editable cells"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Eval blocks"
              }
            ],
            {
              "s": " — Hob expressions evaluated at block position in documents, structural editor integration, implicit "
            },
            [
              ":code",
              {
                "s": "do"
              }
            ],
            {
              "s": " wrapping"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Inline nodes"
              }
            ],
            {
              "s": " — "
            },
            [
              ":code",
              {
                "s": "@"
              }
            ],
            {
              "s": " autocomplete for item-refs, "
            },
            [
              ":code",
              {
                "s": "@@"
              }
            ],
            {
              "s": " for transclusions, "
            },
            [
              ":code",
              {
                "s": "{{"
              }
            ],
            {
              "s": " for field-refs, URL link insertion"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Editing popovers"
              }
            ],
            {
              "s": " — click-to-edit for item-refs, transclusions, and links"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Bulk migration"
              }
            ],
            {
              "s": " — all 294 items with string descriptions converted to "
            },
            [
              ":code",
              {
                "s": ":doc"
              }
            ],
            {
              "s": " AST format"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Performance fix"
              }
            ],
            {
              "s": " — replaced Hob-interpreted AST walks with native JS in hot paths (startup ~4s → near-instant)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Named fn support"
              }
            ],
            {
              "s": " — "
            },
            [
              ":code",
              {
                "s": "(fn name [params] body)"
              }
            ],
            {
              "s": " for recursion in Hob"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Phase 7 reactive simplification"
              }
            ],
            {
              "s": " — DependencyTracker removed, replaced with registry-based selector-filtered reactivity"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Kernel minimization"
              }
            ],
            {
              "s": " — rendering moved to userland "
            },
            [
              ":code",
              {
                "s": "viewport-rendering"
              }
            ],
            {
              "s": " library"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "22 of 48 views are Hob"
              }
            ],
            {
              "s": " — JSON AST is canonical, structural editor works"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Priority 1: Active Text Editor Parity"
        }
      ],
      [
        ":p",
        {
          "s": "Close the remaining gaps before merging the "
        },
        [
          ":code",
          {
            "s": "doc-ast-editor"
          }
        ],
        {
          "s": " branch to master. See "
        },
        [
          ":item-ref",
          "c0c0c0c0-005e-0000-0000-000000000000"
        ],
        {
          "s": " for the full parity analysis."
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Undo/redo"
              }
            ],
            {
