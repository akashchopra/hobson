        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Copy/paste"
              }
            ],
            {
              "s": " — paste HTML/plain text into AST, copy AST as clipboard HTML"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Multi-block selection"
              }
            ],
            {
              "s": " — select across block boundaries, delete/format ranges"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Block reordering"
              }
            ],
            {
              "s": " — drag-and-drop or keyboard shortcuts to move blocks up/down"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Inline expression evaluation"
              }
            ],
            {
              "s": " — extend eval blocks to work at inline level (see "
            },
            [
              ":item-ref",
              "c0c0c0c0-005d-0000-0000-000000000000"
            ],
            {
              "s": ")"
            }
          ]
        ]
      ],
      [
