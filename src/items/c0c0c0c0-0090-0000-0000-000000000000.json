        }
      ],
      [
        ":hr"
      ],
      [
        ":h2",
        {
          "s": "Where We Are"
        }
      ],
      [
        ":p",
        {
          "s": "Recent work has been a concentrated push on:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Phase 7 reactive simplification"
              }
            ],
            {
              "s": " — DependencyTracker removed entirely, replaced with registry-based selector-filtered reactivity"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "`:render-child` mount points"
              }
            ],
            {
              "s": " — declarative child rendering across sortable-list, modal-frame, error-list, spatial-canvas, viewport, hobson-markdown, app-page views"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Centralized navigation"
              }
            ],
            {
              "s": " — "
            },
            [
              ":code",
              {
                "s": "openItem"
              }
            ],
            {
              "s": "/"
            },
            [
              ":code",
              {
                "s": "open-item!"
              }
            ],
            {
              "s": " with modifier key support (Ctrl+click = open as root, etc.)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Element Inspector"
              }
            ],
            {
              "s": " — Hob source attribution, symbol indexing, function name tracking"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Structural editor polish"
              }
            ],
            {
              "s": " — string editing, blinking cursor, Ctrl+E fix, phases 1–6 complete"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Live-reload views"
              }
            ],
            {
              "s": " — re-render instances when view code changes"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Kernel minimization"
              }
            ],
            {
              "s": " — rendering system moved to userland "
            },
            [
              ":code",
              {
                "s": "viewport-rendering"
              }
            ],
            {
              "s": " library"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Type Workshop edit mode"
              }
            ],
            {
              "s": " — load existing types, reverse-engineer fields from ui_hints, update in place"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "`api.createElement` adoption"
              }
            ],
            {
              "s": " — "
            },
            [
              ":item-ref",
              {
                "s": "c0c0c0c0-0055-0000-0000-000000000000"
              },
              {
                "s": "all 13 userland items converted"
              }
            ],
            {
              "s": ", base createElement available on kernel API"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "REPL as item"
              }
            ],
            {
              "s": " — "
            },
            [
              ":item-ref",
              {
                "s": "c0c0c0c0-0057-0000-0000-000000000000"
              },
              {
                "s": "repl-session type + repl-view + singleton instance"
