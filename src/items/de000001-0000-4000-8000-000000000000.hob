"(let [note item]\n  [:div {:style \"padding: 16px; font-family: system-ui, sans-serif;\"}\n    [:h1 {:style \"margin: 0 0 8px 0;\"} (:name note)]\n    [:p {:style \"color: #888; font-size: 0.8em; margin: 0 0 16px 0;\"}\n      (str \"ID: \" (:id note))]\n    [:div {:style \"white-space: pre-wrap; line-height: 1.5;\"}\n      (or (get-in note [:content :description]) \"(no content)\")]])"