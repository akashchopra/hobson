        ":code-block",
        {
          "s": ";; Create mutable state (local to a view/handler)\n(def counter (atom 0))\n\n;; Read\n(deref counter)        ;; => 0\n\n;; Update\n(swap! counter inc)    ;; => 1\n(swap! counter + 5)    ;; => 6\n(reset! counter 0)     ;; => 0"
        }
      ],
      [
        ":p",
