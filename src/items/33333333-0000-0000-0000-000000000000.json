  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Type for kernel subsystem modules. These are the foundational code items that compose the "
        },
        [
          ":item-ref",
          {
            "s": "c0c0c0c0-0001-0000-0000-000000000000"
          },
          {
            "s": "kernel"
          }
        ],
        {
          "s": "—the minimal runtime that everything else builds upon."
        }
      ],
      [
        ":h2",
        {
          "s": "Kernel Modules"
        }
      ],
      [
        ":code-block",
        {
          "s": "const modules = await api.query({ type: api.IDS.KERNEL_MODULE });\nmodules.sort((a, b) => (a.name || '').localeCompare(b.name || ''));\nconst rows = modules.map(m => {\n  const desc = m.content?.description?.split('\\n')[0] || 'No description';\n  return `| [${m.name}](item://${m.id}) | ${desc} |`;\n});\nreturn '| Module | Responsibility |\\n|--------|----------------|\\n' + rows.join('\\n') + '\\n';"
        }
      ],
      [
        ":h2",
        {
          "s": "Why Kernel Modules Are Items"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Inspectable"
              }
            ],
            {
              "s": ": View source code through Hobson's UI"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Linkable"
              }
            ],
            {
              "s": ": Documentation can reference specific functions via "
            },
            [
              ":code",
              {
                "s": "item://id#code?region=name"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Modifiable"
              }
            ],
            {
              "s": ": (Carefully) customize kernel behavior"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Self-describing"
              }
            ],
            {
              "s": ": Each module documents itself"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Caution"
        }
      ],
      [
        ":p",
        {
          "s": "Editing kernel modules can break the system. Use "
        },
        [
          ":item-ref",
          {
            "s": "33333333-7777-0000-0000-000000000000"
          },
          {
            "s": "safe mode"
          }
        ],
        {
          "s": " to recover if needed."
        }
      ],
