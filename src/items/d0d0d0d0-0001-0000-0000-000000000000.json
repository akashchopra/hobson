{
  "id": "d0d0d0d0-0001-0000-0000-000000000000",
  "name": "type-workshop",
  "type": "11111111-0000-0000-0000-000000000000",
  "extends": "00000000-0000-0000-0000-000000000000",
  "created": 1771027200000,
  "modified": 1773243817705,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "A visual tool for creating and editing Hobson types. Generates type definitions with paired readonly and editable views (generic-view delegates) from a form interface."
        }
      ],
      [
        ":h2",
        {
          "s": "Creating a Type"
        }
      ],
      [
        ":p",
        {
          "s": "Fill in the form fields:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Type Name"
              }
            ],
            {
              "s": " — kebab-case identifier (e.g. "
            },
            [
              ":code",
              {
                "s": "recipe"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "bookmark"
              }
            ],
            {
              "s": ")"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Extends"
              }
            ],
            {
              "s": " — parent type (defaults to "
            },
            [
              ":code",
              {
                "s": "kernel:item"
              }
            ],
            {
              "s": ")"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Description"
              }
            ],
            {
              "s": " — free-text description stored on the type definition"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Fields"
              }
            ],
            {
              "s": " — each field specifies a content path ("
            },
            [
              ":code",
              {
                "s": "content.title"
              }
            ],
            {
              "s": "), a field-view ("
            },
            [
              ":code",
              {
                "s": "text"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "markdown"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "number"
              }
            ],
            {
              "s": ", etc.), a mode ("
            },
            [
              ":code",
              {
                "s": "both"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "readonly"
              }
            ],
            {
              "s": ", or "
            },
            [
              ":code",
              {
                "s": "editable"
              }
            ],
            {
              "s": "), and optional per-field-view settings (placeholder, rows, language, etc.)"
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "A "
        },
        [
          ":code",
          {
            "s": "name"
          }
        ],
        {
          "s": " heading field is always auto-included. The summary panel shows what will be created. Click "
        },
        [
          ":strong",
          {
            "s": "Create Type"
          }
        ],
        {
          "s": " to generate three items (type-def + two views), or "
        },
        [
          ":strong",
          {
            "s": "Create Type + Instance"
          }
        ],
        {
          "s": " to also create and navigate to a first instance."
        }
      ],
      [
        ":p",
        {
          "s": "After creation the workshop automatically switches to edit mode for the new type."
        }
      ],
      [
        ":h2",
        {
          "s": "Editing an Existing Type"
        }
      ],
      [
        ":p",
        {
          "s": "Click "
        },
        [
          ":strong",
          {
            "s": "Load Existing"
          }
        ],
        {
          "s": " to open a searchable picker of all type definitions. Selecting one populates the form by reverse-engineering the type's generic-view-delegate views:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Fields, modes, and options are reconstructed from "
            },
            [
              ":code",
              {
                "s": "ui_hints"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Unrecognized hint properties are preserved for round-trip fidelity"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Custom (non-generic-view) views are listed in a warning banner and left untouched"
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "After loading, the header shows which type is being edited, and the action buttons change to "
        },
        [
          ":strong",
          {
            "s": "Update Type"
          }
        ],
        {
          "s": " / "
        },
        [
          ":strong",
          {
            "s": "Update Type + Instance"
          }
        ],
        {
          "s": ". Updates modify the existing type-def and view items in place. Click "
        },
        [
          ":strong",
          {
            "s": "New Type"
          }
        ],
        {
          "s": " to return to create mode."
        }
      ],
      [
        ":h2",
        {
          "s": "Scope"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Manages generic-view delegates only — hand-written views are left untouched and listed in a warning"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Fields that exist on a type but aren't expressed in ui_hints (e.g. content stored by custom views) won't appear in the form"
            }
          ]
        ]
      ]
    ],
    "tags": [
      "c0c0c0c0-0071-0000-0000-000000000000",
      "a63eadd8-ec56-4163-acf2-207aa392069b"
    ]
  },
  "attachments": []
}