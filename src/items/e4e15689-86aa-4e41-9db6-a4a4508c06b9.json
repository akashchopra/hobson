      ":doc",
      [
        ":p",
        {
          "s": "WOBBLE:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "W"
              }
            ],
            {
              "s": "ater – Ensure seawater is flowing through the cooling system and that coolant levels are topped up."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "O"
              }
            ],
            {
              "s": "il – Check engine and gearbox oil. Milky or thick oil indicates contamination or an issue."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "B"
              }
            ],
            {
              "s": "elts – A loose or broken alternator belt can cause power loss and cooling system failure."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "B"
              }
            ],
            {
              "s": "atteries – Ensure they are charged above 12.5V and check for loose or corroded terminals."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "L"
              }
            ],
            {
              "s": "eaks – Look for any signs of water, oil, or fuel leaks in the bilge or around the engine."
            }
          ]
        ]
      ]
    ],
