{
  "id": "c0c0c0c0-0002-0000-0000-000000000000",
  "name": "Bootstrap",
  "type": "871ae771-b9b1-4f40-8c7f-d9038bfb69c3",
  "created": 1738454400000,
  "modified": 1775756670476,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Hobson uses a two-part bootstrap architecture: a minimal HTML bootloader loads a modular kernel from IndexedDB, enabling self-modification."
        }
      ],
      [
        ":h2",
        {
          "s": "The Two Parts"
        }
      ],
      [
        ":h3",
        {
          "s": "1. Bootloader ("
        },
        [
          ":code",
          {
            "s": "bootloader.html"
          }
        ],
        {
          "s": ")"
        }
      ],
      [
        ":p",
        {
          "s": "A minimal "
        },
        [
          ":item-ref",
          {
            "s": "f761e023-da8d-492d-9933-a75adcc8d316"
          },
          {
            "s": "HTML file"
          }
        ],
        {
          "s": " that "
        },
        [
          ":strong",
          {
            "s": "never changes"
          }
        ],
        {
          "s": " after deployment. It:"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            {
              "s": "Opens IndexedDB (database: "
            },
            [
              ":code",
              {
                "s": "hobson"
              }
            ],
            {
              "s": ")"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Looks for "
            },
            [
              ":item-ref",
              {
                "s": "33333333-1111-0000-0000-000000000000"
              },
              {
                "s": "kernel:core"
              }
            ],
            {
              "s": " by its GUID"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "If missing → shows import UI"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "If present → creates "
            },
            [
              ":code",
              {
                "s": "require()"
              }
            ],
            {
              "s": " function and loads kernel"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Calls "
            },
            [
              ":code",
              {
                "s": "kernel.boot()"
              }
            ]
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "The bootloader handles "
        },
        [
          ":strong",
          {
            "s": "nested instances"
          }
        ],
        {
          "s": " via "
        },
        [
          ":code",
          {
            "s": "?instance="
          }
        ],
        {
          "s": " URL parameter, passing the instance ID to the kernel for storage isolation."
        }
      ],
      [
        ":h3",
        {
          "s": "2. Kernel Modules"
        }
      ],
      [
        ":p",
        {
          "s": "The "
        },
        [
          ":item-ref",
          {
            "s": "c0c0c0c0-0001-0000-0000-000000000000"
          },
          {
            "s": "kernel"
          }
        ],
        {
          "s": " exists as items in IndexedDB. The bootloader loads and composes them."
        }
      ],
      [
        ":h2",
        {
          "s": "Boot Sequences"
        }
      ],
      [
        ":h3",
        {
          "s": "First Run (Empty Database)"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            {
              "s": "User opens bootstrap.html"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Bootloader checks IndexedDB → kernel:core not found"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Import UI shown"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "User selects kernel.json (contains "
            },
            [
              ":item-ref",
              {
                "s": "33333333-1111-0000-0000-000000000000?symbol=loadKernel.IDS"
              },
              {
                "s": "all seed items"
              }
            ],
            {
              "s": ")"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Items written to IndexedDB"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Page reloads → proceeds to normal boot"
            }
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "Normal Boot"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            {
              "s": "Bootloader opens IndexedDB"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Creates require() function (blob URL evaluation)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Loads kernel:core module"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Calls loadKernel(require, db, instanceId)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Kernel constructor initializes subsystems"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "kernel.boot() runs:"
            }
          ],
          [
            ":ul",
            [
              ":li",
              [
                ":p",
                {
                  "s": "Applies styles from kernel:styles"
                }
              ]
            ],
            [
              ":li",
              [
                ":p",
                {
                  "s": "Checks for ?safe=1 parameter"
                }
              ]
            ],
            [
              ":li",
              [
                ":p",
                {
                  "s": "Builds event type cache"
                }
              ]
            ],
            [
              ":li",
              [
                ":p",
                {
                  "s": "Sets up declarative watches"
                }
              ]
            ],
            [
              ":li",
              [
                ":p",
                {
                  "s": "Renders viewport (which renders root item)"
                }
              ]
            ],
            [
              ":li",
              [
                ":p",
                {
                  "s": "Emits kernel:boot-complete"
                }
              ]
            ]
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "Safe Mode Boot ("
        },
        [
          ":code",
          {
            "s": "?safe=1"
          }
        ],
        {
          "s": ")"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            {
              "s": "Same as normal boot through step 5"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "kernel.boot() detects ?safe=1"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Renders safe mode UI instead of viewport"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "User code items NOT executed"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "The "
        },
        [
          ":code",
          {
            "s": "require()"
          }
        ],
        {
          "s": " Function"
        }
      ],
      [
        ":p",
        {
          "s": "The bootloader creates a custom "
        },
        [
          ":code",
          {
            "s": "require()"
          }
        ],
        {
          "s": " that:"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            {
              "s": "Fetches the code item from IndexedDB"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Wraps code with "
            },
            [
              ":code",
              {
                "s": "\"use strict\""
              }
            ],
            {
              "s": " and "
            },
            [
              ":code",
              {
                "s": "//# sourceURL"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Creates a Blob URL"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Uses "
            },
            [
              ":code",
              {
                "s": "import()"
              }
            ],
            {
              "s": " for native ES module evaluation"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Caches the result"
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "This is how the kernel loads itself and all other code."
        }
      ],
      [
        ":h2",
        {
          "s": "Why This Architecture?"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Problem"
              }
            ],
            [
              ":th",
              {
                "s": "Solution"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              {
                "s": "Monolithic kernel can't be linked to"
              }
            ],
            [
              ":td",
              {
                "s": "Decompose into items"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Kernel can't modify itself"
              }
            ],
            [
              ":td",
              {
                "s": "Load from storage, not source file"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Broken code crashes everything"
              }
            ],
            [
              ":td",
              {
                "s": "Safe mode bypasses user code"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Can't nest Hobson instances"
              }
            ],
            [
              ":td",
              {
                "s": "ID prefixing isolates storage"
              }
            ]
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Nested Instances"
        }
      ],
      [
        ":p",
        {
          "s": "Hobson can run inside itself:"
        }
      ],
      [
        ":code-block",
        {
          "s": "?instance=abc      → items stored as \"abc:item-id\"\n?instance=abc:def  → items stored as \"abc:def:item-id\""
        }
      ],
      [
        ":p",
        {
          "s": "Each nested instance gets isolated storage sharing the same IndexedDB."
        }
      ],
      [
        ":h2",
        {
          "s": "Design Rationale"
        }
      ],
      [
        ":h3",
        {
          "s": "Why Two Parts?"
        }
      ],
      [
        ":p",
        {
          "s": "The bootloader is the one file that never changes after deployment. Everything else (kernel, views, libraries) lives in IndexedDB and can be modified from within. This separation enables:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Self-modification"
              }
            ],
            {
              "s": " — kernel can be edited from within Hobson"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Self-hosting"
              }
            ],
            {
              "s": " — Hobson instances can run within Hobson"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Self-documentation"
              }
            ],
            {
              "s": " — kernel code is linkable from documentation"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Theoretical completeness"
              }
            ],
            {
              "s": " — the system defines itself in terms of itself"
            }
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "Why "
        },
        [
          ":code",
          {
            "s": "require()"
          }
        ],
        {
          "s": " via Blob URLs?"
        }
      ],
      [
        ":p",
        {
          "s": "There's no module resolution system (no CDN, no node_modules). Code lives in IndexedDB. The bootloader creates a "
        },
        [
          ":code",
          {
            "s": "require()"
          }
        ],
        {
          "s": " that loads code from storage, wraps it as a blob URL, and uses native "
        },
        [
          ":code",
          {
            "s": "import()"
          }
        ],
        {
          "s": ". This gives standard ES module semantics without a network."
        }
      ],
      [
        ":h3",
        {
          "s": "Why Self-Healing Bootstrap?"
        }
      ],
      [
        ":p",
        {
          "s": "Seed items are verified on every boot. Missing seeds are recreated in dependency order. This means the system recovers from accidental deletions without user intervention, while preserving user modifications to existing seeds."
        }
      ],
      [
