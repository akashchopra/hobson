      [
        ":h2",
        {
          "s": "Editable Mode"
        }
      ],
      [
        ":p",
        {
          "s": "In editable mode, call "
        },
        [
          ":code",
          {
            "s": "options.onChange(newValue)"
          }
        ],
        {
          "s": " to persist changes:"
        }
      ],
      [
        ":code-block",
        {
          "s": "export async function render(value, options, api) {\n  const { label, mode, onChange } = options;\n  \n  if (mode === 'editable') {\n    const input = api.createElement('input', { \n      type: 'text', \n      value: value || '' \n    });\n    input.onblur = () => onChange(input.value);\n    return input;\n  } else {\n    const span = api.createElement('span');\n    span.textContent = value || '';\n    return span;\n  }\n}"
        }
      ],
      [
        ":h2",
        {
          "s": "Creating a Custom Field-View"
        }
      ],
      [
        ":code-block",
        {
          "s": "{\n  id: crypto.randomUUID(),\n  name: \"field-view-color-picker\",\n  type: \"cccccccc-0000-0000-0000-000000000000\",  // field-view\n  content: {\n    description: \"Color picker for hex color values\",\n    code: `\n      export async function render(value, options, api) {\n        const { label, mode, onChange } = options;\n        const wrapper = api.createElement('div');\n        \n        if (label) {\n          const labelEl = api.createElement('label');\n          labelEl.textContent = label;\n          wrapper.appendChild(labelEl);\n        }\n        \n        if (mode === 'editable') {\n          const input = api.createElement('input', { type: 'color' });\n          input.value = value || '#000000';\n          input.onchange = () => onChange(input.value);\n          wrapper.appendChild(input);\n        } else {\n          const swatch = api.createElement('div');\n          swatch.style.cssText = \\`\n            width: 24px; height: 24px; \n            background: \\${value || '#000'};\n            border-radius: 4px;\n          \\`;\n          wrapper.appendChild(swatch);\n        }\n        \n        return wrapper;\n      }\n    `\n  }\n}"
        }
      ],
      [
        ":p",
        {
          "s": "Then use in a view-spec:"
        }
      ],
      [
        ":code-block",
        {
          "s": "ui_hints: [\n  { field: \"themeColor\", label: \"Theme\", component: \"color-picker\", mode: \"editable\" }\n]"
        }
      ],
