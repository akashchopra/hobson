  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "A reusable component for rendering individual fields/properties within a "
        },
        [
          ":item-ref",
          {
            "s": "bbbbbbbb-0000-0000-0000-000000000000"
          },
          {
            "s": "view-spec"
          }
        ],
        {
          "s": ". Field-views are the building blocks of declarative views."
        }
      ],
      [
        ":h2",
        {
          "s": "The Render Function"
        }
      ],
      [
        ":p",
        {
          "s": "Field-views export a "
        },
        [
          ":code",
          {
            "s": "render"
          }
        ],
        {
          "s": " function with a different signature than item views:"
        }
      ],
      [
        ":code-block",
        {
          "s": "export async function render(value, options, api) {\n  // value: the field's current value\n  // options: { label, mode, onChange, field, item, ... }\n  // api: the renderer API\n  \n  const wrapper = api.createElement('div', { className: 'my-field' });\n  // ... build UI ...\n  return wrapper;\n}"
        }
      ],
