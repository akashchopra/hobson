{
  "id": "c0c0c0c0-0035-0000-0000-000000000000",
  "name": "Transclusion",
  "type": "871ae771-b9b1-4f40-8c7f-d9038bfb69c3",
  "created": 1770600000000,
  "modified": 1773243817563,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Transclusion embeds content from one item into another inline, without duplicating it. This is Hobson's primary composition mechanism — documentation, dashboards, and live views are all built by transcluding items into markdown."
        }
      ],
      [
        ":p",
        {
          "s": "Implemented by "
        },
        [
          ":item-ref",
          {
            "s": "a1b2c3d4-5e6f-7a8b-9c0d-e1f2a3b4c5d6"
          },
          {
            "s": "hobson-markdown"
          }
        ],
        {
          "s": ". Inserted via the toolbar in "
        },
        [
          ":item-ref",
          {
            "s": "56f77a00-baf5-43cc-9dc4-8ad0c66f1e8f"
          },
          {
            "s": "field-view-markdown-editable"
          }
        ],
        {
          "s": "."
        }
      ],
      [
        ":h2",
        {
          "s": "Syntax"
        }
      ],
      [
        ":p",
        {
          "s": "Transclusion uses markdown image syntax with "
        },
        [
          ":code",
          {
            "s": "item://"
          }
        ],
        {
          "s": " URLs:"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Syntax"
              }
            ],
            [
              ":th",
              {
                "s": "Effect"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "![](item://id)"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Full item transclusion"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "![](item://id#description)"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Specific field"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "![](item://id#code?region=name)"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Named region"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "![](item://id#code?lines=10-20)"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Line range"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "![](item://id?symbol=name)"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Symbol extraction (auto-resolves to code field)"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "![](item://id#description?render=code)"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Override render mode"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "![](item://id?call=fn)"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Functional — call export "
              },
              [
                ":code",
                {
                  "s": "fn"
                }
              ]
            ]
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "Full transclusion renders the entire item using "
        },
        [
          ":code",
          {
            "s": "api.renderItem()"
          }
        ],
        {
          "s": ". Partial transclusion extracts a specific field, region, symbol, or line range and renders it inline."
        }
      ],
      [
        ":h2",
        {
          "s": "Render Modes"
        }
      ],
      [
        ":p",
        [
          ":code",
          {
            "s": "?render=markdown"
          }
        ],
        {
          "s": " or "
        },
        [
          ":code",
          {
            "s": "?render=code"
          }
        ],
        {
          "s": " controls how the transcluded text is displayed. By default, "
        },
        [
          ":code",
          {
            "s": "description"
          }
        ],
        {
          "s": " fields render as markdown and everything else renders as a code block with line numbers."
        }
      ],
      [
        ":h2",
        {
          "s": "Region Markers"
        }
      ],
      [
        ":p",
        {
          "s": "Named regions in code or markdown enable targeted transclusion without brittle line numbers:"
        }
      ],
      [
        ":code-block",
        {
          "s": "// [BEGIN:myFunction]\nfunction myFunction() { ... }\n// [END:myFunction]"
        }
      ],
      [
        ":p",
        {
          "s": "Reference with "
        },
        [
          ":code",
          {
            "s": "![](item://id#code?region=myFunction)"
          }
        ],
        {
          "s": ". Supported comment styles: "
        },
        [
          ":code",
          {
            "s": "//"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "#"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "<!-- -->"
          }
        ],
        {
          "s": ". In rendered markdown, region markers become invisible anchor spans for scroll-to-region navigation."
        }
      ],
      [
        ":h2",
        {
          "s": "Symbol Resolution"
        }
      ],
      [
        ":p",
        [
          ":code",
          {
            "s": "?symbol=name"
          }
        ],
        {
          "s": " looks up functions and classes in "
        },
        [
          ":code",
          {
            "s": "content._symbols"
          }
        ],
        {
          "s": " (auto-generated metadata). Supports qualified names like "
        },
        [
          ":code",
          {
            "s": "createAPI.get"
          }
        ],
        {
          "s": " and falls back to unqualified matching. The symbol's source lines are extracted and displayed as a code block."
        }
      ],
      [
        ":h2",
        {
          "s": "Functional Transclusion"
        }
      ],
      [
        ":p",
        {
          "s": "Image syntax with "
        },
        [
          ":code",
          {
            "s": "?call="
          }
        ],
        {
          "s": " loads the target item as a module and calls the named export:"
        }
      ],
      [
        ":code-block",
        {
          "s": "![](item://my-lib?call=renderWidget&someParam=value)"
        }
      ],
      [
        ":p",
        {
          "s": "The function receives "
        },
        [
          ":code",
          {
            "s": "(api, params)"
          }
        ],
        {
          "s": " where "
        },
        [
          ":code",
          {
            "s": "params"
          }
        ],
        {
          "s": " is the parsed URL query object (excluding "
        },
        [
          ":code",
          {
            "s": "call"
          }
        ],
        {
          "s": " itself). It can return:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "A "
            },
            [
              ":strong",
              {
                "s": "DOM node"
              }
            ],
            {
              "s": " — embedded directly into the document"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "A "
            },
            [
              ":strong",
              {
                "s": "string"
              }
            ],
            {
              "s": " — rendered as markdown"
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "This powers live, interactive content. The "
        },
        [
          ":item-ref",
          {
            "s": "c0c0c0c0-0034-0000-0000-000000000000"
          },
          {
            "s": "Context Menu"
          }
        ],
        {
          "s": " documentation uses functional transclusion to show the real context menu inline, built from the same code the viewport uses."
        }
      ],
      [
        ":h2",
        {
          "s": "Query Blocks"
        }
      ],
      [
        ":p",
        {
          "s": "Fenced code blocks with language "
        },
        [
          ":code",
          {
            "s": "query"
          }
        ],
        {
          "s": " execute JavaScript at render time:"
        }
      ],
      [
        ":code-block",
        {
          "s": ""
        }
      ],
      [
        ":p",
        {
          "s": "const items = await api.query({ type: noteTypeId }); return items.map(i => "
        },
        [
          ":code",
          {
            "s": "- [${i.name}](item://${i.id})"
          }
        ],
        {
          "s": ").join('\\n');"
        }
      ],
      [
        ":code-block",
        {
          "s": ""
        }
      ],
      [
        ":p",
        {
          "s": "Query code has access to "
        },
        [
          ":code",
          {
            "s": "api"
          }
        ],
        {
          "s": " and two transclusion helpers:"
        }
      ],
      [
        ":h3",
        {
          "s": "transclude(item, text, options)"
        }
      ],
      [
        ":p",
        {
          "s": "Wraps text with attribution chrome linking back to the source item."
        }
      ],
      [
        ":h3",
        {
          "s": "transcludeEach(items, formatter, options)"
        }
      ],
      [
        ":p",
        {
          "s": "Applies "
        },
        [
          ":code",
          {
            "s": "transclude()"
          }
        ],
        {
          "s": " to each item using "
        },
        [
          ":code",
          {
            "s": "formatter(item)"
          }
        ],
        {
          "s": " for the text."
        }
      ],
      [
        ":h3",
        {
          "s": "Chrome Options"
        }
      ],
      [
        ":p",
        {
          "s": "Both helpers accept "
        },
        [
          ":code",
          {
            "s": "{ chrome }"
          }
        ],
        {
          "s": " to control attribution display:"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Chrome"
              }
            ],
            [
              ":th",
              {
                "s": "Effect"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "'full'"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Styled container with header and collapse toggle"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "'subtle'"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Small ↗ link marker (default)"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "'none'"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "No wrapper — content appears as if authored in place"
              }
            ]
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "Query blocks can return a DOM node instead of a string. If the result has a "
        },
        [
          ":code",
          {
            "s": "nodeType"
          }
        ],
        {
          "s": " property, it is inserted directly without markdown processing."
        }
      ],
      [
        ":h2",
        {
          "s": "Visual Appearance"
        }
      ],
      [
        ":p",
        {
          "s": "Transcluded content appears in a collapsible "
        },
        [
          ":code",
          {
            "s": "<details>"
          }
        ],
        {
          "s": " box with:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Light gray background and border"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "\"Transcluded from: [Item Name] ↗\" header"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Clicking the header collapses/expands; clicking ↗ navigates to the source"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Transclusion vs Attachments"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Aspect"
              }
            ],
            [
              ":th",
              {
                "s": "Transclusion"
              }
            ],
            [
              ":th",
              [
                ":item-ref",
                {
                  "s": "c0c0c0c0-0005-0000-0000-000000000000"
                },
                {
                  "s": "Attachments"
                }
              ]
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              {
                "s": "Syntax"
              }
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "![](item://id)"
                }
              ],
              {
                "s": " in markdown"
              }
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "attachments"
                }
              ],
              {
                "s": " array in item"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Display"
              }
            ],
            [
              ":td",
              {
                "s": "Inline within text flow"
              }
            ],
            [
              ":td",
              {
                "s": "As positioned windows"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Relationship"
              }
            ],
            [
              ":td",
              {
                "s": "Implicit via content"
              }
            ],
            [
              ":td",
              {
                "s": "Explicit in structure"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Use case"
              }
            ],
            [
              ":td",
              {
                "s": "Documentation, composition"
              }
            ],
            [
              ":td",
              {
                "s": "Spatial organization"
              }
            ]
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "An item can be both transcluded and attached — these are orthogonal relationships."
        }
      ],
      [
        ":h2",
        {
          "s": "See Also"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "a1b2c3d4-5e6f-7a8b-9c0d-e1f2a3b4c5d6"
              },
              {
                "s": "hobson-markdown"
              }
            ],
            {
              "s": " — The library that implements transclusion rendering"
            }
          ]
        ],
        [
          ":li",
          [
