              },
              {
                "s": "Navigation"
              }
            ],
            {
              "s": " — Link behavior and the "
            },
            [
              ":code",
              {
                "s": "item://"
              }
            ],
            {
              "s": " URL scheme"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "c0c0c0c0-0005-0000-0000-000000000000"
              },
              {
                "s": "Attachments"
              }
            ],
            {
              "s": " — Structural parent-child relationships"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "c0c0c0c0-0034-0000-0000-000000000000"
              },
              {
                "s": "Context Menu"
              }
            ],
            {
              "s": " — Uses functional transclusion for live documentation"
            }
          ]
        ]
      ]
    ],
    "tags": [
      "bff75873-edb8-412e-81c9-c744e68fe29f",
