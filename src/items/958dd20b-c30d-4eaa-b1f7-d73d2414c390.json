  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Field editor for single-line text using HTML text input. The default field editor used by "
        },
        [
          ":item-ref",
          {
            "s": "ffd688d1-93a8-4c4b-b09a-127b249294f5"
          },
          {
            "s": "generic-editor"
          }
        ],
        {
          "s": " when no specific editor is specified, or with "
        },
        [
          ":code",
          {
            "s": "editor: 'text'"
          }
        ],
        {
          "s": "."
        }
      ],
      [
        ":h2",
        {
          "s": "Options"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "placeholder"
              }
            ],
            {
              "s": ": Placeholder text when empty"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "readonly"
              }
            ],
            {
              "s": ": Makes input non-editable"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Fallback Behavior"
        }
      ],
      [
        ":p",
        {
          "s": "When the generic editor encounters an unknown editor type, it falls back to this text editor."
        }
      ]
    ],
    "code": "\nexport function render(value, onChange, api, options = {}) {\n  const input = api.createElement('input', {}, []);\n  input.type = 'text';\n  input.value = value || '';\n  input.placeholder = options.placeholder || '';\n  input.style.cssText = 'width: 100%; padding: 8px; border: 1px solid var(--color-border); border-radius: var(--border-radius); font-size: 0.875rem;';\n\n  if (options.readonly) {\n    input.readOnly = true;\n    input.style.background = 'var(--color-bg-body)';\n  }\n\n  input.addEventListener('input', (e) => {\n    onChange(e.target.value);\n  });\n\n  return input;\n}\n",
