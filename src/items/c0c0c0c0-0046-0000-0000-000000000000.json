  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Visual network graph of item relationships."
        }
      ],
      [
        ":h2",
        {
          "s": "Concept"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Nodes represent items"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Edges represent relationships (attachments, "
            },
            [
              ":code",
              {
                "s": "item://"
              }
            ],
            {
              "s": " links, type references, tag associations)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Interactive: click nodes to navigate, drag to rearrange"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Filterable by type, tag, or relationship kind"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Libraries to Consider"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "D3.js force-directed graph"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Cytoscape.js"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Vis.js network"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Implementation Notes"
        }
      ],
      [
        ":p",
        {
          "s": "Could be built as a view item — a new view type that renders a container's contents (or query results) as a force-directed graph rather than a spatial canvas or list."
        }
      ],
      [
        ":h2",
        {
          "s": "Design Questions"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Is graph view useful for personal information, or just visually appealing but not practical?"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "What insights would it provide that search/tags don't?"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "How to handle large graphs (hundreds of items)? Clustering? Progressive loading?"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Priority"
        }
      ],
      [
        ":p",
        {
          "s": "Low — interesting visualization but unclear practical value for personal use. The "
        },
        [
          ":item-ref",
          {
            "s": "ef793c27-2d4b-4c99-b05a-2769db5bc5a9"
          },
          {
            "s": "Spatial Windowing"
          }
        ],
        {
          "s": " system already provides a spatial view of items."
        }
      ]
    ],
