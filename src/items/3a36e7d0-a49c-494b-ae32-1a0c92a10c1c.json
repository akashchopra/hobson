      [
        ":p",
        {
          "s": "A multi-pane hierarchical browser for navigating the Hobson item system by structure. Inspired by Smalltalk's System Browser, it lets users drill down through organizational axes (Types, Tags, Views, Libraries) to discover what exists in the system."
        }
      ],
