            ":p",
            [
              ":code",
              {
                "s": "api.rerenderItem(id)"
              }
            ],
            {
              "s": " — Re-render in place"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "api.createElement(tag, attrs, children)"
              }
            ],
            {
              "s": " — Create DOM elements"
            }
