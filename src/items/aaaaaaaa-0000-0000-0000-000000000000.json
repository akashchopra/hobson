      [
        ":h2",
        {
          "s": "View Discovery"
        }
      ],
      [
        ":p",
        {
          "s": "When the system needs to render an item, it resolves the view through a preference hierarchy:"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Explicit"
              }
            ],
            {
              "s": ": View ID passed to "
            },
            [
              ":code",
              {
                "s": "api.renderItem(itemId, viewId)"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Contextual"
              }
            ],
            {
              "s": ": Parent's child spec has "
            },
            [
              ":code",
              {
                "s": "view.type"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Item preference"
              }
            ],
            {
              "s": ": Item's "
            },
            [
              ":code",
              {
                "s": "preferredView"
              }
            ],
            {
              "s": " field"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Type preference"
              }
            ],
            {
              "s": ": Type definition's "
            },
            [
              ":code",
              {
                "s": "preferredView"
              }
            ],
            {
              "s": " field"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Type chain walk"
              }
            ],
            {
              "s": ": Find view with matching "
            },
            [
              ":code",
              {
                "s": "for_type"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Fallback"
              }
            ],
            {
              "s": ": "
            },
            [
              ":item-ref",
              {
                "s": "aaaaaaaa-1111-0000-0000-000000000000"
              },
              {
                "s": "kernel:default-view"
              }
            ],
            {
              "s": " (JSON inspector)"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "The Renderer API"
        }
      ],
      [
        ":p",
        {
          "s": "The "
        },
        [
          ":code",
          {
            "s": "api"
          }
        ],
        {
          "s": " parameter provides:"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Storage:"
          }
        ]
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "api.get(id)"
              }
            ],
            {
              "s": " — Fetch an item"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "api.set(item)"
              }
            ],
            {
              "s": " — Save an item"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "api.query(filter)"
              }
            ],
            {
              "s": " — Search items"
            }
          ]
        ]
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Rendering:"
          }
        ]
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "api.renderItem(id, viewId?)"
              }
