        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "api.require(name)"
              }
            ],
            {
              "s": " — Load libraries"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "api.viewport"
              }
            ],
            {
              "s": " — Current viewport state"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Creating a View"
        }
      ],
      [
        ":code-block",
        {
          "s": "{\n  id: crypto.randomUUID(),\n  name: \"my-note-view\",\n  type: \"aaaaaaaa-0000-0000-0000-000000000000\",  // kernel:view\n  content: {\n    for_type: \"note-type-uuid\",\n    displayName: \"Note View\",\n    description: \"Renders notes with markdown formatting\",\n    code: `\n      export async function render(item, api) {\n        const md = await api.require('hobson-markdown');\n        return md.render(item.content.description || '', api);\n      }\n    `\n  }\n}"
        }
      ],
      [
