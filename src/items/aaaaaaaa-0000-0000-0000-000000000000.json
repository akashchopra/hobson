    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Code that transforms an item into a visual DOM representation. Views are how items become visible and interactive."
        }
      ],
      [
        ":h2",
        {
          "s": "The Render Function"
        }
      ],
      [
        ":p",
        {
          "s": "Every view exports a "
        },
        [
          ":code",
          {
            "s": "render"
          }
        ],
        {
          "s": " function:"
        }
      ],
      [
        ":p",
        {
          "s": "!"
        },
        [
          ":item-ref",
          {
            "s": "605bd4ee-21c3-4dbc-b1b1-21d96ffa09a0#code"
          },
          {
            "s": "example-view"
          }
        ]
      ],
