{
  "id": "602cd3c2-333b-43fd-94f4-9ab08eeb2ca8",
  "name": "binary-asset",
  "type": "11111111-0000-0000-0000-000000000000",
  "extends": "00000000-0000-0000-0000-000000000000",
  "created": 1775982759472,
  "modified": 1775996877505,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Marker type for items whose primary content is binary data stored in the blob store, keyed by item ID. The item JSON contains only metadata — the binary data lives separately."
        }
      ],
      [
        ":h2",
        {
          "s": "Blob Storage"
        }
      ],
      [
        ":p",
        {
          "s": "Binary data is stored in the IDB "
        },
        [
          ":code",
          {
            "s": "blobs"
          }
        ],
        {
          "s": " object store, keyed by the item's ID. The item JSON never contains raw bytes. Access via "
        },
        [
          ":code",
          {
            "s": "api.getBlob(id)"
          }
        ],
        {
          "s": " and "
        },
        [
          ":code",
          {
            "s": "api.setBlob(id, blob)"
          }
        ],
        {
          "s": "."
        }
      ],
      [
        ":h2",
        {
          "s": "Export / Import"
        }
      ],
      [
        ":p",
        {
          "s": "During export ("
        },
        [
          ":code",
          {
            "s": "api.export"
          }
        ],
        {
          "s": ") and file-sync mirror mode, the blob is serialized as a "
        },
        [
          ":code",
          {
            "s": "_blob"
          }
        ],
        {
          "s": " data URL field in the exported JSON. On import, "
        },
        [
          ":code",
          {
            "s": "_blob"
          }
        ],
        {
          "s": " is extracted, written to the blob store, and stripped from the item before storage."
        }
      ],
      [
        ":h2",
        {
          "s": "Required Fields"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Field"
              }
            ],
            [
              ":th",
              {
                "s": "Description"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "mimeType"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "MIME type of the binary data, e.g. \"image/png\""
              }
            ]
          ]
        ]
      ]
    ],
    "required_fields": [
      "mimeType"
    ]
  },
