    "code": "(defn render [item api]\n  (let [it item\n        name (or (:name it) (subs (:id it) 0 8))\n        raw-desc (or (get-in it [:content :description]) \"\")\n        preview (if (string? raw-desc) raw-desc (extract-text raw-desc))\n        type-item (get-item (:type it))\n        tag-ids (or (get-in it [:content :tags]) [])]\n    [:div.compact-card {:style \"padding: 12px; margin-bottom: 8px; background: var(--color-bg-surface); border: 1px solid var(--color-border-light); border-radius: var(--border-radius); cursor: pointer; transition: all 0.2s;\"\n                        :on-click (fn [e] (open-item! e (:id it)))}\n      [:div {:style \"font-weight: 500; color: var(--color-text); margin-bottom: 6px; overflow: hidden;\"}\n  \n        name]\n      (when\n        (seq preview)\n        [:div {:style \"font-size: 0.8125rem; color: var(--color-text-secondary); margin-bottom: 6px; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;\"}\n  \n          (if (> (count preview) 200) (subs preview 0 200) preview)])\n      [:div {:style \"display: flex; flex-wrap: wrap; align-items: center; gap: 6px; font-size: 0.75rem; color: var(--color-border-dark);\"}\n  \n        [:span (str \"Type: \" (:name type-item))]\n        (for [tag-id tag-ids]\n          (let [tag (get-item tag-id)\n                color (or (get-in tag [:content :color]) \"var(--color-primary)\")\n                tag-name (or\n                           (get-in tag [:content :name])\n                           (:name tag)\n                           (subs (:id tag) 0 8))]\n            [:span {:style (str\n                             \"display: inline-flex; align-items: center; gap: 3px; padding: 1px 6px; border-radius: 8px; font-size: 0.625rem; cursor: pointer; color: \"\n                             color\n                             \"; background: \"\n                             color\n                             \"20; border: 1px solid \"\n                             color\n                             \"40;\")\n                    :on-click (fn [e] (open-item! e (:id tag)))}\n              [:span {:style (str\n                               \"width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; background: \"\n                               color\n                               \";\")}\n  ]\n              [:span tag-name]]))]]))\n",
