    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Renders items as clickable cards suitable for lists and grids. Shows title, truncated preview text, type metadata, and compact tag pills."
        }
      ],
      [
        ":h2",
        {
          "s": "Features "
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Title from `item.name`"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "2-line preview from `item.content.description`"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Type name and compact tag pills in footer"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Hover animation (subtle slide and border color)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Click opens item via `open-item!` (supports Ctrl/Cmd+Click for new tab, Alt+Click for root)"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Use Cases"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Search results"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Tag browser listings"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Compact item indexes"
            }
          ]
        ]
      ]
