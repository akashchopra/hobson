        ":p",
        {
          "s": "Helper library for flash-card-deck-view. Provides field path resolution and value type detection."
        }
      ]
    ],
    "code": "const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;\n\nexport function resolveField(item, path) {\n  const parts = path.split('.');\n  let val = item;\n  for (const part of parts) {\n    if (val == null) return null;\n    val = val[part];\n  }\n  return val ?? null;\n}\n\nexport function isUuid(val) {\n  return typeof val === 'string' && UUID_RE.test(val);\n}\n\n",
