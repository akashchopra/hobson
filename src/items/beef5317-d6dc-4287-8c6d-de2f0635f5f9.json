  "name": "field-editor-number",
  "type": "66666666-0000-0000-0000-000000000000",
  "created": 1768550742282,
  "modified": 1775756670153,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Field editor for numeric values using HTML number input. Used by "
        },
        [
          ":item-ref",
          {
            "s": "ffd688d1-93a8-4c4b-b09a-127b249294f5"
          },
          {
            "s": "generic-editor"
          }
        ],
        {
          "s": " for fields with "
        },
        [
          ":code",
          {
            "s": "editor: 'number'"
          }
        ],
        {
          "s": "."
        }
      ],
      [
        ":h2",
        {
          "s": "Options"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "min"
              }
            ],
            {
              "s": ": Minimum allowed value"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "max"
              }
            ],
            {
              "s": ": Maximum allowed value"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "step"
              }
            ],
            {
              "s": ": Increment step (e.g., "
            },
            [
              ":code",
              {
                "s": "0.1"
              }
            ],
            {
              "s": " for decimals)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "readonly"
              }
            ],
            {
              "s": ": Makes input non-editable"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Value Handling"
        }
      ],
      [
        ":p",
        {
          "s": "Empty input returns "
        },
        [
          ":code",
          {
            "s": "null"
          }
        ],
        {
          "s": ", otherwise returns parsed "
        },
        [
          ":code",
          {
            "s": "Number"
          }
        ],
        {
          "s": "."
        }
      ]
    ],
    "code": "\nexport function render(value, onChange, api, options = {}) {\n  const props = {\n    type: 'number',\n    value: value ?? '',\n    style: 'width: 100%; padding: 8px; border: 1px solid var(--color-border); border-radius: var(--border-radius); font-size: 0.875rem;' +\n           (options.readonly ? ' background: var(--color-bg-body);' : ''),\n    oninput: (e) => {\n      const val = e.target.value === '' ? null : Number(e.target.value);\n      onChange(val);\n    }\n  };\n\n  if (options.min !== undefined) props.min = options.min;\n  if (options.max !== undefined) props.max = options.max;\n  if (options.step !== undefined) props.step = options.step;\n  if (options.readonly) props.readonly = true;\n\n  return api.createElement('input', props);\n}\n",
