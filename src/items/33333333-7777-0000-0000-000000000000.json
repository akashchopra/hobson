  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Safe mode is a recovery environment that boots the kernel without executing user code items. Use it when broken code prevents normal operation."
        }
      ],
      [
        ":h2",
        {
          "s": "When to Use Safe Mode"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "A view crashes and you can't navigate away"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "A library has a syntax error and breaks loading"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "An event handler creates an infinite loop"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "You need to edit code without it executing"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Entering Safe Mode"
        }
      ],
      [
        ":h3",
        {
          "s": "Method 1: URL Parameter"
        }
      ],
      [
        ":p",
        {
          "s": "Add "
        },
        [
          ":code",
          {
            "s": "?safe=1"
          }
        ],
        {
          "s": " to the URL:"
        }
      ],
      [
        ":code-block",
        {
          "s": "https://hobson.app/?safe=1\nhttps://hobson.app/?safe=1#item-uuid"
        }
      ],
      [
        ":h3",
        {
          "s": "Method 2: Keyboard Shortcut"
        }
      ],
      [
        ":p",
        {
          "s": "Press "
        },
        [
          ":code",
          {
            "s": "Ctrl+Shift+S"
          }
        ],
        {
          "s": " from anywhere (if the system is responsive)."
        }
      ],
      [
        ":h3",
        {
          "s": "Method 3: Console"
        }
      ],
      [
        ":p",
        {
          "s": "In browser DevTools console:"
        }
      ],
      [
        ":code-block",
        {
          "s": "location.search = '?safe=1';"
