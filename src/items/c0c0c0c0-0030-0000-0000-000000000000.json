{
  "id": "c0c0c0c0-0030-0000-0000-000000000000",
  "name": "Project Context",
  "type": "871ae771-b9b1-4f40-8c7f-d9038bfb69c3",
  "created": 1738454400000,
  "modified": 1775756671101,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Working context for Claude (and future collaborators) when contributing to Hobson. This item replaces the previous "
        },
        [
          ":code",
          {
            "s": "docs/PROJECT_MEMORY.md"
          }
        ],
        {
          "s": " file."
        }
      ],
      [
        ":h2",
        {
          "s": "User Preferences"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Critique first, implement second"
              }
            ],
            {
              "s": " — discuss trade-offs before writing code"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Minimal kernel philosophy"
              }
            ],
            {
              "s": " — bootstrap small, build everything else in the system"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Challenge assumptions"
              }
            ],
            {
              "s": " — direct and questioning approach preferred"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Practical focus"
              }
            ],
            {
              "s": " — working software over perfect architecture"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Project Goals"
        }
      ],
      [
        ":p",
        {
          "s": "Hobson is a personal information management system where everything (data, code, UI) is an item. The system should increasingly define itself in terms of itself."
        }
      ],
      [
        ":h3",
        {
          "s": "Immediate Goals"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "All documentation lives in items (this migration)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Views and libraries are well-described"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "New features are buildable entirely within the system"
            }
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "Long-Term Vision"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "REPL-first workflow with optional UI"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Self-hosting (Hobson-in-Hobson)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Personal knowledge graph with spatial organization"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Known Friction Points"
        }
      ],
      [
        ":h3",
        {
          "s": "Code Item Creation"
        }
      ],
      [
        ":p",
        {
          "s": "Creating code items via the REPL requires multi-level string escaping. "
        },
        [
          ":strong",
          {
            "s": "Workaround:"
          }
        ],
        {
          "s": " Edit JSON files directly in "
        },
        [
          ":code",
          {
            "s": "src/items/*.json"
          }
        ],
        {
          "s": " and import. This is the preferred workflow for Claude."
        }
      ],
      [
        ":h3",
        {
          "s": "Item Discovery"
        }
      ],
      [
        ":p",
        {
          "s": "Finding previously created items can be difficult. The Cmd+K item palette helps but isn't perfect for large item counts. Tagging and spatial organization are the primary mitigation strategies."
        }
      ],
      [
        ":h3",
        {
          "s": "Module-Level State"
        }
      ],
      [
        ":p",
        {
          "s": "Libraries that cache state at module scope break on hot-reload. See "
        },
        [
          ":item-ref",
          {
            "s": "c0c0c0c0-0015-0000-0000-000000000000"
          },
          {
            "s": "Module Cache Invalidation"
          }
        ],
        {
          "s": " for the open problem and workarounds."
        }
      ],
      [
        ":h2",
        {
          "s": "Open Design Tension"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "REPL-first vs UI-first"
          }
        ],
        {
          "s": " remains unresolved:"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Approach"
              }
            ],
            [
              ":th",
              {
                "s": "Strength"
              }
            ],
            [
              ":th",
              {
                "s": "Weakness"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              [
                ":strong",
                {
                  "s": "REPL-first"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Code is primary, UI is secondary"
              }
            ],
            [
              ":td",
              {
                "s": "Requires comfort with JavaScript"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":strong",
                {
                  "s": "UI-first"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Visual navigation is primary, code extends it"
              }
            ],
            [
              ":td",
              {
                "s": "May limit power users"
              }
            ]
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "Current state: Both coexist. The REPL provides full API access. The UI provides visual navigation and spatial organization. Neither is privileged over the other."
        }
      ],
      [
        ":h2",
        {
          "s": "Working Rules for Claude"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Always confirm `src/items` has latest versions"
              }
            ],
            {
              "s": " before editing"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Edit JSON files directly"
              }
            ],
            {
              "s": " — don't write REPL scripts unless specifically needed"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Place REPL scripts in `src/REPL Scripts`"
              }
            ],
            {
              "s": " if they're needed"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Use the c0c0c0c0-XXXX pattern"
              }
            ],
            {
              "s": " for documentation item GUIDs"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Follow existing naming conventions"
              }
            ],
            {
              "s": " — kebab-case for code items, prose for non-code items"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "See Also"
        }
      ],
      [
