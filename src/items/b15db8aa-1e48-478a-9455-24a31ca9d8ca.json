    "code": "(let [event item\n      content (or (:content event) {})\n      type-item (get-item (:type event))\n      category-name (or (:name type-item) \"\")\n      badge-bg (cond\n                 (str/includes? category-name \"system\")\n                 \"var(--color-warning-light)\"\n                 (str/includes? category-name \"item\")\n                 \"var(--color-primary-light)\"\n                 (str/includes? category-name \"viewport\")\n                 \"var(--color-success-light)\"\n                 :else\n                 \"var(--color-bg-surface-alt)\")\n      badge-fg (cond\n                 (str/includes? category-name \"system\")\n                 \"var(--color-warning)\"\n                 (str/includes? category-name \"item\")\n                 \"var(--color-primary)\"\n                 (str/includes? category-name \"viewport\")\n                 \"var(--color-success)\"\n                 :else\n                 \"var(--color-text-secondary)\")\n      description (or (:description content) \"\")\n      payload (or (:payload content) {})\n      payload-keys (keys payload)\n      params (if\n               (seq payload-keys)\n               (str \"{ \" (str/join \", \" payload-keys) \" }\")\n               nil)\n      snippet (str\n                \"api.events.on('\"\n                (:id event)\n                \"', (event) => {\\n\"\n                (if params (str \"  const \" params \" = event.content;\\n\") \"\")\n                \"  // ...\\n\"\n                \"});\")]\n  [:div.event-definition-view {:style \"display: flex; flex-direction: column; gap: 16px; padding: 20px; height: 100%; overflow-y: auto;\"}\n\n    [:div {:style \"display: flex; align-items: center; gap: 12px; flex-wrap: wrap;\"}\n\n      [:h2 {:style \"margin: 0; font-family: var(--font-mono, monospace); font-size: 1.25rem; color: var(--color-text);\"}\n\n        (or (:name event) \"Unnamed Event\")]\n      (when\n        (seq category-name)\n        [:span {:style (str\n                         \"font-size: 0.75rem; padding: 2px 10px; border-radius: 10px; background: \"\n                         badge-bg\n                         \"; color: \"\n                         badge-fg\n                         \"; white-space: nowrap;\")}\n\n          category-name])]\n    (when\n      (seq description)\n      [:div {:style \"line-height: 1.5;\"}\n        (if (and (sequential? description) (= (first description) \":doc\"))\n          (for [node (rest description)] node)\n          (render-markdown description))])\n    (when\n      (seq payload-keys)\n      [:div {:style \"display: flex; flex-direction: column; gap: 8px;\"}\n        [:h3 {:style \"margin: 0; font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--color-text-secondary);\"}\n\n          \"Payload\"]\n        [:div {:style \"border: 1px solid var(--color-border-light); border-radius: var(--border-radius); overflow: hidden;\"}\n\n          (for [entry (seq payload)]\n            (let [k (first entry) v (nth entry 1)]\n              (if\n                (map? v)\n                (vec\n                  (concat\n                    [[:div {:style \"display: flex; align-items: baseline; padding: 8px 12px; border-bottom: 1px solid var(--color-border-light);\"}\n\n                        [:code {:style \"font-size: 0.8125rem; color: var(--color-primary); flex-shrink: 0; min-width: 100px;\"}\n\n                          k]\n                        [:span {:style \"font-size: 0.75rem; color: var(--color-text-tertiary); margin-left: 8px;\"}\n\n                          \"{...}\"]]\n]\n                    (for [nentry (seq v)]\n                      [:div {:style \"display: flex; align-items: baseline; padding: 8px 12px; padding-left: 32px; border-bottom: 1px solid var(--color-border-light);\"}\n\n                        [:code {:style \"font-size: 0.8125rem; color: var(--color-primary); flex-shrink: 0; min-width: 100px;\"}\n\n                          (first nentry)]\n                        [:span {:style \"font-size: 0.8125rem; color: var(--color-text-secondary); margin-left: 12px;\"}\n\n                          (str (nth nentry 1))]])))\n                [:div {:style \"display: flex; align-items: baseline; padding: 8px 12px; border-bottom: 1px solid var(--color-border-light);\"}\n\n                  [:code {:style \"font-size: 0.8125rem; color: var(--color-primary); flex-shrink: 0; min-width: 100px;\"}\n\n                    k]\n                  [:span {:style \"font-size: 0.8125rem; color: var(--color-text-secondary); margin-left: 12px;\"}\n\n                    (str v)]])))]])\n    [:div {:style \"display: flex; flex-direction: column; gap: 8px;\"}\n      [:h3 {:style \"margin: 0; font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--color-text-secondary);\"}\n\n        \"Usage\"]\n      [:pre {:style \"margin: 0; padding: 12px; background: var(--color-bg-body); border: 1px solid var(--color-border-light); border-radius: var(--border-radius); overflow-x: auto; font-size: 0.8125rem; line-height: 1.4; position: relative;\"}\n\n        [:code snippet]\n        [:button {:style \"position: absolute; top: 6px; right: 6px; padding: 2px 8px; font-size: 0.6875rem; background: var(--color-bg-surface); border: 1px solid var(--color-border-light); border-radius: var(--border-radius); cursor: pointer; color: var(--color-text-secondary);\"\n                  :on-click (fn [e] (copy-to-clipboard! snippet))}\n          \"Copy\"]]]])"
  },
