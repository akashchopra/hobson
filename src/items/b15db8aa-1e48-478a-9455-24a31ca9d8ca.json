    "code": "(defn render [item api]\n  (def event item)\n  (def content (or (:content event) {}))\n  (def type-item (get-item (:type event)))\n  (def category-name (or (:name type-item) \"\"))\n  (def badge-bg\n    (cond (str/includes? category-name \"system\")\n      \"var(--color-warning-light)\"\n      (str/includes? category-name \"item\")\n      \"var(--color-primary-light)\"\n      (str/includes? category-name \"viewport\")\n      \"var(--color-success-light)\"\n      :else\n      \"var(--color-bg-surface-alt)\"))\n  (def badge-fg\n    (cond (str/includes? category-name \"system\")\n      \"var(--color-warning)\"\n      (str/includes? category-name \"item\")\n      \"var(--color-primary)\"\n      (str/includes? category-name \"viewport\")\n      \"var(--color-success)\"\n      :else\n      \"var(--color-text-secondary)\"))\n  (def description (or (:description content) \"\"))\n  (def payload (or (:payload content) {}))\n  (def payload-keys (keys payload))\n  (def params (if (seq payload-keys) (str \"{ \" (str/join \", \" payload-keys) \" }\") nil))\n  (def snippet\n    (str \"api.events.on('\"\n      (:id event)\n      \"', (event) => {\\n\"\n      (if params (str \"  const \" params \" = event.content;\\n\") \"\")\n      \"  // ...\\n\"\n      \"});\"))\n  [\n    :div.event-definition-view\n    {\n      :style \"display: flex; flex-direction: column; gap: 16px; padding: 20px; height: 100%; overflow-y: auto;\"}\n    [\n      :div\n      {:style \"display: flex; align-items: center; gap: 12px; flex-wrap: wrap;\"}\n      [\n        :h2\n        {\n          :style \"margin: 0; font-family: var(--font-mono, monospace); font-size: 1.25rem; color: var(--color-text);\"}\n        (or (:name event) \"Unnamed Event\")]\n      (when (seq category-name)\n        [\n          :span\n          {\n            :style (str \"font-size: 0.75rem; padding: 2px 10px; border-radius: 10px; background: \"\n              badge-bg\n              \"; color: \"\n              badge-fg\n              \"; white-space: nowrap;\")}\n          category-name])]\n    (when (and (sequential? description) (= (first description) \":doc\"))\n      (let [doc-view (require \"field-view-doc\")]\n        (invoke doc-view \"render\" description {} api)))\n    (when (seq payload-keys)\n      [\n        :div\n        {:style \"display: flex; flex-direction: column; gap: 8px;\"}\n        [\n          :h3\n          {\n            :style \"margin: 0; font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--color-text-secondary);\"}\n          \"Payload\"]\n        [\n          :div\n          {\n            :style \"border: 1px solid var(--color-border-light); border-radius: var(--border-radius); overflow: hidden;\"}\n          (for [entry (seq payload)]\n            (let [k (first entry) v (nth entry 1)]\n              (if (map? v)\n                (vec\n                  (concat\n                    [\n                      [\n                        :div\n                        {\n                          :style \"display: flex; align-items: baseline; padding: 8px 12px; border-bottom: 1px solid var(--color-border-light);\"}\n                        [\n                          :code\n                          {:style \"font-size: 0.8125rem; color: var(--color-primary); flex-shrink: 0; min-width: 100px;\"}\n                          k]\n                        [:span {:style \"font-size: 0.75rem; color: var(--color-text-tertiary); margin-left: 8px;\"} \"{...}\"]]]\n                    (for [nentry (seq v)]\n                      [\n                        :div\n                        {\n                          :style \"display: flex; align-items: baseline; padding: 8px 12px; padding-left: 32px; border-bottom: 1px solid var(--color-border-light);\"}\n                        [\n                          :code\n                          {:style \"font-size: 0.8125rem; color: var(--color-primary); flex-shrink: 0; min-width: 100px;\"}\n                          (first nentry)]\n                        [\n                          :span\n                          {:style \"font-size: 0.8125rem; color: var(--color-text-secondary); margin-left: 12px;\"}\n                          (str (nth nentry 1))]])))\n                [\n                  :div\n                  {\n                    :style \"display: flex; align-items: baseline; padding: 8px 12px; border-bottom: 1px solid var(--color-border-light);\"}\n                  [\n                    :code\n                    {:style \"font-size: 0.8125rem; color: var(--color-primary); flex-shrink: 0; min-width: 100px;\"}\n                    k]\n                  [\n                    :span\n                    {:style \"font-size: 0.8125rem; color: var(--color-text-secondary); margin-left: 12px;\"}\n                    (str v)]])))]])\n    [\n      :div\n      {:style \"display: flex; flex-direction: column; gap: 8px;\"}\n      [\n        :h3\n        {\n          :style \"margin: 0; font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--color-text-secondary);\"}\n        \"Usage\"]\n      [\n        :pre\n        {\n          :style \"margin: 0; padding: 12px; background: var(--color-bg-body); border: 1px solid var(--color-border-light); border-radius: var(--border-radius); overflow-x: auto; font-size: 0.8125rem; line-height: 1.4; position: relative;\"}\n        [:code snippet]\n        [\n          :button\n          {\n            :style \"position: absolute; top: 6px; right: 6px; padding: 2px 8px; font-size: 0.6875rem; background: var(--color-bg-surface); border: 1px solid var(--color-border-light); border-radius: var(--border-radius); cursor: pointer; color: var(--color-text-secondary);\"\n            :on-click (fn [e] (copy-to-clipboard! snippet))}\n          \"Copy\"]]]])\n"
  },
