  "modified": 1774988043709,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "A type definition describes a category of items. Types are themselves items, creating a self-describing system."
        }
      ],
      [
        ":h2",
        {
          "s": "Type Chains"
        }
      ],
      [
        ":p",
        {
          "s": "Every item's "
        },
        [
          ":code",
          {
            "s": "type"
          }
        ],
        {
          "s": " field points to a type item. Type items use "
        },
        [
          ":code",
          {
            "s": "extends"
          }
        ],
        {
          "s": " to form inheritance chains:"
        }
      ],
      [
        ":code-block",
        {
          "s": "my-note → note → kernel:item\nmy-view → kernel:view → kernel:code → kernel:item"
        }
      ],
      [
        ":p",
        {
          "s": "Chains always terminate at "
        },
        [
          ":item-ref",
          {
            "s": "00000000-0000-0000-0000-000000000000"
          },
          {
            "s": "kernel:item"
          }
        ],
        {
          "s": ", which has "
        },
        [
          ":code",
          {
            "s": "extends: null"
          }
        ],
        {
          "s": "."
        }
      ],
      [
        ":p",
        {
          "s": "The kernel validates type chains on every save, rejecting:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Missing type references"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Circular chains"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Chains that don't reach kernel:item"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "The "
        },
        [
          ":code",
          {
            "s": "extends"
          }
        ],
        {
          "s": " Field"
        }
      ],
      [
        ":p",
        {
          "s": "Type definitions use "
        },
        [
          ":code",
          {
            "s": "extends"
          }
        ],
        {
          "s": " to establish inheritance:"
        }
      ],
      [
        ":code-block",
        {
          "s": "{\n  id: \"note-type-uuid\",\n  name: \"note\",\n  type: \"11111111-0000-0000-0000-000000000000\",  // This is a type definition\n  extends: \"00000000-0000-0000-0000-000000000000\", // Extends kernel:item\n  content: {\n    description: \"A markdown note\",\n    required_fields: [\"description\"]\n  }\n}"
        }
      ],
      [
        ":h2",
        {
          "s": "View Dispatch"
        }
      ],
      [
        ":p",
        {
          "s": "When rendering an item, the system walks its type chain looking for a matching "
        },
        [
          ":item-ref",
          {
            "s": "aaaaaaaa-0000-0000-0000-000000000000"
          },
          {
            "s": "view"
          }
        ],
        {
          "s": ":"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            {
              "s": "Check item's "
            },
            [
              ":code",
              {
                "s": "preferredView"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Check type's "
            },
            [
              ":code",
              {
                "s": "preferredView"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Walk the type chain via "
            },
            [
              ":code",
              {
                "s": "extends"
              }
            ],
            {
              "s": ", find view with matching "
            },
            [
              ":code",
              {
                "s": "for_type"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Fall back to default view (JSON inspector)"
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "This means a view for "
        },
        [
          ":code",
          {
            "s": "kernel:item"
          }
        ],
        {
          "s": " works for "
        },
        [
          ":em",
          {
            "s": "all"
          }
        ],
        {
          "s": " items (it's at the root). A view for "
        },
        [
          ":code",
          {
            "s": "note"
          }
        ],
        {
          "s": " only works for notes and subtypes of note."
        }
      ],
      [
        ":h2",
        {
          "s": "Creating a New Type"
        }
      ],
      [
        ":code-block",
        {
          "s": "await api.set({\n  id: crypto.randomUUID(),\n  name: \"my-custom-type\",\n  type: api.IDS.TYPE_DEFINITION,  // \"11111111-0000-0000-0000-000000000000\"\n  extends: api.IDS.ITEM,          // \"00000000-0000-0000-0000-000000000000\"\n  attachments: [],\n  content: {\n    description: \"Describe what this type represents\",\n    required_fields: [\"title\"]  // Optional: hint for editors\n  }\n});"
        }
      ],
      [
        ":p",
        {
          "s": "No restart needed—items of the new type immediately work with existing views."
        }
      ],
      [
