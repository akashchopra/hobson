{
  "id": "c28eeb82-aac7-4bea-9d7b-7d17c1fd73e7",
  "name": "field-editor-select",
  "type": "66666666-0000-0000-0000-000000000000",
  "created": 1768550742282,
  "modified": 1773243817673,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Field editor for selection from predefined choices using HTML select dropdown. Used by "
        },
        [
          ":item-ref",
          {
            "s": "ffd688d1-93a8-4c4b-b09a-127b249294f5"
          },
          {
            "s": "generic-editor"
          }
        ],
        {
          "s": " for fields with "
        },
        [
          ":code",
          {
            "s": "editor: 'select'"
          }
        ],
        {
          "s": "."
        }
      ],
      [
        ":h2",
        {
          "s": "Options"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "choices"
              }
            ],
            {
              "s": ": Array of options, either strings ("
            },
            [
              ":code",
              {
                "s": "['a', 'b']"
              }
            ],
            {
              "s": ") or objects ("
            },
            [
              ":code",
              {
                "s": "[{value: 'a', label: 'Option A'}]"
              }
            ],
            {
              "s": ")"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "readonly"
              }
            ],
            {
              "s": ": Disables the dropdown"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Example ui_hints"
        }
      ],
      [
        ":code-block",
        {
          "s": "ui_hints: {\n  \"content.status\": {\n    editor: \"select\",\n    options: { choices: [\"draft\", \"published\", \"archived\"] }\n  }\n}"
        }
      ]
    ],
    "code": "\nexport function render(value, onChange, api, options = {}) {\n  const select = api.createElement('select', {}, []);\n  select.style.cssText = 'width: 100%; padding: 8px; border: 1px solid var(--color-border); border-radius: var(--border-radius); font-size: 0.875rem; background: var(--color-bg-surface);';\n\n  if (options.readonly) {\n    select.disabled = true;\n    select.style.background = 'var(--color-bg-body)';\n  }\n\n  // options.choices should be [{value, label}] or ['value1', 'value2']\n  const choices = options.choices || [];\n\n  for (const choice of choices) {\n    const opt = api.createElement('option', {}, []);\n    if (typeof choice === 'object') {\n      opt.value = choice.value;\n      opt.textContent = choice.label || choice.value;\n    } else {\n      opt.value = choice;\n      opt.textContent = choice;\n    }\n    if (opt.value === value) {\n      opt.selected = true;\n    }\n    select.appendChild(opt);\n  }\n\n  select.addEventListener('change', (e) => {\n    onChange(e.target.value);\n  });\n\n  return select;\n}\n",
