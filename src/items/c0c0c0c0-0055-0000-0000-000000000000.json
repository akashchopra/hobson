      [
        ":h3",
        {
          "s": "Architecture: Base createElement"
        }
      ],
      [
        ":p",
        [
          ":item-ref",
          {
            "s": "33333333-1111-0000-0000-000000000000"
          },
          {
            "s": "kernel:core"
          }
        ],
        {
          "s": " exposes a generic "
        },
        [
          ":code",
          {
            "s": "_baseCreateElement"
          }
        ],
        {
          "s": " slot in "
        },
        [
          ":code",
          {
            "s": "createAPI()"
          }
        ],
        {
          "s": ". "
        },
        [
          ":item-ref",
          {
            "s": "f1111111-0008-0000-0000-000000000000"
          },
          {
            "s": "viewport-rendering"
          }
        ],
        {
          "s": " fills it during "
        },
        [
          ":code",
          {
            "s": "RenderingSystem"
          }
        ],
        {
          "s": " construction (called by viewport-manager's boot handler), providing a base "
        },
        [
          ":code",
          {
            "s": "createElement"
          }
        ],
        {
          "s": " without debug context. All subsequent "
        },
        [
          ":code",
          {
            "s": "createAPI()"
          }
        ],
        {
          "s": " callers — watch handlers, REPL, etc. — get "
        },
        [
          ":code",
          {
            "s": "api.createElement"
          }
        ],
        {
          "s": ". Per-render "
        },
        [
          ":code",
          {
            "s": "enrichAPI"
          }
        ],
        {
          "s": " overrides it with a debug-attributed version for inspector coverage."
        }
      ],
      [
        ":h3",
        {
          "s": "Remaining: Kernel internals"
        }
      ],
      [
        ":p",
        [
          ":item-ref",
          {
            "s": "33333333-1111-0000-0000-000000000000"
          },
          {
            "s": "kernel:core"
          }
        ],
        {
          "s": " has 24 calls and "
        },
        [
          ":item-ref",
          {
            "s": "f1111111-0008-0000-0000-000000000000"
          },
          {
            "s": "viewport-rendering"
          }
        ],
        {
          "s": " has 5 calls in fallback UIs. These can't use "
        },
        [
          ":code",
          {
            "s": "api.createElement"
          }
        ],
        {
          "s": " (chicken-and-egg)."
        }
      ]
