              }
            ],
            {
              "s": " only"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "css-loader-lib, theme-hot-reload — "
            },
            [
              ":code",
              {
                "s": "<style>"
              }
            ],
            {
              "s": " only"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "kernel-export, extract-js — download "
            },
            [
              ":code",
              {
                "s": "<a>"
              }
            ],
            {
              "s": " only"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "codemirror — third-party"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "bootloader.html — pre-kernel, no "
            },
            [
