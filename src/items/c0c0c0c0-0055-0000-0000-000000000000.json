          }
        ],
        {
          "s": " tags, download links, or third-party code — not meaningful for inspector tracking:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "field-view-code-editable, field-view-markdown-editable, field-view-code-readonly — "
