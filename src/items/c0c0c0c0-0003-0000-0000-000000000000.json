{
  "id": "c0c0c0c0-0003-0000-0000-000000000000",
  "name": "Navigation",
  "type": "871ae771-b9b1-4f40-8c7f-d9038bfb69c3",
  "created": 1738454400000,
  "modified": 1774988060522,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Navigation in Hobson determines which item is displayed and how. The system supports both full-page navigation and opening items as siblings within a container."
        }
      ],
      [
        ":h2",
        {
          "s": "URL Structure"
        }
      ],
      [
        ":p",
        {
          "s": "The URL reflects the current view state:"
        }
      ],
      [
        ":code-block",
        {
          "s": "https://hobson.app/?root=item-uuid\nhttps://hobson.app/?root=item-uuid&view=view-uuid\nhttps://hobson.app/?root=item-uuid&field=code&line=42"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Component"
              }
            ],
            [
              ":th",
              {
                "s": "Meaning"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "?root="
                }
              ]
            ],
            [
              ":td",
              {
                "s": "The root item being displayed"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "&view="
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Optional view override"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "&field="
                }
              ],
              {
                "s": ", "
              },
              [
                ":code",
                {
                  "s": "&line="
                }
              ],
              {
                "s": ", "
              },
              [
                ":code",
                {
                  "s": "&col="
                }
              ],
              {
                "s": ", "
              },
              [
                ":code",
                {
                  "s": "&symbol="
                }
              ],
              {
                "s": ", "
              },
              [
                ":code",
                {
                  "s": "&region="
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Optional scroll/focus targets"
              }
            ]
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "The Viewport"
        }
      ],
      [
        ":p",
        {
          "s": "The "
        },
        [
          ":item-ref",
          {
            "s": "88888888-0000-0000-0000-000000000000"
          },
          {
            "s": "viewport"
          }
        ],
        {
          "s": " is a special item managing view state:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "rootId"
              }
            ],
            {
              "s": " — Currently displayed item"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "rootViewId"
              }
            ],
            {
              "s": " — Optional view override"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "selection"
              }
            ],
            {
              "s": " — Currently selected child (runtime only)"
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "Viewport state persists to IndexedDB, so your location survives page refresh."
        }
      ],
      [
        ":h2",
        {
          "s": "Navigation Methods"
        }
      ],
      [
        ":h3",
        {
          "s": "Full Navigation: "
        },
        [
          ":code",
          {
            "s": "api.navigate()"
          }
        ]
      ],
      [
        ":code-block",
        {
          "s": "// Navigate to an item\napi.navigate('item-uuid');\n\n// With view override\napi.navigate('item-uuid', { view: 'view-uuid' });\n\n// With scroll target (for code/markdown)\napi.navigate('item-uuid', { \n  field: 'code',\n  region: 'myFunction',\n  line: 42\n});"
        }
      ],
      [
        ":p",
        {
          "s": "This changes the viewport root and updates the URL."
        }
      ],
      [
        ":h3",
        {
          "s": "Contextual Open: "
        },
        [
          ":code",
          {
            "s": "api.openItem()"
          }
        ]
      ],
      [
        ":p",
        {
          "s": "The standard way to open an item on click. Handles modifier keys and container context automatically:"
        }
      ],
      [
        ":code-block",
        {
          "s": "// JS view — pass the click event + item ID (or attachment object)\nlink.onclick = (e) => api.openItem(e, targetId);\n\n// With navigation params (field, symbol, region, line)\nnameEl.onclick = (e) => api.openItem(e, { id: targetId, view: { navigateTo: { field: 'code', symbol: 'myFn' } } });"
        }
      ],
      [
        ":p",
        {
          "s": "In Hob views, use "
        },
        [
          ":code",
          {
            "s": "open-item!"
          }
        ],
        {
          "s": ":"
        }
      ],
      [
        ":code-block",
        {
          "s": "[:div {:on-click (fn [e] (open-item! e (:id it)))} (:name it)]"
        }
      ],
      [
        ":p",
        {
          "s": "Behavior based on modifier keys:"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Action"
              }
            ],
            [
              ":th",
              {
                "s": "Effect"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              {
                "s": "Click"
              }
            ],
            [
              ":td",
              {
                "s": "Open as sibling in container (or navigate if at root)"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Alt+Click"
              }
            ],
            [
              ":td",
              {
                "s": "Navigate as root in current tab"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Ctrl/Cmd+Click"
              }
            ],
            [
              ":td",
              {
                "s": "Open in new browser tab"
              }
            ]
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "The plain click fallback chain is: "
        },
        [
          ":code",
          {
            "s": "getOpenIn()"
          }
        ],
        {
          "s": " → "
        },
        [
          ":code",
          {
            "s": "getParentId()"
          }
        ],
        {
          "s": " → "
        },
        [
          ":code",
          {
            "s": "getCurrentRoot()"
          }
        ],
        {
          "s": ". If none are available, it navigates to the item as root."
        }
      ],
      [
        ":p",
        {
          "s": "All clickable items (compact cards, inline cards, tag pills, inline links, search results, browser views, etc.) use this centralized path."
        }
      ],
      [
        ":h3",
        {
          "s": "Low-Level: "
        },
        [
          ":code",
          {
            "s": "api.attach()"
          }
        ],
        {
          "s": " / "
        },
        [
          ":code",
          {
            "s": "api.navigate()"
          }
        ]
      ],
      [
        ":p",
        [
          ":code",
          {
            "s": "api.openItem"
          }
        ],
        {
          "s": " is built on two primitives:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "`api.attach(parentId, itemIdOrAttachment)`"
              }
            ],
            {
              "s": " — Adds an item as a child of a container (e.g., a spatial canvas window). The attachment can be a bare ID string or "
            },
            [
              ":code",
              {
                "s": "{ id, view: { navigateTo, x, y, ... } }"
              }
            ],
            {
              "s": "."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "`api.navigate(id, navigateTo?)`"
              }
            ],
            {
              "s": " — Changes the viewport root and updates the URL."
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "Use these directly only when you need explicit control (e.g., context menu actions, programmatic item creation). For click-to-open interactions, always prefer "
        },
        [
          ":code",
          {
            "s": "api.openItem"
          }
        ],
        {
          "s": " / "
        },
        [
          ":code",
          {
            "s": "open-item!"
          }
        ],
        {
          "s": "."
        }
      ],
      [
        ":h2",
        {
          "s": "Link Syntax"
        }
      ],
      [
        ":p",
        {
          "s": "Documents support "
        },
        [
          ":code",
          {
            "s": "item://"
          }
        ],
        {
          "s": " links:"
        }
      ],
      [
        ":code-block",
        {
          "s": "[Display Text](item://item-uuid)\n[Code Item](item://item-uuid#code?region=myFunction)\n[Line 42](item://item-uuid#code?lines=42)"
        }
      ],
      [
        ":p",
        {
          "s": "Clicking these links uses the same modifier key behavior as all other clickable items (see table above)."
        }
      ],
      [
        ":h2",
        {
          "s": "Navigation Events"
        }
      ],
      [
        ":p",
        {
          "s": "The system emits events on navigation:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "viewport:root-changed"
              }
            ],
            {
              "s": " — Root item changed"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "selection:changed"
              }
            ],
            {
              "s": " — Selected child changed"
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "Subscribe via the "
        },
        [
          ":item-ref",
          {
            "s": "c0c0c0c0-0006-0000-0000-000000000000"
          },
          {
            "s": "event system"
          }
        ],
        {
          "s": " to react to navigation."
        }
      ],
      [
        ":h2",
        {
          "s": "Navigation Stack"
        }
      ],
      [
        ":p",
        {
          "s": "Browser back/forward buttons work because:"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            {
              "s": "Navigation updates the URL via "
            },
            [
              ":code",
              {
                "s": "history.pushState"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "popstate"
              }
            ],
            {
              "s": " event triggers viewport update"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Previous item renders"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Item Palette (Cmd+K)"
        }
      ],
      [
        ":p",
        {
          "s": "The "
        },
        [
          ":item-ref",
          {
            "s": "f1111111-0005-0000-0000-000000000000"
          },
          {
            "s": "item search modal"
          }
        ],
        {
          "s": " provides quick navigation:"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            {
              "s": "Press "
            },
            [
              ":code",
              {
                "s": "Cmd+K"
              }
            ],
            {
              "s": " (or "
            },
            [
              ":code",
              {
                "s": "Ctrl+K"
              }
            ],
            {
              "s": ")"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Type to search items"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Enter to navigate"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Design Rationale"
        }
      ],
      [
        ":h3",
        {
          "s": "Why URL-Based Root?"
        }
      ],
      [
        ":p",
        {
          "s": "The root item being displayed is specified via URL hash, enabling:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Bookmarking"
              }
            ],
            {
              "s": " — save a link to any item"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Browser history"
              }
            ],
            {
              "s": " — back/forward buttons work naturally"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Sharing"
              }
            ],
            {
              "s": " — copy URL to reference a specific item"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Multiple entry points"
              }
            ],
            {
              "s": " — different bookmarks for different workflows"
            }
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "Why Renderer-Controlled Navigation?"
        }
      ],
      [
        ":p",
        {
          "s": "The view API provides navigation helpers ("
        },
        [
          ":code",
          {
            "s": "api.navigate()"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "api.attach()"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "api.getParentId()"
          }
        ],
        {
          "s": ") but doesn't enforce a particular pattern. Navigation and rendering methods are added to the API by "
        },
        [
          ":item-ref",
          {
            "s": "f1111111-0008-0000-0000-000000000000"
          },
          {
            "s": "viewport-rendering"
          }
        ],
        {
          "s": " when rendering views; the kernel itself has no concept of navigation. This means:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Spatial containers open links as sibling windows"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Full-screen views do full navigation"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Future views could use browsing paths, split panes, or modals"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Navigation behavior is a view concern, not a kernel concern"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "See Also"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
