  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "The REPL (Read-Eval-Print Loop) is Hobson's interactive JavaScript console for querying, scripting, and extending the system at runtime."
        }
      ],
      [
        ":h2",
        {
          "s": "Overview"
        }
      ],
      [
        ":p",
        {
          "s": "The REPL provides direct access to Hobson's API, letting you:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Query and inspect items in storage"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Create, modify, and delete items"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Test code before packaging it as libraries or views"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Debug renderers and system behavior"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Import and export data"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Accessing the REPL"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Action"
              }
            ],
            [
              ":th",
              {
                "s": "Keyboard"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              {
                "s": "Toggle REPL"
              }
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "Ctrl+\\"
                }
              ]
            ]
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "The REPL appears as a collapsible panel at the bottom of the viewport. It persists across page reloads."
        }
      ],
      [
        ":h2",
        {
          "s": "The "
        },
        [
          ":code",
          {
            "s": "api"
          }
        ],
        {
          "s": " Object"
        }
      ],
      [
        ":p",
        {
          "s": "The REPL provides an "
        },
        [
          ":code",
          {
            "s": "api"
          }
        ],
        {
          "s": " object with full access to the system:"
        }
      ],
      [
        ":p",
        {
          "s": "!"
        },
        [
          ":item-ref",
          {
            "s": "33333333-1111-0000-0000-000000000000?symbol=Kernel.createAPI"
          }
        ]
      ],
      [
        ":code-block",
        {
          "s": "const core = await api.get('33333333-1111-0000-0000-000000000000');\nconst symbols = core.content._symbols || {};\n\n// Filter to REPL API methods (direct children only)\nconst apiMethods = Object.entries(symbols)\n  .filter(([key, info]) => {\n    return key.startsWith('Kernel.createAPI.') &&\n           key.split('.').length === 3 &&\n           info.kind.includes('function');\n  })\n  .sort((a, b) => a[1].line - b[1].line);\n\n// Generate markdown table with linked method names\nlet md = '| Method | Signature |\\n|--------|----------|\\n';\nfor (const [key, info] of apiMethods) {\n  // Put full method name inside the link text to avoid markdown parsing issues\n  const link = `[\\`api.${info.name}\\`](item://33333333-1111-0000-0000-000000000000?symbol=${key})`;\n  md += `| ${link} | \\`${info.signature || '()'}\\` |\\n`;\n}\nreturn md;"
        }
      ],
      [
        ":code-block",
        {
          "s": "// Storage operations                  \nawait api.get(id)                // Get item by ID\nawait api.set(item)              // Save item (no re-render)\nawait api.update(item)           // Save item and re-render\nawait api.delete(id)             // Delete item\nawait api.query({ name: 'foo' }) // Find items by properties\nawait api.getAll()               // Get all items\n\n// Code loading\nawait api.require('library-name') // Load a library by name\n\n// Events (use EVENT_IDS GUIDs, not string names)\napi.events.on(api.EVENT_IDS.ITEM_UPDATED, handler) // Subscribe\napi.events.emit({ type: eventTypeGuid, content })  // Emit\n\n// Import/Export\nawait api.import()                // Import items from JSON file\nawait api.export()                // Export all items to JSON"
        }
      ],
      [
