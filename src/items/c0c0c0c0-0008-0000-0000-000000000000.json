      [
        ":h2",
        {
          "s": "Examples"
        }
      ],
      [
        ":h3",
        {
          "s": "Find an item by name"
        }
      ],
      [
        ":code-block",
        {
          "s": "const item = await api.helpers.findByName('my-library');\nreturn item;"
        }
      ],
      [
        ":h3",
        {
          "s": "Create a new note"
        }
      ],
      [
        ":code-block",
        {
          "s": "await api.set({\n  id: crypto.randomUUID(),\n  name: 'My Note',\n  type: '871ae771-b9b1-4f40-8c7f-d9038bfb69c3', // note type\n  attachments: [],\n  content: { description: 'Hello world' }\n});"
        }
      ],
      [
        ":h3",
        {
          "s": "List all views"
        }
      ],
      [
        ":code-block",
        {
          "s": "const views = await api.query({ type: api.IDS.VIEW });\nreturn views.map(v => v.name);"
        }
      ],
      [
        ":h3",
        {
          "s": "Navigate by URL"
        }
      ],
      [
        ":code-block",
        {
          "s": "// The REPL has no navigate() — use direct URL manipulation\nwindow.location.search = '?root=' + itemId;"
        }
      ],
      [
        ":h2",
        {
          "s": "Architecture"
        }
      ],
      [
        ":p",
        {
          "s": "The REPL has two parts:"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
