        ]
      ],
      [
        ":p",
        {
          "s": "The base API is defined in the kernel because it's used everywhere."
        }
      ],
      [
        ":h2",
        {
          "s": "Two-Layer API"
        }
      ],
      [
        ":p",
        {
          "s": "The REPL receives the base kernel API from "
        },
        [
          ":code",
          {
            "s": "createAPI()"
          }
        ],
        {
          "s": " — storage, events, modules, parent-child operations, and import/export."
        }
      ],
      [
        ":p",
        {
          "s": "Views receive an "
        },
        [
          ":strong",
          {
            "s": "enriched"
          }
        ],
        {
          "s": " API: "
        },
        [
          ":code",
          {
            "s": "createAPI()"
          }
        ],
        {
          "s": " base + rendering methods added by "
        },
        [
          ":item-ref",
          {
            "s": "f1111111-0008-0000-0000-000000000000#code?region=enrichAPI"
          },
          {
            "s": "`enrichAPI()`"
          }
        ],
        {
          "s": " in viewport-rendering. This adds "
        },
        [
          ":code",
          {
            "s": "renderItem"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "rerenderItem"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "getViews"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "navigate"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "viewport.*"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "instances.*"
          }
        ],
        {
          "s": ", and context methods ("
        },
        [
          ":code",
          {
            "s": "getViewConfig"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "updateViewConfig"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "restorePreviousView"
          }
        ],
        {
          "s": "). The 1-param forms of "
        },
        [
          ":code",
          {
            "s": "attach(itemId)"
          }
        ],
        {
          "s": " and "
        },
        [
          ":code",
          {
            "s": "detach(itemId)"
          }
        ],
        {
          "s": " also use the container context."
        }
      ],
      [
        ":h2",
        {
          "s": "Tips"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Multiline code"
              }
            ],
            {
              "s": ": The input is a textarea—write functions, loops, anything"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Async/await"
              }
            ],
            {
              "s": ": Top-level "
            },
            [
              ":code",
              {
                "s": "await"
              }
            ],
            {
              "s": " works automatically"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Return values"
              }
            ],
            {
              "s": ": Use "
            },
            [
              ":code",
              {
                "s": "return"
              }
            ],
            {
              "s": " to display results in the transcript"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "No return"
              }
            ],
            {
              "s": ": Executes silently (useful for side effects)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "String escaping"
              }
            ],
            {
              "s": ": When creating code items, be careful with nested quotes"
            }
          ]
        ]
      ],
