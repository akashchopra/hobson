      ],
      [
        ":h2",
        {
          "s": "When to Use"
        }
      ],
      [
        ":p",
        {
          "s": "This pattern is needed whenever "
        },
        [
          ":code",
          {
            "s": "api.update()"
          }
        ],
        {
          "s": " triggers a re-render that replaces DOM nodes the user is interacting with. It's most commonly used in:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Container views (spatial canvas) when adding/removing children"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "The viewport when the root item changes"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Any view that does full DOM replacement on update"
            }
          ]
        ]
