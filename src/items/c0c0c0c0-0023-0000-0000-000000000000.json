            [
              ":item-ref",
              {
                "s": "33333333-7777-0000-0000-000000000000"
              },
              {
                "s": "Safe Mode"
              }
            ],
            {
              "s": " — Nuclear recovery option"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "c0c0c0c0-0001-0000-0000-000000000000"
              },
              {
                "s": "Kernel"
              }
            ],
            {
              "s": " — What's kernel vs userland"
            }
          ]
        ]
      ]
    ],
