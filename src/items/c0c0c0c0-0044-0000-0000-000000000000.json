    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Multi-device sync and multi-user collaboration."
        }
      ],
      [
        ":h2",
        {
          "s": "Offline/Online Architecture"
        }
      ],
      [
        ":p",
        {
          "s": "The system is fully offline today. Online capabilities could add:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Optional online enhancements"
              }
            ],
            {
              "s": ": Fetch web pages, import from APIs, check for updates"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Cached web resources"
              }
            ],
            {
              "s": ": Fetch and cache URLs locally for offline access"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Device sync"
              }
            ],
            {
              "s": ": Sync between devices (laptop, phone)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Collaborative editing"
              }
            ],
            {
              "s": ": Multiple users sharing items (much later)"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Sync Design Questions"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Question"
              }
            ],
            [
              ":th",
              {
                "s": "Options"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              {
                "s": "Conflict resolution"
              }
            ],
            [
              ":td",
              {
                "s": "Last-write-wins, manual merge, CRDT"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "What syncs"
              }
            ],
            [
              ":td",
              {
                "s": "All items, specific containers, user-selected"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "When to sync"
              }
            ],
            [
              ":td",
              {
                "s": "Continuous, periodic, manual"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Mobile subset"
              }
            ],
            [
              ":td",
              {
                "s": "Full mirror or filtered subset"
              }
            ]
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Collaborative Editing"
        }
      ],
      [
        ":p",
        {
          "s": "Far-future consideration:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Operational transforms or CRDT?"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Permissions model (per-item? per-container?)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Real-time vs async collaboration"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Priority"
        }
      ],
      [
        ":p",
        {
          "s": "Low — the offline-first architecture is a deliberate design choice. Sync adds significant complexity (conflict resolution, networking, auth). Consider only when multi-device use becomes a pain point."
        }
      ]
