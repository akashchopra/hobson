{
  "id": "00000000-0000-0000-0000-000000000000",
  "name": "kernel:item",
  "type": "11111111-0000-0000-0000-000000000000",
  "extends": null,
  "created": 1768505848878,
  "modified": 1775756655511,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "The universal data structure in Hobson. Every entity — notes, types, code, views, the viewport itself — is an item with this identical structure."
        }
      ],
      [
        ":h2",
        {
          "s": "Structure"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Field"
              }
            ],
            [
              ":th",
              {
                "s": "Type"
              }
            ],
            [
              ":th",
              {
                "s": "Description"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "id"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "String"
              }
            ],
            [
              ":td",
              {
                "s": "Globally unique identifier (UUID). Seed items use memorable GUIDs like "
              },
              [
                ":code",
                {
                  "s": "00000000-..."
                }
              ],
              {
                "s": ". User items get random UUIDs."
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "name"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "String?"
              }
            ],
            [
              ":td",
              {
                "s": "Optional human-readable identifier. "
              },
              [
                ":strong",
                {
                  "s": "Required for code items"
                }
              ],
              {
                "s": " (used by "
              },
              [
                ":code",
                {
                  "s": "api.require()"
                }
              ],
              {
                "s": "). Must be unique among code items."
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "type"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "String"
              }
            ],
            [
              ":td",
              {
                "s": "UUID of the item's "
              },
              [
                ":item-ref",
                {
                  "s": "11111111-0000-0000-0000-000000000000"
                },
                {
                  "s": "type"
                }
              ],
              {
                "s": ". Every item must have a type."
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "extends"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "String?"
              }
            ],
            [
              ":td",
              {
                "s": "UUID of parent type (for type definitions only). Creates the type hierarchy."
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "created"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Number"
              }
            ],
            [
              ":td",
              {
                "s": "Timestamp (ms since epoch). Set once at creation, never changes."
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "modified"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Number"
              }
            ],
            [
              ":td",
              {
                "s": "Timestamp of last change. Updated automatically on save."
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "attachments"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Array"
              }
            ],
            [
              ":td",
              {
                "s": "Ordered list of attachment references. See Attachments below."
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "content"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Object"
              }
            ],
            [
              ":td",
              {
                "s": "Arbitrary key-value data. The kernel doesn't interpret this—views do."
              }
            ]
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Attachments"
        }
      ],
      [
        ":p",
        {
          "s": "The "
        },
        [
          ":code",
          {
            "s": "attachments"
          }
        ],
        {
          "s": " array holds references to other items, establishing composition relationships:"
        }
      ],
      [
        ":code-block",
        {
          "s": "attachments: [\n  { id: \"child-uuid\", view: { type: \"view-uuid\", ...viewConfig } }\n]"
        }
      ],
      [
        ":p",
        {
          "s": "Each child object has:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "id"
              }
            ],
            {
              "s": " — The child item's UUID"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "view"
              }
            ],
            {
              "s": " — How to display this child (required "
            },
            [
              ":code",
              {
                "s": "type"
              }
            ],
            {
              "s": " field plus view-specific config)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "previousView"
              }
            ],
            {
              "s": " — Optional; preserved state for view toggling"
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "For spatial containers, view config includes positioning: "
        },
        [
          ":code",
          {
            "s": "{ x, y, width, height, z, minimized, ... }"
          }
        ]
      ],
      [
        ":h2",
        {
          "s": "Content Field"
        }
      ],
      [
        ":p",
        {
          "s": "The "
        },
        [
          ":code",
          {
            "s": "content"
          }
        ],
        {
          "s": " object is unconstrained—each item type defines its own schema. Common patterns:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Notes"
              }
            ],
            {
              "s": ": "
            },
            [
              ":code",
              {
                "s": "{ description: \"markdown content\" }"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Code items"
              }
            ],
            {
              "s": ": "
            },
            [
              ":code",
              {
                "s": "{ description: \"what it does\", code: \"export function...\" }"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Types"
              }
            ],
            {
              "s": ": "
            },
            [
              ":code",
              {
                "s": "{ description: \"what this type represents\", required_fields: [...] }"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Views"
              }
            ],
            {
              "s": ": "
            },
            [
              ":code",
              {
                "s": "{ for_type: \"uuid\", code: \"...\", displayName: \"...\" }"
              }
            ]
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "The "
        },
        [
          ":code",
          {
            "s": "description"
          }
        ],
        {
          "s": " field is conventional—every item should have one explaining its purpose."
        }
      ],
      [
        ":h2",
        {
          "s": "Why Uniform Structure?"
        }
      ],
      [
        ":p",
        {
          "s": "Radical uniformity enables:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "One storage system"
              }
            ],
            {
              "s": " handles all data"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "One validation system"
              }
            ],
            {
              "s": " (type chain checking) applies everywhere"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "One rendering system"
              }
            ],
            {
              "s": " displays everything"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Any item can link to any other"
              }
            ],
            {
              "s": " via "
            },
            [
              ":code",
              {
                "s": "item://"
              }
            ],
            {
              "s": " URLs"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Self-documentation"
              }
            ],
            {
              "s": ": the system describes itself using itself"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "See Also"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "11111111-0000-0000-0000-000000000000"
              },
              {
                "s": "kernel:type-definition"
              }
            ],
            {
              "s": " — How types categorize items"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "22222222-0000-0000-0000-000000000000"
              },
              {
                "s": "kernel:code"
              }
            ],
            {
              "s": " — Executable items"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "aaaaaaaa-0000-0000-0000-000000000000"
              },
              {
                "s": "kernel:view"
              }
            ],
            {
              "s": " — Items that render other items"
            }
          ]
        ]
      ]
    ],
    "tags": [
      "4cae3791-df52-43a7-8152-ba9374bfe089"
    ]
  },
  "attachments": []
}