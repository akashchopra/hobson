                "s": "Silent Update Pattern"
              }
            ],
            {
              "s": " — Why closures become stale"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "ef793c27-2d4b-4c99-b05a-2769db5bc5a9"
              },
              {
                "s": "Spatial Windowing"
              }
            ],
            {
              "s": " — Where this pattern is most critical"
            }
          ]
        ]
      ]
    ],
    "tags": [
