        {
          "s": "Skipped — Trivial generic-view wrappers"
        }
      ],
      [
        ":p",
        {
          "s": "~12 small views (2-10 lines) that just delegate to generic-view. Not worth converting — no logic to exercise."
        }
      ],
      [
        ":h2",
        {
          "s": "Where Hob is already better than JS"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Item references"
              }
            ],
            {
              "s": " ("
            },
            [
              ":code",
              {
                "s": "@my-note"
              }
            ],
            {
              "s": ") are first-class, not string constants"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Domain ops"
              }
            ],
            {
              "s": " ("
            },
            [
              ":code",
              {
                "s": "get-field"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "set-field!"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "navigate!"
              }
            ],
            {
              "s": ") express Hobson concepts directly"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Homoiconicity"
              }
            ],
            {
              "s": " — macros can transform code structurally"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Sandboxed evaluation"
              }
            ],
            {
              "s": " — the system can reason about what code does"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Roadmap"
        }
      ],
      [
        ":h3",
        {
          "s": "1. JSON AST as canonical representation (implemented)"
        }
      ],
      [
        ":p",
        {
          "s": "See: "
        },
        [
          ":link",
          {
            "s": "c0c0c0c0-0051-0000-0000-000000000000"
          },
          {
            "s": "JSON AST as Canonical Code Representation"
          }
        ]
      ],
      [
        ":p",
        {
          "s": "Hob code is now stored as compact JSON AST ("
        },
        [
          ":code",
          {
            "s": "content.hob"
          }
        ],
        {
          "s": "), making it queryable without parsing, structurally editable, and inspectable with the same tools as any item property. The evaluator dispatches directly on compact JSON types — no parsing step. Phase 1 migrated all Hob items to JSON AST; Phase 2 eliminated the "
        },
        [
          ":code",
          {
            "s": "expandCompact"
          }
        ],
        {
          "s": " bridge entirely."
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Unlocks: structural editor, queryable code, safe macro expansion"
            }
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "2. Persistent view state (implemented)"
        }
      ],
      [
        ":p",
        {
          "s": "Local mutable state via atoms (with self-owned atom pattern to prevent re-render loops) plus "
        },
        [
          ":code",
          {
            "s": "get-view-config"
          }
        ],
        {
          "s": "/"
        },
        [
          ":code",
          {
            "s": "update-view-config!"
          }
        ],
        {
          "s": " for state that persists across re-renders. The self-owned atom fix tags atoms with their creation tracking context so "
        },
        [
          ":code",
          {
            "s": "reset!"
          }
        ],
        {
          "s": " on view-local atoms doesn't trigger full re-evaluation. "
        },
        [
          ":code",
          {
            "s": "updateViewConfig"
          }
        ],
        {
          "s": " saves silently to avoid reactivity cascades."
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Unlocks: ~~type-workshop~~, ~~system-browser~~, ~~viewport~~, ~~spatial-canvas~~"
            }
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "3. Sub-item rendering (implemented)"
        }
      ],
      [
        ":p",
        [
          ":code",
          {
            "s": "render-item"
          }
        ],
        {
          "s": " now accepts an options map ("
        },
        [
          ":code",
          {
            "s": ":view"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": ":sibling-container"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": ":on-cycle"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": ":decorator"
          }
        ],
        {
          "s": ") forwarded to the rendering system. "
        },
        [
          ":code",
          {
            "s": "get-sibling-container"
          }
        ],
        {
          "s": " exposes the parent's sibling container for wrapping patterns (close-then-delegate). First exercised by modal-frame-view."
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Unlocks: ~~viewport~~, app-page, ~~spatial-canvas~~, ~~modal-frame~~"
            }
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "4. Document-level events with cleanup (implemented)"
        }
      ],
      [
        ":p",
        [
          ":code",
          {
            "s": "on-document!"
          }
        ],
        {
          "s": " registers a document event listener and auto-removes it when the view's DOM is cleaned up. Returns a removal function for explicit unsubscription. "
        },
        [
          ":code",
          {
            "s": "on-cleanup!"
          }
        ],
        {
          "s": " registers arbitrary cleanup handlers wired to the DOM cleanup protocol. Cleanup handlers are bundled onto the root DOM node by "
        },
        [
          ":code",
          {
            "s": "renderHobView"
          }
        ],
        {
          "s": "."
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Unlocks: ~~viewport~~, ~~modal-frame~~"
            }
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "5. Reactivity / dependency tracking (implemented — basic + selector-filtered)"
        }
      ],
      [
        ":p",
        {
          "s": "The "
        },
        [
          ":code",
          {
            "s": "RenderInstanceRegistry"
          }
        ],
        {
          "s": " indexes every rendered instance by "
        },
        [
          ":code",
          {
            "s": "itemId"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "viewId"
          }
        ],
        {
          "s": ", and "
        },
        [
          ":code",
          {
            "s": "parentId"
          }
        ],
        {
          "s": ". When items change (via "
        },
        [
          ":code",
          {
            "s": "item:updated"
          }
        ],
        {
          "s": " events), the registry looks up affected instances and schedules re-renders. Selector-filtered reactivity ("
        },
        [
          ":code",
          {
            "s": "get-item :select"
          }
        ],
        {
          "s": ") lets Hob views declare which data slice they care about — re-renders fire only when the selector output changes (compared via "
        },
        [
          ":code",
          {
            "s": "deepEquals"
          }
        ],
        {
          "s": ")."
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Selector-filtered reactivity"
          }
        ],
        {
          "s": " (Feb 2026): "
        },
        [
          ":code",
          {
            "s": "(get-item id :select fn)"
          }
        ],
        {
          "s": " extracts the slice a view cares about. Re-renders only fire when that slice changes (via "
        },
        [
          ":code",
          {
            "s": "deepEquals"
          }
        ],
        {
          "s": "). This is how spatial-canvas-view avoids re-rendering on drag/resize — the structural selector only watches child count and minimize/maximize/anchor state."
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Selector pins"
          }
        ],
        {
          "s": ": once a selector is registered for a (context, itemId) pair, later bare "
        },
        [
          ":code",
          {
            "s": "get-item"
          }
        ],
        {
          "s": " calls on the same item don't widen it — the selector is the intentional reactivity contract."
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Bare dep fallback"
          }
        ],
        {
          "s": ": "
        },
        [
          ":code",
          {
            "s": "renderHobView"
          }
        ],
        {
          "s": " registers an implicit bare dep on item.id only if the view didn't register its own dep during evaluation. Views with structural selectors are not overridden."
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Unlocks: ~~spatial-canvas~~ (selector-filtered), efficient nested rendering"
            }
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "6. Structural editor (Phases 1–6 complete)"
        }
      ],
      [
        ":p",
        {
          "s": "Enabled by JSON AST. The strongest UX argument for Hob over JS — edit code structure directly, no syntax errors possible, the system can assist meaningfully because it understands what you're editing."
        }
      ],
      [
        ":p",
        {
          "s": "Implemented in "
        },
        [
          ":code",
          {
            "s": "field-view-hob-structural"
          }
        ],
        {
          "s": " + "
        },
        [
          ":code",
          {
            "s": "hob-structural-css"
          }
        ],
        {
          "s": ":"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Phase 1: Navigation & display with syntax colouring, pretty-printing, breadcrumbs"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Phase 2: Holes, input/string modes, token resolution, undo/redo, save"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Phase 3: Wrap, unwrap, move, slurp, barf, duplicate, change container type"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Phase 4: Inline autocomplete (symbol prefix-match + "
            },
            [
              ":code",
              {
                "s": "@"
              }
            ],
            {
              "s": "-triggered async item search via "
            },
            [
              ":code",
              {
                "s": "item-search-lib"
              }
            ],
            {
              "s": ")"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Phase 5: Mouse interactions (double-click to edit, click between siblings to insert)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Phase 6: Scope-aware autocomplete (binding/param/def analysis, priority ordering with detail labels)"
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "Remaining (Phase 7 — polish): copy/paste, context-sensitive hints, comment support, keyboard help overlay."
        }
      ]
    ],
