{
  "id": "c0c0c0c0-005c-0000-0000-000000000000",
  "name": "Hob Language & Stdlib Roadmap",
  "type": "871ae771-b9b1-4f40-8c7f-d9038bfb69c3",
  "created": 1741564800000,
  "modified": 1774988061159,
  "content": {
    "description": [
      ":doc",
      [
        ":h1",
        {
          "s": "Hob Language & Stdlib Roadmap"
        }
      ],
      [
        ":p",
        {
          "s": "Additions to Hob and its standard library, driven by real usage. See "
        },
        [
          ":item-ref",
          {
            "s": "c0c0c0c0-0058-0000-0000-000000000000"
          },
          {
            "s": "Hob Language Design Direction"
          }
        ],
        {
          "s": " for overall design principles."
        }
      ],
      [
        ":h2",
        {
          "s": "Language Additions"
        }
      ],
      [
        ":h3",
        {
          "s": "Quasiquote / Unquote"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Status:"
          }
        ],
        {
          "s": " Not started"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Motivation:"
          }
        ],
        {
          "s": " AST construction in query blocks requires heavy use of "
        },
        [
          ":code",
          {
            "s": "list"
          }
        ],
        {
          "s": " and "
        },
        [
          ":code",
          {
            "s": "cons"
          }
        ],
        {
          "s": " nesting, which is verbose and hard to read. Compare:"
        }
      ],
      [
        ":code-block",
        {
          "s": ";; Current — verbose\n(list :item-ref (:id m) (:name m))\n\n;; With quasiquote — reads like a template\n`(:item-ref ,(:id m) ,(:name m))"
        }
      ],
      [
        ":p",
        {
          "s": "Quasiquote (`"
        },
        [
          ":code",
          {
            "s": " "
          }
        ],
        {
          "s": " `"
        },
        [
          ":code",
          {
            "s": ") treats its argument as data (like "
          }
        ],
        {
          "s": "quote"
        },
        [
          ":code",
          {
            "s": "), but comma ("
          }
        ],
        {
          "s": ","
        },
        [
          ":code",
          {
            "s": ") escapes back into evaluation for dynamic parts. Splicing unquote ("
          }
        ],
        {
          "s": ",@`) splices a list into the surrounding list:"
        }
      ],
      [
        ":code-block",
        {
          "s": ";; Splicing example\n(let [items [\"a\" \"b\" \"c\"]]\n  `(:ul ,@(map (fn [x] `(:li (:p ,x))) items)))\n;; → [:ul, [:li, [:p, \"a\"]], [:li, [:p, \"b\"]], [:li, [:p, \"c\"]]]"
        }
      ],
      [
        ":p",
        {
          "s": "This is the standard Lisp mechanism for building code/data templates and would significantly improve ergonomics for:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Query blocks that construct AST ("
            },
            [
              ":code",
              {
                "s": ":doc"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": ":ul"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": ":li"
              }
            ],
            {
              "s": ", etc.)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Macro definitions (which currently also need verbose "
            },
            [
              ":code",
              {
                "s": "list"
              }
            ],
            {
              "s": " construction)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Any code that builds structured data with computed values"
            }
          ]
        ]
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Design notes:"
          }
        ]
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "JSON AST representation TBD — could use "
            },
            [
              ":code",
              {
                "s": "{qq: expr}"
              }
            ],
            {
              "s": " and "
            },
            [
              ":code",
              {
                "s": "{uq: expr}"
              }
            ],
            {
              "s": " / "
            },
            [
              ":code",
              {
                "s": "{splice: expr}"
              }
            ],
            {
              "s": " objects"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Should work at the evaluator level, expanding before evaluation"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Structural editor would need to understand these new node types"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Stdlib Additions"
        }
      ],
      [
        ":h3",
        {
          "s": "Transclusion & Interop Functions"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Status:"
          }
        ],
        {
          "s": " Implemented (doc-ast-editor branch)"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "transclude"
              }
            ],
            {
              "s": " — get-field with source attribution: "
            },
            [
              ":code",
              {
                "s": "(transclude @item :field)"
              }
            ],
            {
              "s": ", optional "
            },
            [
              ":code",
              {
                "s": ":symbol"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": ":chrome"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "transclusion-chrome"
              }
            ],
            {
              "s": " — wrap any value in attribution chrome: "
            },
            [
              ":code",
              {
                "s": "(transclusion-chrome value :source @item :symbol \"name\")"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "call-export"
              }
            ],
            {
              "s": " — call a JS export by name: "
            },
            [
              ":code",
              {
                "s": "(call-export @item \"fnName\" arg1 arg2 ...)"
              }
            ],
            {
              "s": ". Transparent arg pass-through with Hob→JS conversion at the boundary."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "extract-symbol"
              }
            ],
            {
              "s": " — extract a symbol's source code: "
            },
            [
              ":code",
              {
                "s": "(extract-symbol @item \"symbolName\")"
              }
            ]
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "Audit view ops vs item ops boundary"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Status:"
          }
        ],
        {
          "s": " Partially addressed"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Problem:"
          }
        ],
        {
          "s": " Functions available to Hob code are split into three tiers: stdlib (always available), item ops (available when api is wired up), and view ops (only available during "
        },
        [
          ":code",
          {
            "s": "renderHobView"
          }
        ],
        {
          "s": "). Active Text eval blocks use "
        },
        [
          ":code",
          {
            "s": "evaluateHob"
          }
        ],
        {
          "s": " which only provides stdlib + item ops, not view ops. This means pure utility functions like "
        },
        [
          ":code",
          {
            "s": "extract-text"
          }
        ],
        {
          "s": " are unavailable in eval blocks simply because they were registered in the wrong tier."
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Action:"
          }
        ],
        {
          "s": " Audit all functions in "
        },
        [
          ":code",
          {
            "s": "registerViewOps"
          }
        ],
        {
          "s": " and move context-free ones (those not needing a render tree, viewport, or cleanup tracking) to "
        },
        [
          ":code",
          {
            "s": "registerItemOps"
          }
        ],
        {
          "s": " or stdlib. Only functions that genuinely require a rendering context ("
        },
        [
          ":code",
          {
            "s": "render-item"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "on-cleanup!"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "navigate!"
          }
        ],
        {
          "s": ", etc.) should remain view-only. Ideally, eval blocks and views should have the same function vocabulary, with context-dependent functions erroring gracefully when used outside a view."
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Done so far:"
          }
        ],
        {
          "s": " Moved "
        },
        [
          ":code",
          {
            "s": "extract-text"
          }
        ],
        {
          "s": " from view ops to item ops (March 2026)."
        }
      ],
      [
        ":h2",
        {
          "s": "Infrastructure"
        }
      ],
      [
        ":h3",
        {
          "s": "Derive editor autocomplete from interpreter stdlib"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Status:"
          }
        ],
        {
          "s": " Not started"
        }
      ],
      [
        ":p",
        {
          "s": "The "
        },
        [
          ":item-ref",
          {
            "s": "50fe7334-da51-4d3a-85a0-1b6074cc8324"
          },
          {
            "s": "hob-structural editor"
          }
        ],
        {
          "s": " has a hardcoded "
        },
        [
          ":code",
          {
            "s": "STDLIB"
          }
        ],
        {
          "s": " array for autocomplete. This drifts whenever stdlib functions are added. The interpreter should expose its stdlib symbol names so the editor can query them at runtime, eliminating the manual sync."
        }
      ],
      [
        ":h3",
        {
          "s": "Fix evaluateHob childEnv (silently ignored)"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Status:"
          }
        ],
        {
          "s": " Not started"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Problem:"
          }
        ],
        {
          "s": " "
        },
        [
          ":code",
          {
            "s": "evaluateHob"
          }
        ],
        {
          "s": " (in viewport-rendering) creates a "
        },
        [
          ":code",
          {
            "s": "childEnv"
          }
        ],
        {
          "s": " via "
        },
        [
          ":code",
          {
            "s": "createEnvironment()"
          }
        ],
        {
          "s": ", adds "
        },
        [
          ":code",
          {
            "s": "api"
          }
        ],
        {
          "s": " and "
        },
        [
          ":code",
          {
            "s": "item"
          }
        ],
        {
          "s": " bindings to it, then passes it to "
        },
        [
          ":code",
          {
            "s": "hob.evaluate(hobAst, childEnv, [])"
          }
        ],
        {
          "s": ". But the interpreter exports "
        },
        [
          ":code",
          {
            "s": "evaluate: (ast) => evaluate(ast, stdlib, [])"
          }
        ],
        {
          "s": " — the second argument is silently ignored. The childEnv bindings have no effect. Things work only because "
        },
        [
          ":code",
          {
            "s": "transclude"
          }
        ],
        {
          "s": " etc. are in stdlib, and item access goes through "
        },
        [
          ":code",
          {
            "s": "rendering._hobItemApi._evalApi"
          }
        ],
        {
          "s": " instead. This is fragile — the code looks correct but the explicit env pattern does nothing."
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Fix:"
          }
        ],
        {
          "s": " Either make the exported "
        },
        [
          ":code",
          {
            "s": "evaluate"
          }
        ],
        {
          "s": " accept an env parameter, or restructure how "
        },
        [
          ":code",
          {
            "s": "evaluateHob"
          }
        ],
        {
          "s": " injects bindings."
        }
      ],
      [
        ":h3",
        {
          "s": "Hob debugging support (Phase 1)"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Status:"
          }
        ],
        {
          "s": " Done (March 2026)"
        }
      ],
      [
        ":p",
        {
          "s": "Structured error data with Hob call stack and expression context. Errors carry structured data (hobStack, hobExpr) rather than baking context into message strings — each consumer (toast, error view, console) renders appropriately."
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "What was implemented:"
          }
        ]
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "HobError class stores structured hobStack (call frames with name + AST) and hobExpr (failing expression)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Context frames in all special forms (let, if, do, and, or, loop, try, plet, for, def) — push/pop around sub-expression evaluation"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Centralized error capture in evaluateHob — all callers get toast notifications without their own captureError calls"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Error handler and error view updated to render Hob call stack with pretty-printed expressions; JS stack collapsed by default"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "pretty-print"
              }
            ],
            {
              "s": " added to Hob stdlib for use in Hob views"
            }
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "Hob debugging support (Phase 2)"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Status:"
          }
        ],
        {
          "s": " Not started"
        }
      ],
      [
        ":p",
        {
          "s": "Building on Phase 1's structured error data, the next step is to connect errors to the structural editor:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "When a view render fails, highlight the failing AST node in the structural editor (errors carry node paths via hobExpr)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Click-to-navigate from error view Hob stack frames to the corresponding expression in the structural editor"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Source mapping: connect Hob stack frames to specific positions in the AST, not just the item"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Recent Additions (March 2026)"
        }
      ],
      [
        ":p",
        {
          "s": "These stdlib functions were added during the Active Text editor work:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "extract-text"
              }
            ],
            {
              "s": " — native JS function for extracting plain text from Active Text (replaces slow Hob-interpreted walks)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "extract-symbol"
              }
            ],
            {
              "s": " — extract a named symbol's definition from code"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "call-export"
              }
            ],
            {
              "s": " — call a named export from a code item module"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "transclusion-chrome"
              }
            ],
            {
              "s": " — wrap content with source attribution UI"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "min"
              }
            ],
            {
              "s": " / "
            },
            [
              ":code",
              {
                "s": "max"
              }
            ],
            {
              "s": " — variadic numeric comparison builtins"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "pretty-print"
              }
            ],
            {
              "s": " — format compact JSON AST as readable s-expressions"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Named "
            },
            [
              ":code",
              {
                "s": "fn"
              }
            ],
            {
              "s": " support — "
            },
            [
              ":code",
              {
                "s": "(fn name [params] body)"
              }
            ],
            {
              "s": " enables recursion without "
            },
            [
              ":code",
              {
                "s": "defn"
              }
            ]
          ]
        ]
      ]
    ],
    "tags": [
      "bff75873-edb8-412e-81c9-c744e68fe29f",
      "c0c0c0c0-0040-0000-0000-000000000000",
      "c0c0c0c0-0085-0000-0000-000000000000"
    ]
  },
