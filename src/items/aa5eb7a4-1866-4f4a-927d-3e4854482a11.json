{
  "id": "aa5eb7a4-1866-4f4a-927d-3e4854482a11",
  "name": "Competent Crew Syllabus",
  "type": "871ae771-b9b1-4f40-8c7f-d9038bfb69c3",
  "created": 1775737758412,
  "modified": 1776011980484,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "The Competent Crew course introduces the complete beginner to cruising and teaches personal safety, seamanship and helmsmanship to the level required to be a useful member of crew of a cruising yacht."
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "1. Knowledge of sea terms and parts of a boat, her rigging and sails"
          }
        ]
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Sufficient knowledge to understand orders given concerning the sailing and day to day running of the boat."
            }
          ]
        ]
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "2. Sail Handling"
          }
        ]
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Bending on, setting, reefing and handling of sails"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Use of sheets and halyards and their associated winches"
            }
          ]
        ]
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "3. Ropework"
          }
        ]
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Handling ropes, including coiling, stowing, securing to cleats and single and double bollards"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Handling warps"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Ability to tie the following knots and to know their correct use: "
            }
          ],
          [
            ":ul",
            [
              ":li",
              [
                ":p",
                {
                  "s": "figure-of-eight"
                }
              ]
            ],
            [
              ":li",
              [
                ":p",
                {
                  "s": "clove hitch"
                }
              ]
            ],
            [
              ":li",
              [
                ":p",
                {
                  "s": "rolling hitch"
                }
              ]
            ],
            [
              ":li",
              [
                ":p",
                {
                  "s": "bowline"
                }
              ]
            ],
            [
              ":li",
              [
                ":p",
                {
                  "s": "round turn and two half hitches"
                }
              ]
            ],
            [
              ":li",
              [
                ":p",
                {
                  "s": "single and double sheet bend"
                }
              ]
            ],
            [
              ":li",
              [
                ":p",
                {
                  "s": "reef knot"
                }
              ]
            ]
          ]
        ]
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "4. Fire precautions and fighting"
          }
        ]
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Awareness of the hazards of fire and the precautions necessary to prevent fire"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Knowledge of the action to be taken in the event of fire"
            }
          ]
        ]
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "5. Personal safety equipment"
          }
        ]
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Understands and complies with rules for the wearing of safety harnesses, lifejackets and personal buoyancy aids"
            }
          ]
        ]
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "6. Man overboard"
          }
        ]
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Understands the action to be taken to recover a man overboard"
            }
          ]
        ]
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "7. Emergency equipment"
          }
        ]
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Can operate distress flares and knows when they should be used"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Understands how to launch and board a liferaft"
            }
          ]
        ]
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "8. Manners and customs"
          }
        ]
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Understands accepted practice with regard to: use of burgees and ensigns, prevention of unnecessary noise or disturbance in harbour including courtesies to other craft berthed"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Aware of the responsibility of yacht skippers to protect the environment"
            }
          ]
        ]
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "9. Rules of the road"
          }
        ]
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Is able to keep an efficient lookout at sea"
            }
          ]
        ]
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "10. Dinghies"
          }
        ]
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Understands and complies with the loading rules."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Is able to handle a dinghy under oars"
            }
          ]
        ]
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "11. Meteorology"
          }
        ]
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Awareness of forecasting services and knowledge of the Beaufort scale"
            }
          ]
        ]
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "12. Seasickness"
          }
        ]
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Working efficiency is unaffected/partially affected/severely affected by seasickness"
            }
          ]
        ]
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "13. Helmsmanship and sailing"
          }
        ]
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Understands the basic principles of sailing and can steer and trim sails on all points of sailing"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Can steer a compass course, under sail and power"
            }
          ]
        ]
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "14. General duties"
          }
        ]
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Has carried out general duties satisfactorily on deck and below decks in connection with the daily routine of the vessel"
            }
          ]
        ]
      ]
    ],
    "tags": [
      "ead45f59-419c-468a-8dd5-420a06df5ed1",
      "c0c0c0c0-0085-0000-0000-000000000000"
    ]
  },
