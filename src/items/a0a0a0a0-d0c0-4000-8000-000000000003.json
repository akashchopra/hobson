          "s": "Kernel Modules"
        }
      ],
      [
        ":p",
        {
          "s": "The kernel is decomposed into specialized subsystems:"
        }
      ],
      [
        ":code-block",
        {
          "s": "const modules = await api.query({ type: api.IDS.KERNEL_MODULE });\nmodules.sort((a, b) => (a.name || '').localeCompare(b.name || ''));\nreturn transcludeEach(modules, m =>\n  `### [${m.name}](item://${m.id})\\n${m.content?.description?.split('\\n')[0] || 'No description'}`,\n  { chrome: 'none' }\n);"
        }
