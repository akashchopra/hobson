      [
        ":p",
        {
          "s": "Each widget type has a corresponding "
        },
        [
          ":code",
          {
            "s": "*-view"
          }
        ],
        {
          "s": " item. New widget types can be added incrementally (one type-def + one view) without modifying any existing code."
        }
      ],
      [
        ":h2",
        {
          "s": "Page Data Model"
        }
      ],
      [
        ":p",
        {
          "s": "An app-page item has:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "content.columns"
              }
            ],
            {
              "s": " (number, default 12) — grid column count"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "content.gap"
              }
            ],
            {
              "s": " (number, default 8) — gap between cells in pixels"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "content.rowHeight"
              }
            ],
            {
              "s": " (number, default 40) — fixed row height in pixels. Uses "
            },
            [
              ":code",
              {
                "s": "grid-auto-rows"
              }
            ],
            {
              "s": " with "
            },
            [
              ":code",
              {
                "s": "row-gap: 0"
              }
            ],
            {
              "s": "; vertical spacing comes from cell padding. Widgets use "
            },
            [
              ":code",
              {
                "s": "rowSpan"
              }
            ],
            {
              "s": " to occupy multiple rows. Cells have "
            },
            [
              ":code",
              {
                "s": "overflow: auto"
              }
            ],
            {
              "s": " so tall content scrolls within its allocated space"
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "Attachments use the standard "
        },
        [
          ":code",
          {
            "s": "{ id, view }"
          }
        ],
        {
          "s": " format with grid-specific view properties:"
        }
      ],
      [
        ":code-block",
        {
          "s": "{ id: \"<widget-id>\", view: { col: 1, row: 1, colSpan: 12, rowSpan: 1, viewId?: \"<view-guid>\" } }"
        }
      ],
      [
        ":p",
        {
          "s": "All positions are 1-based, matching CSS Grid convention. The optional "
        },
        [
          ":code",
          {
            "s": "viewId"
          }
        ],
        {
          "s": " field overrides the standard view resolution for this attachment, allowing a specific view to be used without changing the item's global preferred view."
        }
      ],
      [
        ":h2",
        {
          "s": "Shared State (pageContext)"
        }
      ],
      [
        ":p",
        {
          "s": "Widgets communicate through a runtime key-value state object maintained by the page view. This state is "
        },
        [
          ":strong",
          {
            "s": "not persisted"
          }
        ],
        {
          "s": " — it exists only while the page is rendered."
        }
      ],
      [
        ":p",
        {
          "s": "The page view creates a "
        },
        [
          ":code",
          {
            "s": "pageContext"
          }
        ],
        {
          "s": " object and passes it to widget views via an augmented API ("
        },
        [
          ":code",
          {
            "s": "Object.create(api)"
          }
        ],
        {
          "s": " with "
        },
        [
          ":code",
          {
            "s": "pageContext"
          }
        ],
        {
          "s": " added). Widget views access it through "
        },
        [
          ":code",
          {
            "s": "api.pageContext"
          }
        ],
        {
          "s": "."
        }
      ],
      [
        ":h3",
        {
          "s": "API"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "pageContext.getState(key)"
              }
            ],
            {
              "s": " — read a value"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "pageContext.setState(key, value)"
              }
            ],
            {
              "s": " — write a value and notify listeners"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "pageContext.onStateChange(key, callback)"
              }
            ],
            {
              "s": " — subscribe to changes; returns unsubscribe function"
            }
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "How Widgets Use State"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Producers"
          }
        ],
        {
          "s": " (radio groups, checkbox groups) write to state via their "
        },
        [
          ":code",
          {
            "s": "stateKey"
          }
        ],
        {
          "s": " content field:"
        }
      ],
      [
        ":code-block",
        {
          "s": "pageContext.setState(widget.content.stateKey, selectedValue);"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Consumers"
          }
        ],
        {
          "s": " (buttons) read state in their "
        },
        [
          ":code",
          {
            "s": "content.code"
          }
        ],
        {
          "s": ":"
        }
      ],
      [
        ":code-block",
        {
          "s": "const selected = pageContext.getState('selectedItems');"
        }
      ],
      [
        ":p",
        {
          "s": "Widgets that don't use "
        },
        [
          ":code",
          {
            "s": "pageContext"
          }
        ],
        {
          "s": " work fine standalone — they're just normal views."
        }
      ],
