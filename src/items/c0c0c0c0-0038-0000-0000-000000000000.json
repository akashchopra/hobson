      [
        ":h2",
        {
          "s": "Design Mode"
        }
      ],
      [
        ":p",
        {
          "s": "The app-page-view includes a visual design mode for editing layout without manually editing JSON. A small \"Design\" button in the top-right corner of the page toggles between modes."
        }
      ],
      [
        ":h3",
        {
          "s": "Live Mode"
        }
      ],
      [
        ":p",
        {
          "s": "Widgets are fully interactive. No design UI is visible (except the toggle button)."
        }
      ],
      [
        ":h3",
        {
          "s": "Design Mode"
        }
      ],
      [
        ":p",
        {
          "s": "A toolbar appears with:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Live Mode"
              }
            ],
            {
              "s": " button — switch back to live mode"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "+ Add Widget"
              }
            ],
            {
              "s": " button — opens a picker listing all "
            },
            [
              ":code",
              {
