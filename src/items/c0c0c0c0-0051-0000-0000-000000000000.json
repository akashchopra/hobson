                ":code",
                {
                  "s": "content.hob"
                }
              ],
              {
                "s": " (text). Could offer a sugar-syntax editing mode via the sugar layer."
              }
            ]
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "Unchanged"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Component"
              }
            ],
            [
              ":th",
              {
                "s": "Why"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              {
                "s": "Storage, item model"
              }
            ],
            [
              ":td",
              {
                "s": "Items are already JSON. "
              },
              [
                ":code",
                {
                  "s": "content.code"
                }
              ],
              {
                "s": " is just another JSON property."
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Type system"
              }
            ],
            [
              ":td",
              {
                "s": "No change. Code items still have types, extend chains, etc."
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Watch system"
              }
            ],
            [
              ":td",
              {
                "s": "No change. Watches can trigger on "
              },
              [
                ":code",
                {
                  "s": "content.code"
                }
              ],
              {
                "s": " changes as they do on any content change."
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Rendering system"
              }
            ],
            [
              ":td",
              {
                "s": "No change. Views render items; the item's content format is the view's concern."
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Kernel"
              }
            ],
            [
              ":td",
              {
                "s": "No change. The kernel doesn't know about Hob specifically."
              }
            ]
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "What We Gain"
        }
      ],
      [
        ":h3",
        {
          "s": "Parser elimination"
        }
      ],
      [
        ":p",
        [
          ":code",
          {
            "s": "JSON.parse()"
          }
        ],
        {
          "s": " replaces ~200+ lines of hand-written parser. It is built-in, battle-tested, and zero maintenance. The sugar layer exists only as a UI convenience and is not on any critical path — if it has a bug, the system still functions."
        }
      ],
      [
        ":h3",
        {
          "s": "True code-as-data"
        }
      ],
      [
        ":p",
        {
          "s": "Code is stored in the same JSON format as every other item property. This is not a philosophical aspiration — it is literally true. The same tools that query, index, transform, and display item data work on code without any adaptation."
        }
      ],
      [
        ":h3",
        {
          "s": "Queryability"
        }
      ],
      [
        ":p",
        {
          "s": "\"Find all items that call function X\" becomes a recursive walk over native JS arrays — no parse step required. Indexes can be built over the AST structure directly. Pattern matching against code structure is matching against plain JS values."
        }
      ],
      [
        ":h3",
        {
          "s": "Structural editing alignment"
        }
      ],
      [
        ":p",
        {
          "s": "A future structural editor operates directly on the canonical representation. There is no parse-on-load / serialize-on-save cycle, no round-trip fidelity concerns. Every edit modifies the real data."
        }
      ],
      [
        ":h3",
        {
          "s": "Simpler evaluator"
        }
      ],
      [
        ":p",
        {
          "s": "The evaluator dispatches on native JS types rather than wrapper objects. A "
        },
        [
          ":code",
          {
            "s": "switch"
          }
        ],
        {
          "s": " on "
        },
        [
          ":code",
          {
            "s": "typeof"
          }
        ],
        {
          "s": " and a few property checks replaces a "
        },
        [
          ":code",
          {
            "s": "switch"
          }
        ],
        {
          "s": " on "
        },
        [
          ":code",
          {
            "s": "node.type"
          }
        ],
        {
          "s": " with associated unwrapping."
        }
      ],
      [
        ":h3",
        {
          "s": "Simpler macros"
        }
      ],
      [
        ":p",
        {
          "s": "Macros construct return values using array literals and object literals — standard JS. No AST constructor functions needed. A macro that transforms "
        },
        [
          ":code",
          {
            "s": "(when cond body)"
          }
        ],
        {
          "s": " into "
        },
        [
          ":code",
          {
            "s": "(if cond (do body) nil)"
          }
        ],
        {
          "s": ":"
        }
      ],
      [
        ":code-block",
        {
          "s": "// Before (typed AST):\nfunction whenMacro(node) {\n  return makeList([\n    makeSymbol('if'),\n    node.elements[1],\n    makeList([makeSymbol('do'), node.elements[2]]),\n    makeNil()\n  ]);\n}\n\n// After (JSON AST):\nfunction whenMacro(args) {\n  return [\"if\", args[1], [\"do\", args[2]], null];\n}"
        }
      ],
      [
        ":h2",
        {
          "s": "What We Lose"
        }
      ],
      [
        ":h3",
        {
          "s": "Raw readability"
        }
      ],
      [
        ":p",
        [
          ":code",
          {
            "s": "[\"defn\", \"greet\", {\"v\": [\"name\"]}, ...]"
          }
        ],
        {
          "s": " is noisier than "
        },
        [
          ":code",
          {
            "s": "(defn greet [name] ...)"
          }
        ],
        {
          "s": " when inspecting raw item JSON. Mitigated by the pretty printer for display and the sugar layer for input. In practice, users would rarely read raw JSON — they'd interact through the REPL, code editor, or structural editor."
        }
      ],
      [
        ":h3",
        {
          "s": "Formatting control"
        }
      ],
      [
        ":p",
        {
          "s": "The pretty printer makes all formatting decisions. Hand-formatting (aligning columns, grouping blank lines) is not preserved. This is consistent with modern auto-formatting (gofmt, Prettier) and is moot for a structural editor."
        }
      ],
      [
        ":h3",
        {
          "s": "Copy-paste from external Lisp"
        }
      ],
      [
        ":p",
        {
          "s": "You cannot paste raw s-expression code from the web and have it work directly. The sugar layer handles conversion, but it's an extra step. In practice, Hob is not standard Scheme or Clojure — external code would need adaptation regardless."
        }
      ],
      [
        ":h3",
        {
          "s": "Error reporting"
        }
      ],
      [
        ":p",
        {
          "s": "Text-based errors report line and column. AST-based errors report paths like "
        },
        [
          ":code",
          {
            "s": "content.code.3.1.0"
          }
        ],
        {
          "s": ". The pretty printer can reverse-map paths to rendered lines. A structural editor can highlight the node directly. Error quality depends on the evaluator's messages, not the representation."
        }
      ],
      [
        ":h3",
        {
          "s": "JSON numeric edge cases"
        }
      ],
      [
        ":p",
        [
          ":code",
          {
            "s": "Infinity"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "NaN"
          }
        ],
        {
          "s": ", and "
        },
        [
          ":code",
          {
            "s": "-0"
          }
        ],
        {
          "s": " cannot be represented in JSON. These are unlikely to appear as literals in Hob source code. If needed, they could be represented as symbols ("
        },
        [
          ":code",
          {
            "s": "\"Infinity\""
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "\"NaN\""
          }
        ],
        {
          "s": ") that the evaluator resolves."
        }
      ],
      [
        ":h2",
        {
          "s": "Migration"
        }
      ],
      [
        ":p",
        {
          "s": "Conversion from text to JSON AST is fully automatable. A one-time migration tool would:"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            {
              "s": "Read each code item's "
            },
            [
              ":code",
              {
                "s": "content.hob"
              }
            ],
            {
              "s": " text."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Parse using the existing Hob reader (with a small modification to capture comments and their positions rather than discarding them)."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Convert the verbose AST ("
            },
            [
              ":code",
              {
                "s": "{ type: 'symbol', value: 'foo' }"
              }
            ],
            {
              "s": ") to compact form ("
            },
            [
              ":code",
              {
                "s": "\"foo\""
              }
            ],
            {
              "s": ")."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Map captured comment positions to AST paths."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Write "
            },
            [
              ":code",
              {
                "s": "content.code"
              }
            ],
            {
              "s": " and "
            },
            [
              ":code",
              {
                "s": "content.comments"
              }
            ],
            {
              "s": " to the item."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Remove "
            },
            [
              ":code",
              {
                "s": "content.hob"
              }
            ],
            {
              "s": "."
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "The migration tool uses the existing parser one final time, then the parser can be retired. The tool is run once per item and then discarded."
        }
      ],
      [
        ":h2",
        {
          "s": "Relationship to Future Structural Editor"
        }
      ],
      [
        ":p",
        {
          "s": "This proposal is independent of but complementary to the structural editor design. The original design assumed Option B (parse text on load, serialize on save). With JSON AST as canonical, the structural editor instead operates directly on the stored representation — a strictly simpler architecture."
        }
      ],
      [
        ":p",
        {
          "s": "The sugar layer and pretty printer designed here serve double duty: they provide text-mode editing and REPL interaction now, and become the import/export layer for a structural editor later."
        }
      ],
      [
        ":h2",
        {
          "s": "Alignment with Hobson Philosophy"
        }
      ],
      [
        ":p",
        {
          "s": "This change deepens the alignment between Hobson's design and its inspirations:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Humane Dozen — Unified representation:"
              }
            ],
            {
              "s": " \"Source\" and \"object\" language representations become literally the same. Code items are JSON. Data items are JSON. There is one representation."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Humane Dozen — Self-revealing:"
              }
            ],
            {
              "s": " The AST is inspectable with the same tools as any item. No hidden text-parsing step stands between the user and their code's structure."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Smalltalk / live environments:"
              }
            ],
            {
              "s": " The system operates on live objects (JS arrays and primitives), not on text that must be parsed into objects. This is closer to how Smalltalk's image works — code exists as structured objects, not source files."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Lisp homoiconicity:"
              }
            ],
            {
              "s": " The representation is faithful to Lisp's \"code is data\" principle — more so than text, because the stored form "
            },
            [
              ":em",
              {
                "s": "is"
              }
            ],
            {
              "s": " the data structure the evaluator consumes."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Obenauer's itemised OS:"
              }
            ],
            {
              "s": " Everything is an item, queryable and linkable. Code was the last holdout stored as opaque text. This proposal closes that gap."
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Open Questions"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Should the sugar layer support the full Hob syntax (reader macros, anonymous function shorthand `#(+ %1 %2)`, etc.)?"
              }
            ],
            {
              "s": " Or should it be minimal, covering only what's needed for comfortable REPL use? The latter is simpler and defers complexity to the structural editor."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Comment path stability."
              }
            ],
            {
              "s": " When a list element is inserted or removed, existing comment paths shift. Should the system attempt to update paths automatically, or treat comments as best-effort metadata that may need manual repair? (This is analogous to how line-based comments in text don't survive arbitrary refactoring.)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Anonymous function shorthand."
              }
            ],
            {
              "s": " In text, "
            },
            [
              ":code",
              {
                "s": "#(+ %1 %2)"
              }
            ],
            {
              "s": " is syntactic sugar for "
            },
            [
              ":code",
              {
                "s": "(fn [a b] (+ a b))"
              }
            ],
            {
              "s": ". In JSON AST, should this sugar exist at all, or should the canonical form always be the expanded "
            },
            [
              ":code",
              {
                "s": "[\"fn\", {\"v\": [\"a\", \"b\"]}, [\"+\", \"a\", \"b\"]]"
              }
            ],
            {
              "s": "? The latter is simpler and more explicit."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Naming."
              }
            ],
            {
              "s": " "
            },
            [
              ":code",
              {
                "s": "content.code"
              }
            ],
            {
              "s": " is currently used by JavaScript code items. Hob code items would need either a different field name (e.g. "
            },
            [
              ":code",
              {
                "s": "content.ast"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "content.hob"
              }
            ],
            {
              "s": ") or a convention to distinguish the two. Using "
            },
            [
              ":code",
              {
                "s": "content.hob"
              }
            ],
            {
              "s": " (the same field name, now containing JSON instead of text) is clean but could cause confusion during migration."
            }
          ]
        ]
      ]
