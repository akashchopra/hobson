                }
              ]
            ]
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Supporting Libraries"
        }
      ],
      [
        ":code-block",
        {
          "s": "const ids = ['f1111111-0001-0000-0000-000000000000', 'f1111111-0002-0000-0000-000000000000', 'f1111111-0003-0000-0000-000000000000', 'f1111111-0004-0000-0000-000000000000', 'f1111111-0005-0000-0000-000000000000', 'f1111111-0006-0000-0000-000000000000', 'f1111111-0007-0000-0000-000000000000'];\nconst items = [];\nfor (const id of ids) {\n  try { items.push(await api.get(id)); } catch(e) {}\n}\nreturn '| Library | Purpose |\\n|---------|---------|\\n' + items.map(i => {\n  const desc = i.content?.description?.split('\\n')[0] || 'No description';\n  return `| [${i.name}](item://${i.id}) | ${desc} |`;\n}).join('\\n') + '\\n';"
        }
      ],
      [
        ":h2",
        {
          "s": "Design Rationale"
        }
      ],
      [
        ":h3",
        {
          "s": "Why Userland?"
        }
      ],
      [
        ":p",
        {
          "s": "The viewport could be kernel code, but keeping it as regular items means:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "The REPL panel, item palette, and help dialog can be modified or replaced"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Context menu operations are inspectable and extensible"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "The viewport view itself can be swapped (though this is rare)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Hot-reload works — editing viewport-view updates behavior immediately"
            }
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "Why Singleton?"
        }
      ],
      [
        ":p",
        {
          "s": "There is exactly one viewport per Hobson instance. It serves as the root of the render tree. Nested instances (via "
        },
        [
          ":code",
          {
            "s": "?instance="
          }
        ],
        {
          "s": ") get their own viewport in their own storage namespace."
        }
      ],
      [
        ":h3",
        {
          "s": "Why URL-Authoritative?"
        }
      ],
      [
        ":p",
        {
          "s": "Making the URL the source of truth for the root item enables bookmarking, browser history, sharing links, and multiple entry points — all for free from the browser platform."
        }
      ],
