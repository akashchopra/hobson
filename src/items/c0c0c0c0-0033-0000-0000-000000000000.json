              {
                "s": "Toggle REPL"
              }
            ],
            [
              ":td",
              [
                ":item-ref",
                {
                  "s": "f1111111-0003-0000-0000-000000000000"
                },
                {
                  "s": "repl-ui"
                }
              ]
            ]
          ],
          [
            ":tr",
            [
              ":td",
              {
                "s": "Ctrl+Shift+S"
              }
            ],
            [
              ":td",
              [
                ":item-ref",
                {
                  "s": "33333333-7777-0000-0000-000000000000"
                },
                {
                  "s": "Safe mode"
                }
              ],
              {
                "s": " escape hatch"
              }
            ],
            [
              ":td",
              {
                "s": "Bootloader (hardcoded)"
              }
            ]
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Viewport Events"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Event"
              }
            ],
            [
              ":th",
              {
                "s": "When"
              }
            ],
            [
              ":th",
              {
                "s": "Payload"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
