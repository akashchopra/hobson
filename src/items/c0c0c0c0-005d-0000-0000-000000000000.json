                }
              ],
              {
                "s": " — field with chrome"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "![](item://id#code?region=name)"
                }
              ]
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "(transclude @id :code :region \"name\")"
                }
              ]
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "![](item://id#code?lines=10-20)"
                }
              ]
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "(transclude @id :code :lines 10 20)"
                }
              ]
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "![](item://id?symbol=name)"
                }
              ]
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "(transclude @id :code :symbol \"name\")"
                }
              ]
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "![](item://id?call=fn)"
                }
              ]
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "(call-export @id \"fn\")"
                }
              ]
            ]
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "The "
        },
        [
          ":code",
          {
            "s": "transclude"
          }
        ],
        {
          "s": " function handles region/lines/symbol extraction internally, keeping the call site clean. For cases where you want the raw data without chrome, use "
        },
        [
          ":code",
          {
            "s": "get-field"
          }
        ],
        {
          "s": " and the extraction helpers directly:"
        }
      ],
      [
        ":code-block",
        {
          "s": "(extract-region (get-field @id :code) \"name\")\n(extract-lines (get-field @id :code) 10 20)\n(extract-symbol @id \"name\")"
        }
      ],
      [
        ":p",
        {
          "s": "The helper functions ("
        },
        [
          ":code",
          {
            "s": "extract-region"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "extract-lines"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "extract-symbol"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "call-export"
          }
        ],
        {
          "s": ") would be stdlib additions. Each is independently useful beyond transclusion."
        }
      ],
      [
        ":h2",
        {
          "s": "Migration"
        }
      ],
      [
        ":p",
        {
          "s": "Existing "
        },
        [
          ":code",
          {
            "s": ":transclusion"
          }
        ],
        {
          "s": " and "
        },
        [
          ":code",
          {
            "s": ":field-ref"
          }
        ],
        {
          "s": " nodes in stored ASTs need manual conversion. Since "
        },
        [
          ":code",
          {
            "s": ":doc"
          }
        ],
        {
          "s": " Active Text adoption is early, this is a small number of items. The doc-ast-converter ("
        },
        [
          ":code",
          {
            "s": "d0d0d0d0-0008"
          }
        ],
        {
          "s": ") would be updated to emit "
        },
        [
          ":code",
          {
            "s": "get-field"
          }
        ],
        {
          "s": " calls instead of "
        },
        [
          ":code",
          {
            "s": ":transclusion"
          }
        ],
        {
          "s": "/"
        },
        [
          ":code",
          {
            "s": ":field-ref"
          }
        ],
        {
          "s": " nodes."
        }
      ],
      [
        ":h2",
        {
          "s": "Editable view changes"
        }
      ],
      [
        ":p",
        {
          "s": "The editable view (field-view-doc-editable) currently renders "
        },
        [
          ":code",
          {
            "s": ":transclusion"
          }
        ],
        {
          "s": " and "
        },
        [
          ":code",
          {
            "s": ":field-ref"
          }
        ],
        {
          "s": " as non-editable inline chips. After this change:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Chips render for any non-keyword inline expression (not just specific node types)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "The chip display text can be derived from the expression structure (e.g., show item name for "
            },
            [
              ":code",
              {
                "s": "get-field @id ..."
              }
            ],
            {
              "s": ")"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "DOM-to-AST sync reconstructs the expression from chip "
            },
            [
              ":code",
              {
                "s": "data-*"
              }
            ],
            {
              "s": " attributes"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "The "
            },
            [
              ":code",
              {
                "s": "@@"
              }
            ],
            {
              "s": " and "
            },
            [
              ":code",
              {
                "s": "{{"
              }
            ],
            {
              "s": " autocomplete flows produce expression nodes instead of keyword nodes"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Design decisions"
        }
      ],
      [
        ":h3",
        {
          "s": "Provenance is universal"
        }
      ],
      [
        ":p",
        {
