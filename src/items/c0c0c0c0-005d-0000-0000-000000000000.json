                  "s": "let"
                }
              ],
              {
                "s": ", "
              },
              [
                ":code",
                {
                  "s": "map"
                }
              ],
              {
                "s": ", "
              },
              [
                ":code",
                {
                  "s": "if"
                }
              ],
              {
                "s": ", any user-defined macro"
              }
            ],
            [
              ":td",
              {
                "s": "Hob evaluator"
              }
            ]
          ]
        ]
      ],
      [
        ":p",
        [
          ":code",
          {
            "s": ":item-ref"
          }
        ],
        {
          "s": " stays as a renderer node because it's pure structure (a clickable link) — it doesn't fetch or compute anything."
        }
      ],
      [
        ":h2",
        {
          "s": "Legacy transclusion features"
        }
      ],
      [
        ":p",
        {
          "s": "Legacy transclusion ("
        },
        [
          ":item-ref",
          {
            "s": "c0c0c0c0-0035-0000-0000-000000000000"
          },
          {
            "s": "Transclusion"
          }
        ],
        {
          "s": ") supports features beyond simple field access. With inline expression evaluation, these become composable Hob expressions rather than URL query parameters:"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Legacy syntax"
              }
            ],
            [
              ":th",
              {
                "s": "Hob expression"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "![](item://id)"
                }
              ]
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "(transclude @id :description)"
                }
              ],
              {
                "s": " — defaults to "
              },
              [
                ":code",
                {
                  "s": ":description"
                }
              ]
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": "![](item://id#field)"
                }
              ]
            ],
            [
              ":td",
              [
                ":code",
                {
