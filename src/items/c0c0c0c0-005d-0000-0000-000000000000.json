                }
              ]
            ],
            [
              ":td",
              {
                "s": "Renderer directly"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":strong",
                {
                  "s": "Expressions"
                }
              ]
            ],
            [
              ":td",
              [
