{
  "id": "c0c0c0c0-005d-0000-0000-000000000000",
  "name": "Active Text: Inline Expression Evaluation & Macro Unification",
  "type": "871ae771-b9b1-4f40-8c7f-d9038bfb69c3",
  "created": 1741564800000,
  "modified": 1775756671723,
  "content": {
    "description": [
      ":doc",
      [
        ":h1",
        {
          "s": "Active Text: Inline Expression Evaluation & Macro Unification"
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Status:"
          }
        ],
        {
          "s": " Proposal"
        }
      ],
      [
        ":p",
        {
          "s": "The "
        },
        [
          ":code",
          {
            "s": ":doc"
          }
        ],
        {
          "s": " AST currently has two kinds of inline nodes that fetch data at render time: "
        },
        [
          ":code",
          {
            "s": ":field-ref"
          }
        ],
        {
          "s": " and "
        },
        [
          ":code",
          {
            "s": ":transclusion"
          }
        ],
        {
          "s": ". Both are implemented as hardcoded renderer special cases rather than as Hob expressions. This proposal replaces them with standard Hob code, enabled by adding inline expression evaluation to the doc renderer."
        }
      ],
      [
        ":p",
        {
          "s": "See "
        },
        [
          ":item-ref",
          {
            "s": "c0c0c0c0-0058-0000-0000-000000000000"
          },
          {
            "s": "Hob Language Design Direction"
          }
        ],
        {
          "s": " for overall principles. See "
        },
        [
          ":item-ref",
          {
            "s": "c0c0c0c0-0095-0000-0000-000000000000"
          },
          {
            "s": "Active Text Specification"
          }
        ],
        {
          "s": " for the "
        },
        [
          ":code",
          {
            "s": ":doc"
          }
        ],
        {
          "s": " AST spec."
        }
      ],
      [
        ":h2",
        {
          "s": "Current State"
        }
      ],
      [
        ":h3",
        {
          "s": "The two expression-like inline nodes"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "Node"
              }
            ],
            [
              ":th",
              {
                "s": "AST"
              }
            ],
            [
              ":th",
              {
                "s": "Renderer does"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": ":field-ref"
                }
              ]
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "[:field-ref {s: \"weight\"}]"
                }
              ]
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "api.getField(currentItemId, \"weight\")"
                }
              ]
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":code",
                {
                  "s": ":transclusion"
                }
              ]
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "[:transclusion {s: itemId} {s: \"description\"}]"
                }
              ]
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "api.getField(itemId, \"description\")"
                }
              ]
            ]
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "Both call "
        },
        [
          ":code",
          {
            "s": "get-field"
          }
        ],
        {
          "s": " and render the result. The only difference is the target item."
        }
      ],
      [
        ":h3",
        {
          "s": "The dispatch boundary"
        }
      ],
      [
        ":p",
        {
          "s": "The renderer separates structure from computation by tag prefix:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "`:keyword`"
              }
            ],
            {
              "s": " tags → doc structure, renderer handles directly"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Bare symbol"
              }
            ],
            {
              "s": " tags → Hob expression, evaluator handles"
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "This dispatch exists in "
        },
        [
          ":code",
          {
            "s": "renderNode"
          }
        ],
        {
          "s": " (block level) but NOT in "
        },
        [
          ":code",
          {
            "s": "renderInlineNode"
          }
        ],
        {
          "s": ". Hob expressions can only appear at block level today."
        }
      ],
      [
        ":h2",
        {
          "s": "Partially implemented — block-level expression evaluation is working; inline-level evaluation is still a proposal"
        }
      ],
      [
        ":h3",
        {
          "s": "1. Add inline expression evaluation"
        }
      ],
      [
        ":p",
        {
          "s": "Add evaluator fallback to "
        },
        [
          ":code",
          {
            "s": "renderInlineNode"
          }
        ],
        {
          "s": ", matching what "
        },
        [
          ":code",
          {
            "s": "renderNode"
          }
        ],
        {
          "s": " already does at block level:"
        }
      ],
      [
        ":code-block",
        {
          "s": "// In renderInlineNode, after the switch statement:\ndefault: {\n  if (!tag.startsWith(':')) {\n    const result = await api.evaluateHob(node, { item });\n    if (result != null) await renderInlineNode(result, parent, api, item);\n  }\n}"
        }
      ],
      [
        ":p",
        {
          "s": "This is the key enabler. Once inline expressions work, any Hob expression — including macro calls — can appear anywhere in a document."
        }
      ],
      [
        ":h3",
        {
          "s": "2. Replace "
        },
        [
          ":code",
          {
            "s": ":transclusion"
          }
        ],
        {
          "s": " with "
        },
        [
          ":code",
          {
            "s": "get-field"
          }
        ],
        {
          "s": " calls"
        }
      ],
      [
        ":p",
        {
          "s": "The "
        },
        [
          ":code",
          {
            "s": ":transclusion"
          }
        ],
        {
          "s": " node type is removed from the renderer. The stored AST changes from keyword to bare symbol:"
        }
      ],
      [
        ":code-block",
        {
          "s": ";; Before (renderer special case)\n[:transclusion {s: \"item-id\"} {s: \"description\"} {s: \"display\"}]\n\n;; After (standard Hob expression)\n[\"get-field\", \"@item-id\", \":description\"]"
        }
      ],
      [
        ":p",
        {
          "s": "The "
        },
        [
          ":code",
          {
            "s": "@@"
          }
        ],
        {
          "s": " autocomplete in field-view-doc-editable continues to work — it just inserts a "
        },
        [
          ":code",
          {
            "s": "get-field"
          }
        ],
        {
          "s": " call instead of a "
        },
        [
          ":code",
          {
            "s": ":transclusion"
          }
        ],
        {
          "s": " node."
        }
      ],
      [
        ":h3",
        {
          "s": "3. Replace "
        },
        [
          ":code",
          {
            "s": ":field-ref"
          }
        ],
        {
          "s": " with "
        },
        [
          ":code",
          {
            "s": "get-field :self"
          }
        ]
      ],
      [
        ":p",
        {
          "s": "Same treatment:"
        }
      ],
      [
        ":code-block",
        {
          "s": ";; Before\n[:field-ref {s: \"weight\"}]\n\n;; After\n[\"get-field\", \":self\", \":weight\"]"
        }
      ],
      [
        ":p",
        {
          "s": "The "
        },
        [
          ":code",
          {
            "s": "{{"
          }
        ],
        {
          "s": " autocomplete inserts "
        },
        [
          ":code",
          {
            "s": "(get-field :self :fieldName)"
          }
        ],
        {
          "s": " instead of a "
        },
        [
          ":code",
          {
            "s": ":field-ref"
          }
        ],
        {
          "s": " node."
        }
      ],
      [
        ":h3",
        {
          "s": "4. "
        },
        [
          ":code",
          {
            "s": "transclude"
          }
        ],
        {
          "s": " function with chrome/attribution"
        }
      ],
      [
        ":p",
        [
          ":code",
          {
            "s": "transclude"
          }
        ],
        {
          "s": " is a "
        },
        [
          ":strong",
          {
            "s": "function"
          }
        ],
        {
          "s": " (not a macro) that calls "
        },
        [
          ":code",
          {
            "s": "get-field"
          }
        ],
        {
          "s": " AND wraps the result with source attribution metadata:"
        }
      ],
      [
        ":code-block",
        {
          "s": "(transclude @id :description)                 ;; default chrome\n(transclude @id :description :chrome :subtle) ;; small attribution link\n(transclude @id :description :chrome :none)   ;; suppress chrome"
        }
      ],
      [
        ":p",
        {
          "s": "It returns a wrapper value (e.g. "
        },
        [
          ":code",
          {
            "s": "{_hobType: \"transclusion\", value, sourceId, sourceField, chrome}"
          }
        ],
        {
          "s": ") that the renderer detects and turns into attribution UI — a collapsible container with source link, matching the existing transclusion chrome."
        }
      ],
      [
        ":p",
        {
          "s": "This is meaningfully different from bare "
        },
        [
          ":code",
          {
            "s": "get-field"
          }
        ],
        {
          "s": ":"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "get-field"
              }
            ],
            {
              "s": " — data fetch, no attribution"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "transclude"
              }
            ],
            {
              "s": " — data fetch + attribution chrome"
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "The "
        },
        [
          ":code",
          {
            "s": "@@"
          }
        ],
        {
          "s": " autocomplete inserts "
        },
        [
          ":code",
          {
            "s": "transclude"
          }
        ],
        {
          "s": " calls (with chrome). The "
        },
        [
          ":code",
          {
            "s": "{{"
          }
        ],
        {
          "s": " autocomplete inserts "
        },
        [
          ":code",
          {
            "s": "(get-field :self :fieldName)"
          }
        ],
        {
          "s": " directly — local field refs don't need attribution since they reference the current item's own data."
        }
      ],
      [
        ":h2",
        {
          "s": "What this unifies"
        }
      ],
      [
        ":p",
        {
          "s": "After this change, the Active Text format has a clean two-category split:"
        }
      ],
