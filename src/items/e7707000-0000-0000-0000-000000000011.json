    "hob": ";; Error List View — displays all errors newest-first with clear all option\n\n(let [error-type-id \"e7707000-0000-0000-0000-000000000001\"\n\n      ;; Query all errors and sort newest-first\n      all-items (get-all)\n      errors (->> all-items\n                  (filter (fn [i] (= (:type i) error-type-id)))\n                  (sort-by (fn [i] (- (or (get-in i [:content :timestamp]) 0)))))\n      error-count (count errors)\n\n      ;; Find compact-card-view for rendering each error\n      compact-view-id (let [views (find-items {:name \"compact-card-view\"})]\n                        (when (seq views) (:id (first views))))\n\n      ;; Styles\n      s-container \"max-width: 800px; margin: 0 auto; padding: 20px;\"\n      s-header \"display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 2px solid var(--color-border-light);\"\n      s-title \"margin: 0; font-size: 1.25rem;\"\n      s-count \"font-size: 0.875rem; color: var(--color-text-secondary); margin-top: 4px;\"\n      s-btn-group \"display: flex; gap: 8px;\"\n      s-btn-refresh \"padding: 8px 16px; background: var(--color-bg-hover); color: var(--color-text); border: none; border-radius: var(--border-radius); cursor: pointer; font-size: 0.875rem;\"\n      s-btn-clear \"padding: 8px 16px; background: var(--color-danger); color: white; border: none; border-radius: var(--border-radius); cursor: pointer; font-size: 0.875rem;\"\n      s-empty \"padding: 40px; text-align: center; color: var(--color-text-secondary); font-style: italic;\"]\n\n  [:div {:style s-container}\n    ;; Header\n    [:div {:style s-header}\n      [:div {}\n        [:h2 {:style s-title} (or (:name item) \"Error List\")]\n        [:div {:style s-count}\n          (if (= error-count 0)\n            \"No errors\"\n            (str error-count \" error\" (when (not= error-count 1) \"s\")))]]\n      [:div {:style s-btn-group}\n        [:button {:style s-btn-refresh\n                  :on-click (fn [e] (rerender!))}\n          \"Refresh\"]\n        (when (> error-count 0)\n          [:button {:style s-btn-clear\n                    :on-click (fn [e]\n                      (when (confirm (str \"Delete \" error-count \" error\" (when (not= error-count 1) \"s\") \"?\"))\n                        (doseq [err errors] (delete-item! (:id err)))\n                        (rerender!)))}\n            \"Clear All\"])]]\n\n    ;; Error list or empty state\n    (if (= error-count 0)\n      [:div {:style s-empty} \"No errors\"]\n      (for [err errors]\n        (render-item (:id err) compact-view-id)))])\n"
  },
