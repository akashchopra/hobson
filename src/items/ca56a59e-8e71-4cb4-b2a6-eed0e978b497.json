  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "We can determine if there is a risk of collision by continually taking a bearing to the other vessel."
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "If the bearing remains constant, then we will collide"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "If the bearing increases, the other vessel will pass ahead of us"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "If the bearing decreases, the other vessel will pass behind us"
            }
          ]
        ]
      ]
    ],
