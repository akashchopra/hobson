            ]
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "The REPL appears as a collapsible panel at the bottom of the viewport. It persists across page reloads."
        }
      ],
      [
        ":h2",
        {
          "s": "The "
        },
        [
          ":code",
          {
            "s": "api"
          }
        ],
        {
          "s": " Object"
        }
      ],
      [
        ":p",
        {
          "s": "The REPL provides an "
        },
        [
          ":code",
          {
            "s": "api"
          }
        ],
        {
          "s": " object with full access to the system:"
        }
      ],
      [
        ":p",
        {
          "s": "!"
        },
        [
          ":item-ref",
          {
            "s": "33333333-1111-0000-0000-000000000000?symbol=Kernel.createAPI"
          }
        ]
      ],
      [
        ":code-block",
        {
          "s": "const core = await api.get('33333333-1111-0000-0000-000000000000');\nconst symbols = core.content._symbols || {};\n\n// Filter to REPL API methods (direct children only)\nconst apiMethods = Object.entries(symbols)\n  .filter(([key, info]) => {\n    return key.startsWith('Kernel.createAPI.') &&\n           key.split('.').length === 3 &&\n           info.kind.includes('function');\n  })\n  .sort((a, b) => a[1].line - b[1].line);\n\n// Generate markdown table with linked method names\nlet md = '| Method | Signature |\\n|--------|----------|\\n';\nfor (const [key, info] of apiMethods) {\n  // Put full method name inside the link text to avoid markdown parsing issues\n  const link = `[\\`api.${info.name}\\`](item://33333333-1111-0000-0000-000000000000?symbol=${key})`;\n  md += `| ${link} | \\`${info.signature || '()'}\\` |\\n`;\n}\nreturn md;"
        }
      ],
      [
        ":code-block",
        {
          "s": "// Storage operations                  \nawait api.get(id)                // Get item by ID\nawait api.set(item)              // Save item (no re-render)\nawait api.update(item)           // Save item and re-render\nawait api.delete(id)             // Delete item\nawait api.query({ name: 'foo' }) // Find items by properties\nawait api.getAll()               // Get all items\n\n// Code loading\nawait api.require('library-name') // Load a library by name\n\n// Navigation\nawait api.navigate(itemId)        // Navigate to item\nawait api.navigate(id, { field: 'code', line: 42 }) // With scroll target\n\n// Rendering\nawait api.renderItem(itemId)      // Render an item to DOM\nawait api.rerenderItem(itemId)    // Re-render visible instances\nawait api.getViews(typeId)        // Get available views for type\n\n// Events\napi.events.on(eventId, handler)   // Subscribe to events\napi.events.emit({ type, content }) // Emit event\n\n// Import/Export\nawait api.import()                // Import items from JSON file\nawait api.export()                // Export all items to JSON"
        }
