  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Hobson is the code name for this app: a live programming environment where everything is represented uniformly and is editable by the user. This includes the kernel that runs the system, and all of the userland developed features including the entire UI. The system runs entirely in your browser, persisted in IndexedDB, with no server required."
        }
      ],
      [
        ":hr"
      ],
      [
        ":h2",
        {
          "s": "Getting Started"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            {
              "s": "Open "
            },
            [
              ":item-ref",
              {
                "s": "f761e023-da8d-492d-9933-a75adcc8d316"
              },
              {
                "s": "Bootloader"
              }
            ],
            {
              "s": " in a browser"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "On first run, you'll see an import prompt: "
            },
            [
              ":em",
              {
                "s": "\"Hobson needs a kernel to run\""
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Use the "
            },
            [
              ":item-ref",
              {
                "s": "aaaa0001-1000-0000-0000-000000000000"
              },
              {
                "s": "kernel-export"
              }
            ],
            {
              "s": " library to create new import file from your running instance."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Select the JSON file generated in step 3."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "The system reloads and you're live"
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "After the initial import, Hobson persists everything in IndexedDB—edit items, create views, write code, all within Hobson itself."
        }
      ],
      [
        ":p",
        [
          ":strong",
          {
            "s": "Key shortcuts:"
          }
        ]
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":code",
              {
                "s": "Ctrl+Shift+?"
              }
            ],
            {
              "s": " - Show the shortcut help modal"
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "!"
        },
        [
          ":item-ref",
          {
            "s": "f1111111-0006-0000-0000-000000000000?call=buildHelpPanel"
          },
          {
            "s": "Keyboard Shortcuts"
          }
        ]
      ],
      [
        ":hr"
      ],
      [
        ":h2",
        {
          "s": "Philosophy"
        }
      ],
      [
        ":p",
        {
          "s": "Hobson draws from several traditions in interactive computing:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Conway's Humane Dozen"
              }
            ],
            {
              "s": " — Immediate, inspectable, modifiable interfaces"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Smalltalk"
              }
            ],
            {
              "s": " — Image-based persistence where the environment is the application"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Lisp"
              }
            ],
            {
              "s": " — REPL-first development, code as data"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Obenauer's Itemized OS"
              }
            ],
            {
              "s": " — Universal containers and graph-based organization"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Obsidian"
              }
            ],
            {
              "s": " — Bidirectional linking and transclusion"
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "For the full exploration of these ideas, see "
        },
        [
          ":item-ref",
          {
            "s": "a0a0a0a0-d0c0-4000-8000-000000000001"
          },
          {
            "s": "Philosophy & Inspirations"
          }
        ],
        {
          "s": "."
        }
      ],
      [
        ":hr"
      ],
      [
        ":h2",
        {
          "s": "Documentation"
        }
      ],
      [
        ":h3",
        {
          "s": "Conceptual"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "a0a0a0a0-d0c0-4000-8000-000000000002"
              },
              {
                "s": "Core Concepts"
              }
            ],
            {
              "s": " — Items, types, code as data, views"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "a0a0a0a0-d0c0-4000-8000-000000000003"
              },
              {
                "s": "Architecture Overview"
              }
            ],
            {
              "s": " — Bootstrap, kernel modules, boot process"
            }
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "Technical"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "a0a0a0a0-d0c0-4000-8000-000000000004"
              },
              {
                "s": "Views & Rendering"
              }
            ],
            {
              "s": " — View lookup, renderer API, partial re-rendering"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "ef793c27-2d4b-4c99-b05a-2769db5bc5a9"
              },
              {
                "s": "Spatial Windowing"
              }
            ],
            {
              "s": "  — 2D canvas, window management, sibling containers"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "a0a0a0a0-d0c0-4000-8000-000000000006"
              },
              {
                "s": "Events System"
              }
            ],
            {
              "s": " — Type-hierarchy dispatch, declarative watches"
            }
          ]
        ]
      ],
      [
        ":hr"
      ],
      [
        ":h2",
        {
          "s": "Kernel Modules"
        }
      ],
      [
        ":p",
        {
          "s": "The kernel is decomposed into focused subsystems:"
        }
      ],
      [
        ":code-block",
        {
          "s": "const modules = await api.query({ type: api.IDS.KERNEL_MODULE });\nmodules.sort((a, b) => (a.name || '').localeCompare(b.name || ''));\nreturn transcludeEach(modules, m =>\n  `- [${m.name}](item://${m.id}) — ${m.content?.description?.split('\\n')[0] || 'No description'}`\n);"
        }
      ],
      [
        ":hr"
      ],
      [
        ":h2",
        {
          "s": "Views"
        }
      ],
      [
        ":p",
        {
          "s": "Views render items. The system discovers views by type and preference:"
        }
      ],
      [
        ":code-block",
        {
          "s": "const views = await api.query({ type: api.IDS.VIEW });\nconst userViews = views.filter(v => v.content?.displayName);\nuserViews.sort((a, b) => (a.content?.displayName || '').localeCompare(b.content?.displayName || ''));\nreturn transcludeEach(userViews, v =>\n  `- **${v.content.displayName}** ([${v.name}](item://${v.id})) — ${v.content.description?.split('\\n')[0] || 'No description'}`\n);"
        }
      ],
      [
        ":hr"
      ],
      [
        ":h2",
        {
          "s": "Libraries"
        }
      ],
      [
        ":p",
        {
          "s": "Reusable code modules loaded via "
        },
        [
          ":code",
          {
            "s": "api.require('name')"
          }
        ],
        {
          "s": ":"
        }
      ],
      [
        ":code-block",
        {
          "s": "const libs = await api.query({ type: api.IDS.LIBRARY });\nlibs.sort((a, b) => (a.name || '').localeCompare(b.name || ''));\nreturn transcludeEach(libs, lib =>\n  `- [${lib.name}](item://${lib.id}) — ${lib.content?.description?.split('\\n')[0] || 'No description'}`\n);"
        }
      ],
      [
        ":hr"
      ],
      [
        ":h2",
        {
          "s": "Seed Items"
        }
      ],
      [
        ":p",
        {
          "s": "Foundational items with well-known GUIDs:"
        }
      ],
      [
        ":p",
        {
          "s": "!"
        },
        [
          ":item-ref",
          {
            "s": "33333333-1111-0000-0000-000000000000#code?symbol=IDS"
          },
          {
            "s": "kernel:core SEED_IDS"
          }
        ]
      ],
      [
        ":hr"
      ],
      [
        ":h2",
        {
          "s": "Safe Mode"
        }
      ],
      [
        ":p",
        {
          "s": "If userland code breaks the system, add "
        },
        [
          ":code",
          {
            "s": "?safe=1"
          }
        ],
        {
          "s": " to the URL (or press "
        },
        [
          ":code",
          {
            "s": "Ctrl+Shift+S"
          }
        ],
        {
          "s": "). Safe mode boots only the kernel and provides:"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Item browser with raw JSON editing"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Export/import for backup and recovery"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "System reset option"
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "See "
        },
        [
          ":item-ref",
          {
            "s": "33333333-7777-0000-0000-000000000000"
          },
          {
            "s": "kernel:safe-mode"
          }
        ],
        {
          "s": " for implementation."
        }
      ],
      [
        ":hr"
      ],
