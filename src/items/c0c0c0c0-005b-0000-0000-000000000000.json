{
  "id": "c0c0c0c0-005b-0000-0000-000000000000",
  "name": "Container-Handled Open Intent",
  "type": "871ae771-b9b1-4f40-8c7f-d9038bfb69c3",
  "created": 1741219200000,
  "modified": 1773243817614,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Container views now handle open-item intents directly, instead of "
        },
        [
          ":code",
          {
            "s": "openItem"
          }
        ],
        {
          "s": " bypassing the container and going straight to "
        },
        [
          ":code",
          {
            "s": "kernel.attach"
          }
        ],
        {
          "s": "."
        }
      ],
      [
        ":h2",
        {
          "s": "The Problem"
        }
      ],
      [
        ":p",
        [
          ":code",
          {
            "s": "openItem"
          }
        ],
        {
          "s": " used to call "
        },
        [
          ":code",
          {
            "s": "kernel.attach(target, itemIdOrAttachment)"
          }
        ],
        {
          "s": " directly. This caused two issues:"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "`kernel.attach` clobbers"
              }
            ],
            {
              "s": " — replaces the entire attachment, losing position ("
            },
            [
              ":code",
              {
                "s": "x"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "y"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "w"
              }
            ],
            {
              "s": ", "
            },
            [
              ":code",
              {
                "s": "h"
              }
            ],
            {
              "s": "). This was deliberate (commit "
            },
            [
              ":code",
              {
                "s": "208350d"
              }
            ],
            {
              "s": ") to fix minimized items not restoring, but it's a blunt fix."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "No way to update `navigateTo` on an already-visible item"
              }
            ],
            {
              "s": " — morphdom skipped re-rendering because "
            },
            [
              ":code",
              {
                "s": "data-child-item"
              }
            ],
            {
              "s": " and "
            },
            [
              ":code",
              {
                "s": "data-child-view"
              }
            ],
            {
              "s": " hadn't changed."
            }
          ]
        ]
      ],
      [
        ":p",
        {
          "s": "Every attempted fix leaked canvas knowledge ("
        },
        [
          ":code",
          {
            "s": "minimized"
          }
        ],
        {
          "s": ", "
        },
        [
          ":code",
          {
            "s": "z"
          }
        ],
        {
          "s": ", position) into the viewport layer."
        }
      ],
      [
        ":h2",
        {
          "s": "Solution: "
        },
        [
          ":code",
          {
            "s": ":open-item"
          }
        ],
        {
          "s": " on "
        },
        [
          ":code",
          {
            "s": ":render-child"
          }
        ]
      ],
      [
        ":p",
        {
          "s": "Container views provide an "
        },
        [
          ":code",
          {
            "s": ":open-item"
          }
        ],
        {
          "s": " handler function on their "
        },
        [
          ":code",
          {
            "s": ":render-child"
          }
        ],
        {
          "s": " elements. This function receives the "
        },
        [
          ":code",
          {
            "s": "itemIdOrAttachment"
          }
        ],
        {
          "s": " argument and handles attach/bring-to-front/unminimize/navigateTo with full knowledge of its own schema."
        }
      ],
      [
        ":h3",
        {
          "s": "How it works"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "`openItem`"
              }
            ],
            {
              "s": " (viewport-rendering) handles Ctrl/Alt modifiers, then delegates to the container's handler via "
            },
            [
              ":code",
              {
                "s": "context.openItemFn"
              }
            ],
            {
              "s": ". Falls back to the old "
            },
            [
              ":code",
              {
                "s": "openIn"
              }
            ],
            {
              "s": "/attach path if no handler."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Container handler"
              }
            ],
            {
              "s": " (e.g. spatial canvas) does an atomic mutation: checks if already attached, unminimizes, brings to front, sets navigateTo — one "
            },
            [
              ":code",
              {
                "s": "set-item!"
              }
            ],
            {
              "s": " call, one re-render."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Morphdom"
              }
            ],
            {
              "s": " compares "
            },
            [
              ":code",
              {
                "s": "data-navigate-to"
              }
            ],
            {
              "s": " attribute alongside "
            },
            [
              ":code",
              {
                "s": "data-child-item"
              }
            ],
            {
              "s": "/"
            },
            [
              ":code",
              {
                "s": "data-child-view"
              }
            ],
            {
              "s": ". When navigateTo changes, the child re-renders and scrolls to the symbol."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Selector"
              }
            ],
            {
              "s": " includes "
            },
            [
              ":code",
              {
                "s": "navigateTo"
              }
            ],
            {
              "s": " so the reactive system triggers re-render when it changes."
            }
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "What changed"
        }
      ],
      [
        ":table",
        [
          ":thead",
          [
            ":tr",
            [
              ":th",
              {
                "s": "File"
              }
            ],
            [
              ":th",
              {
                "s": "Change"
              }
            ]
          ]
        ],
        [
          ":tbody",
          [
            ":tr",
            [
              ":td",
              [
                ":item-ref",
                {
                  "s": "f1111111-0008-0000-0000-000000000000"
                },
                {
                  "s": "viewport-rendering"
                }
              ]
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "openItem"
                }
              ],
              {
                "s": " delegates to "
              },
              [
                ":code",
                {
                  "s": "context.openItemFn"
                }
              ],
              {
                "s": "; morphdom compares "
              },
              [
                ":code",
                {
                  "s": "data-navigate-to"
                }
              ],
              {
                "s": "; "
              },
              [
                ":code",
                {
                  "s": "fillMountPoints"
                }
              ],
              {
                "s": " inherits "
              },
              [
                ":code",
                {
                  "s": "openItemFn"
                }
              ],
              {
                "s": " from parent context; instance stores/recovers "
              },
              [
                ":code",
                {
                  "s": "openItemFn"
                }
              ]
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":item-ref",
                {
                  "s": "40b00001-0000-4000-8000-000000000000"
                },
                {
                  "s": "hob-interpreter"
                }
              ]
            ],
            [
              ":td",
              {
                "s": "Parses "
              },
              [
                ":code",
                {
                  "s": ":open-item"
                }
              ],
              {
                "s": " on "
              },
              [
                ":code",
                {
                  "s": ":render-child"
                }
              ],
              {
                "s": "; sets "
              },
              [
                ":code",
                {
                  "s": "data-navigate-to"
                }
              ],
              {
                "s": " attribute"
              }
            ]
          ],
          [
            ":tr",
            [
              ":td",
              [
                ":item-ref",
                {
                  "s": "ef793c27-2d4b-4c99-b05a-2769db5bc5a9"
                },
                {
                  "s": "spatial-canvas-view"
                }
              ]
            ],
            [
              ":td",
              [
                ":code",
                {
                  "s": "open-item-handler"
                }
              ],
              {
                "s": " function replaces "
              },
              [
                ":code",
                {
                  "s": ":open-in"
                }
              ],
              {
                "s": "; selector includes "
              },
              [
                ":code",
                {
                  "s": "navigateTo"
                }
              ]
            ]
          ]
        ]
      ],
      [
        ":h3",
        {
          "s": "Backwards compatible"
        }
      ],
      [
        ":p",
        {
          "s": "Views that still use "
        },
        [
          ":code",
          {
            "s": ":open-in"
          }
        ],
        {
          "s": " (sortable-list, modal-frame, error-list, app-page) continue working via the fallback path. They can be migrated to "
        },
        [
          ":code",
          {
            "s": ":open-item"
          }
        ],
        {
          "s": " later."
        }
      ],
      [
        ":h3",
        {
          "s": "Relation to "
        },
        [
          ":code",
          {
            "s": "siblingContainer"
          }
        ]
      ],
      [
        ":p",
        {
          "s": "This replaces the same need that "
        },
        [
          ":code",
          {
            "s": "siblingContainer"
          }
        ],
        {
          "s": " (removed in "
        },
        [
          ":code",
          {
            "s": "5e04db8"
          }
        ],
        {
          "s": ") addressed — letting the container control how items are opened within it. But instead of threading invisible capability objects through the render tree, the handler is an explicit function on "
        },
        [
          ":code",
          {
            "s": ":render-child"
          }
        ],
        {
          "s": " that inherits through context."
        }
      ],
      [
        ":h2",
        {
          "s": "See Also"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "c0c0c0c0-005a-0000-0000-000000000000"
              },
              {
                "s": "Auto-Generated Diagrams"
              }
            ],
            {
              "s": " — Where this was discovered"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "c0c0c0c0-0091-0000-0000-000000000000"
              },
              {
                "s": "System Layers"
              }
            ],
            {
              "s": " — Layer boundaries"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":item-ref",
              {
                "s": "c0c0c0c0-0006-0000-0000-000000000000"
              },
              {
                "s": "Event System"
              }
            ],
            {
              "s": " — Declarative watches"
            }
          ]
        ]
      ]
    ],
