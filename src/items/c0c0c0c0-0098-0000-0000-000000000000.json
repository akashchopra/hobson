      [
        ":hr"
      ],
      [
        ":h2",
        {
          "s": "Assessment"
        }
      ],
      [
        ":p",
        {
          "s": "All metrics are acceptable. A.load() is the only concern, but full boot simulation across all 337 real items shows 1.49s total — dominated by a handful of large library items. Storage is a net win: Automerge binary is 39% smaller than JSON (2.34 MB vs 3.82 MB). With lazy loading, perceived boot cost would be well under 200ms."
        }
      ],
      [
        ":h3",
        {
          "s": "Recommended approach: lazy loading"
        }
      ],
      [
        ":p",
        {
          "s": "Load only the items needed for the initial view at boot (~5-10 items, ~50ms). Background-load remaining items after first paint. This eliminates perceived boot cost while using Automerge as the sole storage layer — no dual-store complexity needed."
        }
      ],
      [
        ":h3",
        {
          "s": "Other mitigations (if needed)"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Metadata index."
              }
            ],
            {
              "s": " A lightweight IDB store with (id, name, type, tags) for each item, updated on every write. Avoids deserializing all Automerge docs for search/listing. Bulk queries hit the index; full docs loaded on-demand."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Worker-based deserialisation."
              }
            ],
            {
              "s": " Move A.load() to a Web Worker so background loading doesn't block the main thread."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            [
              ":strong",
              {
                "s": "Dual-store (fallback)."
              }
            ],
            {
              "s": " If lazy loading proves insufficient, store both JSON (for fast reads) and Automerge binary (for history/sync) in IDB. Adds write-path complexity but preserves current boot speed exactly."
            }
          ]
        ]
      ],
      [
        ":hr"
      ],
      [
        ":h2",
        {
          "s": "What We Know So Far"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Automerge supports maps, lists, text (with rich-text marks), strings, booleans, null, integers, floats, counters, timestamps, bytes — a superset of JSON."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Documents read like plain JS objects (proxy-based). JSON.stringify() works directly."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Documents are immutable outside of A.change() — callers need a mutable clone, which is why the plain-object conversion on read is functionally necessary."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Active Text ASTs (nested arrays of mixed types) work natively. Fine-grained mutations on nested elements are supported. Replacing whole subtrees works but loses merge granularity."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "A.view(doc, oldHeads) gives cheap read-only snapshots at any historical state (shares memory, no copying). A.diff() returns structured patches."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "No built-in undo — implemented via patch inversion (capture reverse patches during A.change(), apply them to revert)."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Storage: A.save() produces compact binary (Uint8Array) for IDB. A.load() restores. No need for automerge-repo for basic persistence."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Automerge 3.0 has 10x memory improvement over 2.0. Plain strings are collaborative by default; use A.ImmutableString for atomic strings (GUIDs, type IDs)."
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "PouchDB was considered but rejected — its revision system discards old bodies on compaction, making it unsuitable for version history."
            }
          ]
        ]
