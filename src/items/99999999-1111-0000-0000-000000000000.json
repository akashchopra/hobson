{
  "id": "99999999-1111-0000-0000-000000000000",
  "type": "aaaaaaaa-0000-0000-0000-000000000000",
  "name": "hobson-instance-view",
  "created": 1769072570000,
  "modified": 1773243817079,
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Renders a hobson-instance item as a fully isolated nested Hobson environment inside an iframe."
        }
      ],
      [
        ":h2",
        {
          "s": "How It Works"
        }
      ],
      [
        ":ol",
        [
          ":li",
          [
            ":p",
            {
              "s": "Builds instance ID by chaining parent's instance ID with item ID"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Creates iframe pointing to "
            },
            [
              ":code",
              {
                "s": "bootstrap.html?instance=<id>"
              }
            ]
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "The bootloader uses this instance ID as a storage prefix, creating isolated IndexedDB namespace"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Nested kernel boots independently with its own items"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "UI Elements"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Header bar matching spatial window chrome"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Back button for nested instance history navigation (tracks pushState depth to prevent escaping into parent)"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Reload button to refresh nested instance"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "\"Open in Tab\" button to open in new browser tab"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Loading indicator during iframe load"
            }
          ]
        ]
      ],
      [
        ":h2",
        {
          "s": "Use Cases"
        }
      ],
      [
        ":ul",
        [
          ":li",
          [
            ":p",
            {
              "s": "Sandboxed kernel development/testing"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Multiple isolated workspaces"
            }
          ]
        ],
        [
          ":li",
          [
            ":p",
            {
              "s": "Experimenting with kernel modifications safely"
            }
          ]
        ]
      ]
    ],
