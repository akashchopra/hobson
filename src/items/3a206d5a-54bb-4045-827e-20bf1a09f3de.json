  "name": "markdown-it-wrapper",
  "type": "66666666-0000-0000-0000-000000000000",
  "content": {
    "description": [
      ":doc",
      [
        ":p",
        {
          "s": "Wrapper that initializes markdown-it with HTML enabled using the global "
        },
        [
          ":code",
          {
            "s": "window.markdownit"
          }
        ],
        {
          "s": " function (loaded by "
        },
        [
          ":item-ref",
          {
            "s": "08d5ecd2-01a1-43f1-ad50-314027db231a"
          },
          {
            "s": "markdown-it"
          }
        ],
        {
          "s": "), and exports the configured instance as an ES module."
        }
      ],
      [
        ":h2",
        {
          "s": "Usage"
        }
      ],
      [
        ":code-block",
        {
          "s": "await api.require('markdown-it'); // Must load first to set window.markdownit\nconst md = await api.require('markdown-it-wrapper');\nconst html = md.render('# Hello **world**');"
        }
      ],
      [
        ":h2",
        {
          "s": "Configuration"
        }
      ],
      [
        ":p",
        {
          "s": "Initialized with "
        },
        [
          ":code",
          {
            "s": "{ html: true }"
          }
        ],
        {
          "s": " to allow raw HTML passthrough in markdown content."
        }
      ]
    ],
    "code": "const md = window.markdownit({ html: true });\nexport default md;",
