{
  "$schema": "https://raw.githubusercontent.com/nickersoft/tauri/v2/packages/tauri/schema.json",
  "productName": "Hobson",
  "version": "0.1.0",
  "identifier": "dev.hobson.app",
  "build": {
    "beforeDevCommand": "cp src/bootloader.html frontend/index.html",
    "beforeBuildCommand": "cp src/bootloader.html frontend/index.html",
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Hobson",
        "url": "index.html",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: https://asset.localhost; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: https://esm.sh; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data: blob:; connect-src 'self' ipc: http://ipc.localhost asset: https://asset.localhost https: http: ws: wss: data: blob:; font-src 'self' data:; worker-src 'self' blob:",
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
